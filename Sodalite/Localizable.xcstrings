    "changelog.0_10_0.mergedRow.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Volitelně sloučíte Další do řady Pokračovat ve sledování, jedna řada pro vše rozkoukané. Přepíná se v nabídce Přizpůsobit domov."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fold valgfrit Næste ind i rækken Fortsæt med at se, én række til alt det, du er i gang med. Slå det til under Tilpas hjem."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lege Als Nächstes optional in die Weiterschauen-Reihe, eine Reihe für alles, was du gerade schaust. Umschaltbar unter Startseite anpassen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Προαιρετικά ενσωματώστε το Επόμενο στη σειρά Συνέχιση παρακολούθησης, μία σειρά για όλα όσα παρακολουθείτε. Ενεργοποιείται στην Προσαρμογή αρχικής."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Optionally fold Next Up into the Continue Watching row, one row for everything you are in the middle of. Toggle it under Customize Homepage."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Integra opcionalmente Siguiente en la fila Seguir viendo, una sola fila para todo lo que tienes a medias. Actívalo en Personalizar inicio."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Voit halutessasi yhdistää Seuraavaksi-rivin Jatka katselua -riviin, yksi rivi kaikelle kesken olevalle. Kytke se päälle kohdassa Mukauta aloitusnäyttö."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Intégrez si vous le souhaitez À suivre dans la rangée Continuer à regarder, une seule rangée pour tout ce que vous avez en cours. À activer dans Personnaliser l'accueil."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Po želji uklopite Sljedeće u red Nastavi gledanje, jedan red za sve što ste započeli. Uključuje se pod Prilagodi početnu."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Igény szerint beolvaszthatod a Következő sort a Folytatás sorba, egyetlen sor mindenhez, ami félbemaradt. A Kezdőképernyő testreszabása alatt kapcsolhatod be."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Se vuoi, unisci Prossimo alla riga Continua a guardare, una sola riga per tutto ciò che hai a metà. Si attiva in Personalizza home."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "オプションで「次の再生」を「視聴を続ける」の列にまとめられます。視聴中の作品がひとつの列に収まります。「ホームをカスタマイズ」で切り替えられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "원하면 다음을 계속 시청 행에 합칠 수 있습니다. 보던 작품을 하나의 행에서 확인하세요. 홈 사용자 지정에서 전환할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fold eventuelt Neste inn i raden Fortsett å se, én rad for alt du er midt i. Slå det på under Tilpass hjem."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Voeg desgewenst Volgende samen met de rij Verder kijken, één rij voor alles waar je middenin zit. In te schakelen onder Home aanpassen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Opcjonalnie scal Następne z wierszem Kontynuuj oglądanie, jeden wiersz na wszystko, co masz w trakcie. Włączysz to w sekcji Dostosuj stronę główną."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Se quiser, integre Próximo à fileira Continuar assistindo, uma única fileira para tudo o que você está no meio. Ative em Personalizar início."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Se quiser, integre A seguir na fila Continuar a ver, uma única fila para tudo o que tem a meio. Ative em Personalizar início."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Opțional, integrează Următorul în rândul Continuă vizionarea, un singur rând pentru tot ce ai început. Se activează din Personalizează ecranul principal."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "При желании объедините Далее со строкой Продолжить просмотр, одна строка для всего, что вы смотрите. Включается в разделе Настроить главную."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Voliteľne zlúčite Ďalšie do radu Pokračovať v sledovaní, jeden rad pre všetko rozpozerané. Prepína sa v časti Prispôsobiť domov."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vik valfritt in Nästa i raden Fortsätt titta, en enda rad för allt du håller på med. Slå på det under Anpassa hem."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "İsterseniz Sırada bölümünü İzlemeye Devam Et satırına ekleyin; yarıda kalan her şey tek satırda. Ana Ekranı Özelleştir altından açıp kapatabilirsiniz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "За бажанням об'єднайте Наступне з рядком Продовжити перегляд, один рядок для всього, що ви дивитеся. Вмикається в розділі Налаштувати головну."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "可选择将接下来并入继续观看一行，所有看了一半的内容集中在一行。可在自定义首页中开关。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "可選擇將接下來併入繼續觀看一列，所有看到一半的內容集中在一列。可在自訂主畫面中切換。"
          }
        }
      }
    },
