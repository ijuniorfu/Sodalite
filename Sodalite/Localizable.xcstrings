    "changelog.0_4_0.tintButtons.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tlačítka zůstávají čitelná bez ohledu na vybranou barvu zvýraznění."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Knapper forbliver læsbare uanset hvilken accentfarve du vælger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Buttons bleiben lesbar, egal welche Akzentfarbe du wählst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα κουμπιά παραμένουν ευανάγνωστα ανεξάρτητα από το χρώμα τονισμού που επιλέγετε."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Buttons stay legible no matter which accent colour you pick."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los botones se mantienen legibles sin importar qué color de acento elijas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Painikkeet pysyvät luettavina riippumatta valitsemastasi korostusväristä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les boutons restent lisibles quelle que soit la couleur d'accentuation choisie."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tipke ostaju čitljive bez obzira na to koju boju isticanja odaberete."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A gombok minden választott kiemelőszín mellett olvashatók maradnak."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I pulsanti restano leggibili indipendentemente dal colore d'accento scelto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "選んだアクセントカラーに関わらず、ボタンが見やすくなりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "어떤 강조 색상을 선택해도 버튼이 잘 보이도록 개선되었습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Knappene forblir lesbare uansett hvilken aksentfarge du velger."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Knoppen blijven leesbaar, ongeacht welke accentkleur je kiest."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Przyciski pozostają czytelne niezależnie od wybranego koloru akcentu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os botões continuam legíveis, não importa qual cor de destaque você escolha."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os botões mantêm-se legíveis independentemente da cor de destaque escolhida."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Butoanele rămân lizibile indiferent de culoarea de accent aleasă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Кнопки остаются читаемыми при любом выбранном акцентном цвете."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tlačidlá zostávajú čitateľné bez ohľadu na zvolenú akcentovú farbu."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Knapparna förblir läsbara oavsett vilken accentfärg du väljer."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hangi vurgu rengini seçerseniz seçin, düğmeler okunabilir kalır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Кнопки залишаються читабельними незалежно від обраного акцентного кольору."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "无论选择哪种强调色，按钮都保持清晰可读。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "無論選擇哪種強調色，按鈕都保持清晰可讀。"
          }
        }
      }
    },
