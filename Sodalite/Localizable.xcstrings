    "changelog.0_11_0.detailRedesign.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kompaktnější informační panel s tlačítky akcí na vlastním řádku pod ním, uspořádanější metadata a kolekce nyní sdílejí stejné rozložení jako filmy a seriály."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Et mere kompakt infopanel med handlingsknapperne på deres egen række nedenunder, pænere metadata, og samlinger bruger nu samme layout som film og serier."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kompakteres Info-Panel mit eigener Button-Zeile darunter, aufgeräumtere Metadaten, und Sammlungen nutzen jetzt dasselbe Layout wie Filme und Serien."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Πιο συμπαγές πάνελ πληροφοριών με τα κουμπιά ενεργειών σε δική τους σειρά από κάτω, πιο τακτικά μεταδεδομένα, και οι συλλογές χρησιμοποιούν πλέον την ίδια διάταξη με ταινίες και σειρές."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A more compact info panel with the action buttons on their own row below it, tidier metadata, and collections now share the same layout as movies and series."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un panel de información más compacto con los botones de acción en su propia fila debajo, metadatos más ordenados, y las colecciones ahora comparten el mismo diseño que películas y series."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tiiviimpi tietopaneeli, toimintopainikkeet omalla rivillään sen alla, siistimmät metatiedot, ja kokoelmat käyttävät nyt samaa asettelua kuin elokuvat ja sarjat."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un panneau d'informations plus compact avec les boutons d'action sur leur propre ligne en dessous, des métadonnées mieux rangées, et les collections partagent désormais la même mise en page que les films et les séries."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kompaktnija info ploča s gumbima radnji u vlastitom retku ispod nje, uredniji metapodaci, a kolekcije sada dijele isti raspored kao filmovi i serije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tömörebb információs panel, alatta a műveletgombok saját sorban, rendezettebb metaadatok, a gyűjtemények pedig mostantól ugyanazt az elrendezést használják, mint a filmek és sorozatok."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un pannello informazioni più compatto con i pulsanti delle azioni su una riga dedicata sotto di esso, metadati più ordinati, e le raccolte ora condividono lo stesso layout di film e serie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "情報パネルがよりコンパクトになり、アクションボタンはその下の専用の行に移動しました。メタデータも整理され、コレクションは映画やシリーズと同じレイアウトになりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "정보 패널이 더 콤팩트해지고 동작 버튼이 그 아래 전용 줄로 이동했으며, 메타데이터가 정리되고 컬렉션도 영화 및 시리즈와 같은 레이아웃을 사용합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Et mer kompakt infopanel med handlingsknappene på en egen rad under, ryddigere metadata, og samlinger bruker nå samme oppsett som filmer og serier."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Een compacter infopaneel met de actieknoppen op een eigen rij eronder, nettere metadata, en collecties gebruiken nu dezelfde lay-out als films en series."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bardziej kompaktowy panel informacji z przyciskami akcji w osobnym wierszu poniżej, uporządkowane metadane, a kolekcje korzystają teraz z tego samego układu co filmy i seriale."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Um painel de informações mais compacto com os botões de ação em uma linha própria abaixo dele, metadados mais organizados, e as coleções agora usam o mesmo layout de filmes e séries."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Um painel de informações mais compacto com os botões de ação numa linha própria por baixo, metadados mais arrumados, e as coleções usam agora a mesma disposição que filmes e séries."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un panou de informații mai compact, cu butoanele de acțiune pe propriul rând dedesubt, metadate mai ordonate, iar colecțiile folosesc acum același aspect ca filmele și serialele."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Более компактная информационная панель, кнопки действий в отдельном ряду под ней, упорядоченные метаданные, а коллекции теперь используют ту же компоновку, что фильмы и сериалы."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kompaktnejší informačný panel s tlačidlami akcií vo vlastnom riadku pod ním, upratanejšie metadáta a kolekcie teraz zdieľajú rovnaké rozloženie ako filmy a seriály."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En mer kompakt informationspanel med åtgärdsknapparna på en egen rad under den, prydligare metadata, och samlingar använder nu samma layout som filmer och serier."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Daha kompakt bilgi paneli, altında kendi satırında eylem düğmeleri, daha düzenli meta veriler ve koleksiyonlar artık film ve dizilerle aynı düzeni kullanıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Компактніша інформаційна панель, кнопки дій в окремому рядку під нею, упорядковані метадані, а колекції тепер використовують те саме компонування, що й фільми та серіали."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "信息面板更紧凑，操作按钮移到面板下方的单独一行，元数据更整齐，合集现在与电影和剧集使用相同的布局。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "資訊面板更精簡，操作按鈕移至面板下方的獨立一列，中繼資料更整齊，合輯現在與電影和影集使用相同的版面配置。"
          }
        }
      }
    },
