          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os perfis protegidos exigem o PIN para trocar de perfil, sair ou abrir as configurações"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os perfis protegidos exigem o PIN para mudar de perfil, terminar sessão ou abrir as definições"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Profilurile protejate necesită codul PIN pentru a schimba profilul, a te deconecta sau a deschide setările"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
