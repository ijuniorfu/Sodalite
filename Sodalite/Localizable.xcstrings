    "changelog.0_9_0.restart.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Samostatné tlačítko u seriálů a epizod přehraje od začátku místo pokračování tam, kde jste skončili."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En dedikeret knap på serier og episoder afspiller fra begyndelsen i stedet for at fortsætte, hvor du slap."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ein eigener Button bei Serien und Episoden startet von Anfang an, statt dort fortzusetzen, wo du aufgehört hast."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ένα ειδικό κουμπί σε σειρές και επεισόδια ξεκινά την αναπαραγωγή από την αρχή αντί να συνεχίζει από εκεί που σταματήσατε."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A dedicated button on series and episodes plays from the start instead of resuming where you left off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un botón específico en series y episodios reproduce desde el principio en lugar de continuar donde lo dejaste."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sarjojen ja jaksojen oma painike toistaa alusta sen sijaan, että jatkaisi keskeytyskohdasta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un bouton dédié sur les séries et les épisodes lance la lecture depuis le début au lieu de reprendre là où vous vous étiez arrêté."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zasebni gumb na serijama i epizodama pokreće reprodukciju od početka umjesto nastavka tamo gdje ste stali."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A sorozatoknál és epizódoknál külön gomb játssza le az elejéről ahelyett, hogy onnan folytatná, ahol abbahagytad."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un pulsante dedicato su serie ed episodi avvia la riproduzione dall'inizio invece di riprendere da dove avevi interrotto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "シリーズやエピソードの専用ボタンで、続きからではなく最初から再生できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "시리즈와 에피소드의 전용 버튼으로 이어보기 대신 처음부터 재생할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En egen knapp på serier og episoder spiller av fra begynnelsen i stedet for å fortsette der du slapp."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Een aparte knop bij series en afleveringen speelt vanaf het begin in plaats van verder te gaan waar je was gebleven."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Osobny przycisk przy serialach i odcinkach odtwarza od początku zamiast wznawiać w miejscu, w którym skończyłeś."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Um botão dedicado em séries e episódios inicia a reprodução do começo em vez de continuar de onde você parou."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Um botão dedicado nas séries e episódios reproduz desde o início em vez de continuar de onde ficou."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un buton dedicat pe seriale și episoade pornește redarea de la început în loc să continue de unde ai rămas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Отдельная кнопка у сериалов и серий запускает воспроизведение с начала вместо продолжения с места остановки."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Samostatné tlačidlo pri seriáloch a epizódach prehrá od začiatku namiesto pokračovania tam, kde ste skončili."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En särskild knapp på serier och avsnitt spelar upp från början i stället för att fortsätta där du slutade."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dizilerde ve bölümlerde özel bir düğme, kaldığınız yerden devam etmek yerine baştan oynatır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Окрема кнопка для серіалів та епізодів запускає відтворення з початку замість продовження з місця зупинки."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "剧集和单集新增专用按钮，可从头播放而非从上次中断处继续。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "影集與單集新增專用按鈕，可從頭播放，而非從上次中斷處繼續。"
          }
        }
      }
    },
