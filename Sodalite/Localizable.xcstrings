    "changelog.0_5_0.hdr10Plus.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Metadata ST 2094-40 pro každý snímek se předávají do displeje, takže televizory HDR10+ aplikují tone-mapping křivky zdroje místo návratu na statickou základní vrstvu HDR10."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ST 2094-40-metadata pr. billede videresendes til skærmen, så HDR10+-tv'er anvender kildens tonemapping-kurver i stedet for at falde tilbage til det statiske HDR10-basislag."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Die ST-2094-40-Metadaten pro Bild werden an das Display weitergereicht, sodass HDR10+-Fernseher die Tone-Mapping-Kurven der Quelle anwenden statt auf das statische HDR10-Basis-Layer zurückzufallen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα μεταδεδομένα ST 2094-40 ανά καρέ προωθούνται στην οθόνη, ώστε οι τηλεοράσεις HDR10+ να εφαρμόζουν τις καμπύλες αντιστοίχισης τόνων της πηγής αντί να επιστρέφουν στο στατικό βασικό επίπεδο HDR10."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Per-frame ST 2094-40 dynamic metadata is forwarded to the display, so HDR10+ TVs apply the source's tone-mapping curves instead of falling back to the static HDR10 base layer."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los metadatos ST 2094-40 por fotograma se reenvían a la pantalla, de modo que los televisores HDR10+ aplican las curvas de mapeo de tonos de la fuente en lugar de usar la capa base HDR10 estática."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ruutukohtaiset ST 2094-40 -metatiedot välitetään näytölle, jolloin HDR10+-televisiot käyttävät lähteen sävykartoituskäyriä staattisen HDR10-perustason sijaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les métadonnées ST 2094-40 image par image sont transmises à l'écran, de sorte que les téléviseurs HDR10+ appliquent les courbes de tone-mapping de la source au lieu de retomber sur la couche HDR10 statique."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Metapodaci ST 2094-40 po svakom kadru prosljeđuju se zaslonu, pa HDR10+ televizori primjenjuju krivulje mapiranja tonova izvora umjesto da se vraćaju na statični HDR10 osnovni sloj."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A ST 2094-40 képkockánkénti metaadatokat továbbítjuk a kijelzőre, így a HDR10+-tévék a forrás tónusleképezési görbéit alkalmazzák a statikus HDR10-alapréteg helyett."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I metadati ST 2094-40 fotogramma per fotogramma vengono inoltrati al display, così i TV HDR10+ applicano le curve di tone mapping della sorgente invece di ripiegare sul livello base HDR10 statico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "フレーム単位のST 2094-40メタデータをディスプレイに引き渡すようになり、HDR10+対応テレビが静的なHDR10ベースレイヤーに戻ることなくソースのトーンマッピングカーブを適用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "프레임별 ST 2094-40 메타데이터가 디스플레이로 전달되어, HDR10+ TV가 정적 HDR10 기본 레이어로 돌아가는 대신 소스의 톤 매핑 곡선을 적용합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ST 2094-40-metadata per ramme videresendes til skjermen, slik at HDR10+-TV-er bruker kildens tonemapping-kurver i stedet for å falle tilbake til det statiske HDR10-basislaget."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Per-frame ST 2094-40-metadata worden doorgegeven aan het scherm, zodat HDR10+-tv's de tone-mappingcurves van de bron toepassen in plaats van terug te vallen op de statische HDR10-basislaag."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Metadane ST 2094-40 dla każdej klatki są przekazywane do wyświetlacza, dzięki czemu telewizory HDR10+ stosują krzywe tone mappingu źródła zamiast wracać do statycznej warstwy bazowej HDR10."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os metadados ST 2094-40 por quadro são encaminhados ao display, de modo que TVs HDR10+ aplicam as curvas de tone mapping da fonte em vez de cair na camada base HDR10 estática."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os metadados ST 2094-40 por fotograma são encaminhados ao ecrã, para que TVs HDR10+ apliquem as curvas de tone mapping da fonte em vez de caírem na camada base HDR10 estática."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Metadatele ST 2094-40 pentru fiecare cadru sunt transmise către ecran, astfel încât televizoarele HDR10+ aplică curbele de tone mapping ale sursei în loc să revină la stratul de bază HDR10 static."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Покадровые метаданные ST 2094-40 передаются на дисплей, поэтому телевизоры с HDR10+ применяют кривые тонального отображения источника, а не откатываются на статический базовый слой HDR10."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Metadáta ST 2094-40 pre každú snímku sa odovzdávajú do displeja, takže televízory HDR10+ aplikujú tone-mapping krivky zdroja namiesto návratu na statickú základnú vrstvu HDR10."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ST 2094-40-metadata per bildruta vidarebefordras till skärmen, så HDR10+-tv-apparater använder källans tonmappningskurvor istället för att falla tillbaka till det statiska HDR10-baslagret."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kare başına ST 2094-40 metaverileri ekrana iletilir, böylece HDR10+ TV'ler statik HDR10 temel katmanına geri dönmek yerine kaynağın ton eşleme eğrilerini uygular."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Покадрові метадані ST 2094-40 передаються на дисплей, тож телевізори з HDR10+ застосовують криві тонального відображення джерела, а не відкочуються на статичний базовий шар HDR10."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "逐帧 ST 2094-40 元数据会传递到显示设备,因此 HDR10+ 电视会使用源内容的色调映射曲线,而不是退回到静态的 HDR10 基础层。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "逐幀 ST 2094-40 中繼資料會傳遞至顯示設備,因此 HDR10+ 電視會使用來源內容的色調映射曲線,而不是退回靜態的 HDR10 基礎層。"
          }
        }
      }
    },
