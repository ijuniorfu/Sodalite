    "parental.pin.recovery.subtitle" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pro nastavení nového PINu potvrďte heslo Jellyfin nechráněného účtu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bekræft Jellyfin-adgangskoden for en ubeskyttet konto for at angive en ny PIN-kode."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bestätige das Jellyfin-Passwort eines ungeschützten Kontos, um eine neue PIN festzulegen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
