    "changelog.0_12_0.watchStats.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nová obrazovka v Nastavení s tvými souhrny sledování, mírou dokončení, nejčastějšími žánry a nejvíce opakovanými tituly, vše z tvých dat Jellyfinu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En ny skærm i Indstillinger med dine visningstotaler, fuldførelsesgrad, topgenrer og mest gensete titler, alt sammen fra dine egne Jellyfin-data."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ein neuer Einstellungs-Screen mit deinen Seh-Summen, der Abschlussquote, Top-Genres und am häufigsten wiederholten Titeln, alles aus deinen eigenen Jellyfin-Daten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Μια νέα οθόνη στις Ρυθμίσεις με τα σύνολα προβολών σου, το ποσοστό ολοκλήρωσης, τα κορυφαία είδη και τους τίτλους που είδες ξανά πιο συχνά, όλα από τα δικά σου δεδομένα Jellyfin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A new Settings screen with your viewing totals, completion rate, top genres and most-rewatched titles, all from your own Jellyfin data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una nueva pantalla en Ajustes con tus totales de visionado, tasa de finalización, géneros principales y títulos más revisionados, todo a partir de tus propios datos de Jellyfin."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uusi Asetukset-näkymä, jossa näet katselun kokonaismäärät, valmistumisasteen, suosikkilajityypit ja eniten uudelleenkatsotut nimikkeet, kaikki omista Jellyfin-tiedoistasi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un nouvel écran dans les Réglages avec tes totaux de visionnage, ton taux d'achèvement, tes genres favoris et tes titres les plus revus, le tout depuis tes propres données Jellyfin."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Novi zaslon u Postavkama s tvojim ukupnim gledanjem, stopom dovršenosti, najgledanijim žanrovima i najčešće ponovno gledanim naslovima, sve iz tvojih Jellyfin podataka."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Új képernyő a Beállításokban a nézési összesítéseiddel, a befejezési aránnyal, a legnépszerűbb műfajokkal és a legtöbbször újranézett címekkel, mind a saját Jellyfin-adataidból."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una nuova schermata nelle Impostazioni con i tuoi totali di visione, il tasso di completamento, i generi principali e i titoli più rivisti, tutto dai tuoi dati Jellyfin."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "視聴の合計、完了率、トップジャンル、もっとも繰り返し見た作品を、すべて自分のJellyfinデータから表示する新しい設定画面です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "시청 합계, 완료율, 인기 장르, 가장 많이 다시 본 작품을 모두 내 Jellyfin 데이터로 보여 주는 새 설정 화면입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En ny skjerm i Innstillinger med dine seertotaler, fullføringsgrad, toppsjangre og mest gjensette titler, alt fra dine egne Jellyfin-data."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Een nieuw scherm in Instellingen met je kijktotalen, voltooiingspercentage, topgenres en meest herbekeken titels, allemaal uit je eigen Jellyfin-gegevens."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nowy ekran w Ustawieniach z Twoimi sumami oglądania, wskaźnikiem ukończenia, najczęstszymi gatunkami i najczęściej powtarzanymi tytułami, wszystko z Twoich danych Jellyfina."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uma nova tela em Ajustes com seus totais de exibição, taxa de conclusão, principais gêneros e títulos mais revistos, tudo a partir dos seus próprios dados do Jellyfin."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Um novo ecrã nas Definições com os teus totais de visualização, taxa de conclusão, géneros principais e títulos mais revistos, tudo a partir dos teus próprios dados do Jellyfin."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un nou ecran în Setări cu totalurile tale de vizionare, rata de finalizare, genurile preferate și titlurile cel mai des revizionate, totul din propriile tale date Jellyfin."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Новый экран в Настройках с вашими итогами просмотра, долей завершённого, любимыми жанрами и чаще всего пересматриваемыми тайтлами, всё из ваших данных Jellyfin."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nová obrazovka v Nastaveniach s tvojimi súhrnmi sledovania, mierou dokončenia, najobľúbenejšími žánrami a najčastejšie opakovanými titulmi, všetko z tvojich dát Jellyfinu."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En ny skärm i Inställningar med dina tittartotaler, slutförandegrad, toppgenrer och mest omtittade titlar, allt från dina egna Jellyfin-data."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ayarlar'da yeni bir ekran: izleme toplamlarınız, tamamlama oranı, en çok izlenen türler ve en çok yeniden izlenen başlıklar, hepsi kendi Jellyfin verilerinizden."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Новий екран у Налаштуваннях із вашими підсумками переглядів, відсотком завершення, улюбленими жанрами та найчастіше переглянутими наново тайтлами, усе з ваших даних Jellyfin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "“设置”中的新页面，展示你的观看总量、完成率、热门类型和最常重温的影片，全部来自你自己的 Jellyfin 数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "「設定」中的新頁面，呈現你的觀看總量、完成率、熱門類型和最常重溫的影片，全部來自你自己的 Jellyfin 資料。"
          }
        }
      }
    },
