    "changelog.0_11_0.episodeSynopsis.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Po otevření epizody už popis nezůstává několik sekund prázdný, zobrazí se spolu se zbytkem stránky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Når du åbner en episode, står beskrivelsen ikke længere tom i flere sekunder, den vises sammen med resten af siden."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Beim Öffnen einer Episode bleibt die Beschreibung nicht mehr sekundenlang leer, sie erscheint zusammen mit dem Rest der Seite."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ανοίγοντας ένα επεισόδιο, η περίληψη δεν μένει πια κενή για μερικά δευτερόλεπτα, εμφανίζεται μαζί με την υπόλοιπη σελίδα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Opening an episode no longer shows an empty synopsis for a few seconds, the description appears together with the rest of the page."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Al abrir un episodio, la sinopsis ya no queda vacía durante unos segundos, aparece junto con el resto de la página."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jaksoa avattaessa kuvaus ei enää ole tyhjä useita sekunteja, vaan se ilmestyy yhdessä muun sivun kanssa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "À l'ouverture d'un épisode, le synopsis ne reste plus vide pendant quelques secondes, il s'affiche en même temps que le reste de la page."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pri otvaranju epizode opis više ne ostaje prazan nekoliko sekundi, pojavljuje se zajedno s ostatkom stranice."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Egy epizód megnyitásakor a leírás többé nem marad üres néhány másodpercig, a lap többi részével együtt jelenik meg."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "All'apertura di un episodio la trama non resta più vuota per qualche secondo, appare insieme al resto della pagina."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "エピソードを開いたとき、あらすじが数秒間空白のままになることがなくなり、ページの他の部分と同時に表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "에피소드를 열 때 줄거리가 몇 초간 비어 있지 않고 페이지의 나머지 부분과 함께 표시됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Når du åpner en episode, står ikke beskrivelsen tom i flere sekunder lenger, den vises sammen med resten av siden."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bij het openen van een aflevering blijft de beschrijving niet meer enkele seconden leeg, hij verschijnt samen met de rest van de pagina."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Po otwarciu odcinka opis nie pozostaje już pusty przez kilka sekund, pojawia się razem z resztą strony."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ao abrir um episódio, a sinopse não fica mais vazia por alguns segundos, ela aparece junto com o restante da página."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ao abrir um episódio, a sinopse já não fica vazia durante alguns segundos, aparece juntamente com o resto da página."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La deschiderea unui episod, rezumatul nu mai rămâne gol câteva secunde, apare odată cu restul paginii."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "При открытии эпизода описание больше не остаётся пустым несколько секунд, оно появляется вместе с остальной страницей."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Po otvorení epizódy už popis nezostáva niekoľko sekúnd prázdny, zobrazí sa spolu so zvyškom stránky."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "När du öppnar ett avsnitt står beskrivningen inte längre tom i flera sekunder, den visas tillsammans med resten av sidan."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bir bölüm açıldığında özet artık birkaç saniye boş kalmıyor, sayfanın geri kalanıyla birlikte görünüyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Після відкриття епізоду опис більше не лишається порожнім кілька секунд, він з'являється разом з рештою сторінки."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "打开剧集时，简介不再空白数秒，而是与页面其余内容一同显示。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "打開單集時，簡介不再空白數秒，而是與頁面其餘內容一同顯示。"
          }
        }
      }
    },
