    "changelog.0_6_0.playback.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Čistší posouvání na časové ose, spolehlivější pokračování od místa, kde jste skončili, bezproblémové přepínání jazyka zvuku a přesnější indikátor HDR v přehrávači."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Renere spoling, mere pålidelig genoptagelse fra det sted, du slap, skift af lydsprog der bare virker, og en mere præcis HDR-indikator i afspilleren."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sauberes Spulen, verlässliches Fortsetzen vom letzten Wiedergabepunkt, jederzeit funktionierender Tonspurwechsel und ein genauerer HDR-Hinweis im Player."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Πιο καθαρή μετακίνηση στη γραμμή χρόνου, πιο αξιόπιστη συνέχιση από το σημείο που σταμάτησες, αλλαγή γλώσσας ήχου που λειτουργεί πάντα και πιο ακριβής ένδειξη HDR στο πρόγραμμα αναπαραγωγής."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Cleaner scrubbing, more reliable resume from where you left off, audio language switching that just works, and a more accurate HDR indicator in the player."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Avance y retroceso más precisos, reanudación más fiable desde donde lo dejaste, cambio de idioma de audio que funciona siempre y un indicador HDR más exacto en el reproductor."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sujuvampi kelaus, luotettavampi jatkaminen viimeisestä toistokohdasta, ääniraidan kielen vaihto joka vain toimii, ja tarkempi HDR-ilmaisin soittimessa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Défilement plus net dans la barre de progression, reprise plus fiable à l'endroit où vous vous étiez arrêté, changement de langue audio qui fonctionne sans accroc, et un indicateur HDR plus précis dans le lecteur."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Čišće premotavanje, pouzdaniji nastavak s mjesta na kojem ste stali, prebacivanje jezika zvuka koje jednostavno radi i točniji HDR pokazatelj u reproduktoru."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tisztább tekerés, megbízhatóbb folytatás onnan, ahol abbahagytad, zökkenőmentes hangnyelvváltás, és pontosabb HDR-jelzés a lejátszóban."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Avanzamento più preciso sulla timeline, ripresa più affidabile dal punto in cui avevi interrotto, cambio della lingua audio che funziona sempre e un indicatore HDR più accurato nel lettore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "スムーズなシーク操作、前回の続きからの確実な再開、確実に動作する音声言語の切り替え、そしてプレーヤー内のより正確なHDR表示を実現しました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "더 깔끔한 탐색, 멈춘 지점부터 더 안정적으로 이어보기, 자연스럽게 작동하는 음성 언어 전환, 그리고 플레이어 내 더 정확한 HDR 표시를 제공합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Renere spoling, mer pålitelig gjenopptakelse fra der du slapp, bytte av lydspråk som bare virker, og en mer nøyaktig HDR-indikator i spilleren."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vloeiender spoelen, betrouwbaarder hervatten vanaf waar je gebleven was, audiotaal wisselen dat gewoon werkt, en een nauwkeurigere HDR-indicator in de speler."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Czystsze przewijanie, niezawodne wznawianie od ostatniej pozycji, przełączanie ścieżki audio działające bez zarzutu oraz dokładniejszy wskaźnik HDR w odtwarzaczu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Avanço e retrocesso mais precisos, retomada confiável de onde você parou, troca de idioma do áudio que funciona de verdade e um indicador de HDR mais preciso no reprodutor."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Navegação na linha de tempo mais suave, retoma fiável a partir do ponto onde parou, mudança de idioma de áudio que simplesmente funciona e um indicador HDR mais preciso no leitor."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Derulare mai precisă, reluare mai fiabilă din punctul în care te-ai oprit, schimbare a limbii audio care funcționează impecabil și un indicator HDR mai precis în player."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Чёткая перемотка, надёжное продолжение с места остановки, переключение языка аудио без сбоев и более точный индикатор HDR в плеере."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Čistejšie posúvanie v časovej osi, spoľahlivejšie pokračovanie od miesta, kde ste skončili, prepínanie jazyka zvuku, ktoré jednoducho funguje, a presnejší indikátor HDR v prehrávači."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Renare spolning, tillförlitligare återupptagning där du slutade, ljudspråksbyte som bara fungerar och en mer exakt HDR-indikator i spelaren."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Daha temiz ileri/geri sarma, kaldığınız yerden daha güvenilir devam etme, sorunsuz çalışan ses dili değiştirme ve oynatıcıda daha doğru bir HDR göstergesi."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Чіткіше перемотування, надійніше продовження з останньої позиції, безвідмовне перемикання мови звуку та точніший індикатор HDR у плеєрі."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "进度拖动更顺滑，从上次停下的位置继续播放更可靠，音频语言切换简单好用，播放器中的 HDR 标识也更加准确。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "拖曳進度更滑順、續播位置更可靠、音軌語言切換穩定好用，播放器中的 HDR 標示也更為精確。"
          }
        }
      }
    },
