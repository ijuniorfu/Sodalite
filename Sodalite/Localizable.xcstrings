    "changelog.0_11_0.criticRating.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stránky detailu nyní zobrazují skóre kritiků Rotten Tomatoes vedle hodnocení komunity, včetně známých odznaků pro čerstvé a shnilé."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detaljesider viser nu Rotten Tomatoes-kritikerscoren ved siden af fællesskabsbedømmelsen, med de velkendte friske og rådne mærker."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detailseiten zeigen jetzt den Rotten-Tomatoes-Kritikerwert neben der Community-Bewertung, samt den bekannten Symbolen für frisch und verdorben."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι σελίδες λεπτομερειών εμφανίζουν τώρα τη βαθμολογία κριτικών του Rotten Tomatoes δίπλα στη βαθμολογία της κοινότητας, με τα γνωστά σήματα για φρέσκο και σάπιο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detail pages now show the Rotten Tomatoes critic score next to the community rating, with the familiar fresh and rotten badges."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Las páginas de detalle ahora muestran la puntuación de la crítica de Rotten Tomatoes junto a la valoración de la comunidad, con las conocidas insignias de fresco y podrido."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tietosivut näyttävät nyt Rotten Tomatoesin kriitikkopisteet yhteisöarvion vieressä, tuttujen tuore- ja mätä-merkkien kera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les pages de détail affichent désormais la note des critiques Rotten Tomatoes à côté de la note de la communauté, avec les badges frais et pourri bien connus."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stranice s detaljima sada prikazuju ocjenu kritičara Rotten Tomatoes pokraj ocjene zajednice, s poznatim oznakama za svježe i trulo."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A részletoldalak mostantól a Rotten Tomatoes kritikusi pontszámát is mutatják a közösségi értékelés mellett, az ismerős friss és romlott jelvényekkel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le pagine di dettaglio ora mostrano il punteggio della critica di Rotten Tomatoes accanto alla valutazione della community, con i celebri badge fresco e marcio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "詳細ページにRotten Tomatoesの批評家スコアがコミュニティ評価の隣に表示されるようになりました。おなじみのフレッシュとロッテンのバッジ付きです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "상세 페이지에 로튼 토마토 평론가 점수가 커뮤니티 평점 옆에 표시됩니다. 익숙한 신선/썩음 배지와 함께입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detaljsider viser nå kritikerscoren fra Rotten Tomatoes ved siden av fellesskapsvurderingen, med de velkjente ferske og råtne merkene."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detailpagina's tonen nu de criticiscore van Rotten Tomatoes naast de communitybeoordeling, met de bekende verse en rotte badges."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Strony szczegółów pokazują teraz ocenę krytyków Rotten Tomatoes obok oceny społeczności, ze znanymi odznakami świeżego i zgniłego pomidora."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As páginas de detalhes agora mostram a nota dos críticos do Rotten Tomatoes ao lado da avaliação da comunidade, com os famosos selos de fresco e podre."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As páginas de detalhes mostram agora a pontuação da crítica do Rotten Tomatoes ao lado da classificação da comunidade, com os conhecidos selos de fresco e podre."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Paginile de detalii afișează acum scorul criticilor de pe Rotten Tomatoes lângă evaluarea comunității, cu binecunoscutele insigne proaspăt și putred."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "На страницах описания теперь отображается оценка критиков Rotten Tomatoes рядом с оценкой сообщества, со знакомыми значками свежего и гнилого помидора."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stránky s detailmi teraz zobrazujú skóre kritikov Rotten Tomatoes vedľa hodnotenia komunity, so známymi odznakmi pre čerstvé a zhnité."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detaljsidorna visar nu kritikerbetyget från Rotten Tomatoes bredvid communitybetyget, med de välkända färska och ruttna märkena."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detay sayfaları artık topluluk puanının yanında Rotten Tomatoes eleştirmen puanını da gösteriyor, tanıdık taze ve çürük rozetleriyle."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Сторінки деталей тепер показують оцінку критиків Rotten Tomatoes поруч з оцінкою спільноти, зі знайомими значками свіжого та гнилого помідора."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "详情页现在会在社区评分旁边显示烂番茄影评人评分，并配有熟悉的新鲜和腐烂徽章。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "詳情頁現在會在社群評分旁顯示爛番茄影評人評分，並附上熟悉的新鮮與腐爛徽章。"
          }
        }
      }
    },
