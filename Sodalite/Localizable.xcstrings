    "changelog.0_7_0.playerFixes.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mihotání Skip-Intro je pryč, překryv další epizody zůstává na svém místě, titulky se čistě umístí na obrazovku a pomalé CDN už nezasekávají rozhraní."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro-flimmer er væk, overlejringen for næste afsnit bliver, hvor den er, undertekster lander rent på skærmen, og langsomme CDN'er hænger ikke længere brugerfladen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro-Flackern weg, Next-Episode-Overlay bleibt fest an seinem Platz, Untertitel landen sauber im Bild, und langsame CDNs hängen die UI nicht mehr auf."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Το τρεμοπαίξιμο του Skip-Intro έφυγε, η επικάλυψη του επόμενου επεισοδίου παραμένει στη θέση της, οι υπότιτλοι τοποθετούνται καθαρά στην οθόνη, και τα αργά CDN δεν κολλούν πια το περιβάλλον."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro flicker gone, the next-episode overlay stays pinned, subtitles land cleanly on screen, and slow CDNs no longer stall the UI."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "El parpadeo de Skip-Intro desapareció, la superposición del próximo episodio se mantiene fija, los subtítulos aterrizan limpios en pantalla y las CDN lentas ya no bloquean la interfaz."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro-vilkkuminen on poissa, seuraavan jakson peittokuva pysyy paikallaan, tekstitykset asettuvat siististi näytölle, eivätkä hitaat CDN:t enää jumiuta käyttöliittymää."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le clignotement de Skip-Intro a disparu, l'incrustation de l'épisode suivant reste en place, les sous-titres se posent proprement à l'écran, et les CDN lents ne bloquent plus l'interface."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Treperenje Skip-Intra je nestalo, prekrivač sljedeće epizode ostaje na mjestu, titlovi se uredno smještaju na zaslon, a spori CDN-ovi više ne zaustavljaju sučelje."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A Skip-Intro villogása megszűnt, a következő epizód overlayje a helyén marad, a feliratok tisztán kerülnek a képernyőre, és a lassú CDN-ek nem akasztják meg a felületet."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lo sfarfallio di Skip-Intro è sparito, l'overlay del prossimo episodio resta al suo posto, i sottotitoli si posizionano puliti sullo schermo, e le CDN lente non bloccano più l'interfaccia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro のちらつきが解消され、次のエピソードのオーバーレイは固定され、字幕は画面にきれいに表示され、遅い CDN でも UI が止まらなくなりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro 깜박임이 사라지고, 다음 에피소드 오버레이가 그 자리에 고정되며, 자막이 화면에 깔끔하게 자리잡고, 느린 CDN에서도 UI가 멈추지 않습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro-flimmer er borte, overlegget for neste episode blir værende, undertekster lander rent på skjermen, og trege CDN-er stopper ikke lenger grensesnittet."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro-flikkeren is verdwenen, de overlay van de volgende aflevering blijft op zijn plek, ondertitels landen schoon op het scherm, en trage CDN's blokkeren de UI niet meer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Migotanie Skip-Intro zniknęło, nakładka następnego odcinka pozostaje na miejscu, napisy lądują czysto na ekranie, a wolne CDN-y nie blokują już interfejsu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O piscar do Skip-Intro acabou, a sobreposição do próximo episódio fica fixa, as legendas pousam limpas na tela, e CDNs lentas não travam mais a interface."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O piscar do Skip-Intro acabou, a sobreposição do próximo episódio fica fixa, as legendas posicionam-se limpas no ecrã, e CDN lentos já não bloqueiam a interface."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pâlpâirea Skip-Intro a dispărut, suprapunerea episodului următor rămâne fixă, subtitrările apar curat pe ecran, iar CDN-urile lente nu mai blochează interfața."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Мерцание Skip-Intro исчезло, оверлей следующего эпизода остаётся на месте, субтитры аккуратно ложатся на экран, а медленные CDN больше не подвешивают интерфейс."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Blikanie Skip-Intra je preč, prekrytie ďalšej epizódy zostáva na svojom mieste, titulky sa čisto umiestnia na obrazovku a pomalé CDN už nezasekávajú rozhranie."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro-flimret är borta, överlägget för nästa avsnitt sitter still, undertexter landar rent på skärmen, och långsamma CDN-er stoppar inte längre gränssnittet."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro titremesi gitti, sonraki bölüm yer paylaşımı yerinde kalıyor, altyazılar ekrana temiz oturuyor ve yavaş CDN'ler artık arayüzü tıkamıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Мерехтіння Skip-Intro зникло, оверлей наступного епізоду залишається на місці, субтитри акуратно лягають на екран, а повільні CDN більше не зависають інтерфейс."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro 闪烁问题消除、下集叠加层固定不动、字幕在屏幕上正确显示,慢速 CDN 也不再卡住界面。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip-Intro 閃爍問題消除、下一集疊加層固定不動、字幕在螢幕上正確顯示,慢速 CDN 也不再卡住介面。"
          }
        }
      }
    },
