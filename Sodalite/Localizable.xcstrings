    "home.customize.description" : {
      "comment": "Description in home customize view",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kliknutím řádek přesunete; přepínač vpravo jej zobrazí nebo skryje."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Klik for at flytte en række; kontakten til højre viser eller skjuler den."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Klick verschiebt eine Reihe, der Schalter rechts blendet sie ein oder aus."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Κάντε κλικ για να μετακινήσετε μια σειρά· ο διακόπτης δεξιά την εμφανίζει ή την αποκρύπτει."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Click to move a row; the switch on the right shows or hides it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Haz clic para mover una fila; el interruptor de la derecha la muestra u oculta."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Siirrä riviä napsauttamalla; oikealla oleva kytkin näyttää tai piilottaa sen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Cliquez pour déplacer une ligne ; le bouton à droite l'affiche ou la masque."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kliknite za premještanje retka; prekidač desno ga prikazuje ili skriva."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kattints egy sor áthelyezéséhez; a jobb oldali kapcsoló megjeleníti vagy elrejti."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Clicca per spostare una riga; l'interruttore a destra la mostra o la nasconde."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "クリックで行を移動。右のスイッチで表示・非表示を切り替えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "클릭하여 행을 이동하세요. 오른쪽 스위치로 표시하거나 숨깁니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Klikk for å flytte en rad; bryteren til høyre viser eller skjuler den."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Klik om een rij te verplaatsen; de schakelaar rechts toont of verbergt hem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kliknij, aby przenieść wiersz; przełącznik po prawej pokazuje go lub ukrywa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Clique para mover uma linha; o botão à direita a mostra ou oculta."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Clique para mover uma linha; o botão à direita mostra-a ou oculta-a."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Apasă pentru a muta un rând; comutatorul din dreapta îl afișează sau ascunde."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Нажмите, чтобы переместить строку; переключатель справа показывает или скрывает её."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kliknutím presuniete riadok; prepínač vpravo ho zobrazí alebo skryje."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Klicka för att flytta en rad; reglaget till höger visar eller döljer den."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bir satırı taşımak için tıklayın; sağdaki anahtar onu gösterir veya gizler."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Натисніть, щоб перемістити рядок; перемикач праворуч показує або приховує його."
          }
        },
        "zh-Hans" : {
