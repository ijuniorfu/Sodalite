    "settings.cloudSync.push.confirm.message" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nastavení na vašich ostatních zařízeních budou nahrazena nastavením tohoto zařízení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Indstillingerne på dine andre enheder erstattes af denne enheds indstillinger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Die Einstellungen auf deinen anderen Geräten werden durch die Einstellungen dieses Geräts ersetzt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι ρυθμίσεις στις άλλες συσκευές σας θα αντικατασταθούν από τις ρυθμίσεις αυτής της συσκευής."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Settings on your other devices will be replaced by this device's settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los ajustes de tus otros dispositivos se reemplazarán por los de este dispositivo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Muiden laitteidesi asetukset korvataan tämän laitteen asetuksilla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les réglages de vos autres appareils seront remplacés par ceux de cet appareil."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Postavke na vašim drugim uređajima bit će zamijenjene postavkama ovog uređaja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A többi eszközén lévő beállításokat felülírják ennek az eszköznek a beállításai."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le impostazioni sui tuoi altri dispositivi verranno sostituite da quelle di questo dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "他のデバイスの設定は、このデバイスの設定で置き換えられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "다른 기기의 설정이 이 기기의 설정으로 대체됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Innstillingene på de andre enhetene dine erstattes av innstillingene fra denne enheten."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "De instellingen op je andere apparaten worden vervangen door die van dit apparaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ustawienia na twoich innych urządzeniach zostaną zastąpione ustawieniami tego urządzenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os ajustes nos seus outros dispositivos serão substituídos pelos deste dispositivo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As definições nos seus outros dispositivos serão substituídas pelas deste dispositivo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Setările de pe celelalte dispozitive ale tale vor fi înlocuite cu cele de pe acest dispozitiv."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Настройки на других ваших устройствах будут заменены настройками этого устройства."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nastavenia na vašich ostatných zariadeniach budú nahradené nastaveniami tohto zariadenia."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Inställningarna på dina andra enheter ersätts av den här enhetens inställningar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Diğer cihazlarınızdaki ayarlar bu cihazın ayarlarıyla değiştirilecek."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Налаштування на ваших інших пристроях буде замінено налаштуваннями цього пристрою."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "你其他设备上的设置将被此设备的设置替换。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "你其他裝置上的設定將被此裝置的設定取代。"
          }
        }
      }
    },
