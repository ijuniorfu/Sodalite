    "changelog.0_12_0.compactButtons.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vedlejší tlačítka na stránkách s detaily se zmenší na ikony a popisek ukážou při zaměření, takže stránka zůstává úhledná."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sekundære knapper på detaljesider skrumper til ikoner og viser deres etiket ved fokus, så siden forbliver ryddelig."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sekundäre Buttons auf Detailseiten schrumpfen zu Symbolen und zeigen ihr Label bei Fokus, damit die Seite aufgeräumt bleibt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα δευτερεύοντα κουμπιά στις σελίδες λεπτομερειών συμπτύσσονται σε εικονίδια και δείχνουν την ετικέτα τους στην εστίαση, ώστε η σελίδα να μένει τακτοποιημένη."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Secondary buttons on detail pages collapse to icons and reveal their label when focused, keeping the page tidy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los botones secundarios en las páginas de detalle se reducen a iconos y muestran su etiqueta al enfocarlos, manteniendo la página ordenada."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tietosivujen toissijaiset painikkeet kutistuvat kuvakkeiksi ja näyttävät tekstinsä kohdistettaessa, joten sivu pysyy siistinä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les boutons secondaires des pages de détail se réduisent à des icônes et affichent leur libellé au focus, gardant la page épurée."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sporedne tipke na stranicama s detaljima skupljaju se u ikone i prikazuju oznaku pri fokusu, pa stranica ostaje uredna."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A részletező oldalak másodlagos gombjai ikonokká zsugorodnak, és fókuszban megjelenítik a feliratukat, így az oldal rendezett marad."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I pulsanti secondari nelle pagine di dettaglio si riducono a icone e mostrano l'etichetta quando sono in focus, mantenendo la pagina ordinata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "詳細ページの二次的なボタンはアイコンに縮まり、フォーカス時にラベルを表示するので、ページがすっきり保たれます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "상세 페이지의 보조 버튼이 아이콘으로 줄어들고 포커스를 받으면 라벨을 표시해, 페이지가 깔끔하게 유지됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sekundære knapper på detaljsider krymper til ikoner og viser etiketten ved fokus, slik at siden holder seg ryddig."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Secundaire knoppen op detailpagina's krimpen tot pictogrammen en tonen hun label bij focus, zodat de pagina overzichtelijk blijft."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Drugorzędne przyciski na stronach szczegółów zwijają się do ikon i pokazują etykietę po zaznaczeniu, dzięki czemu strona pozostaje schludna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os botões secundários nas páginas de detalhes encolhem para ícones e mostram o rótulo ao receber foco, mantendo a página organizada."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os botões secundários nas páginas de detalhe encolhem para ícones e mostram a etiqueta ao receber foco, mantendo a página organizada."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Butoanele secundare de pe paginile de detalii se reduc la pictograme și își arată eticheta când sunt focalizate, păstrând pagina ordonată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Второстепенные кнопки на страницах с подробностями сворачиваются в значки и показывают подпись при фокусе, сохраняя страницу опрятной."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vedľajšie tlačidlá na stránkach s detailmi sa zmenšia na ikony a popis ukážu pri zameraní, takže stránka ostáva úhľadná."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sekundära knappar på detaljsidor krymper till ikoner och visar sin etikett vid fokus, så att sidan hålls städad."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ayrıntı sayfalarındaki ikincil düğmeler simgelere küçülür ve odaklanınca etiketini gösterir, böylece sayfa düzenli kalır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Другорядні кнопки на сторінках із деталями згортаються до значків і показують підпис у фокусі, тож сторінка лишається охайною."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "详情页上的次要按钮会收起为图标，获得焦点时显示标签，让页面保持整洁。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "詳細頁上的次要按鈕會收合為圖示，取得焦點時顯示標籤，讓頁面保持整潔。"
          }
        }
      }
    },
