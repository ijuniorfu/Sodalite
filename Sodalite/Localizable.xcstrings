    "search.error.connection" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nelze se připojit k serveru. Zkontrolujte připojení a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kunne ikke nå serveren. Tjek forbindelsen og prøv igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Server nicht erreichbar. Überprüfe die Verbindung und versuche es erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Αδυναμία πρόσβασης στον διακομιστή. Έλεγξε τη σύνδεση και προσπάθησε ξανά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Couldn't reach your server. Check the connection and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "No se pudo contactar con el servidor. Comprueba la conexión e inténtalo de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Palvelimeen ei saatu yhteyttä. Tarkista yhteys ja yritä uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Impossible de joindre votre serveur. Vérifiez la connexion et réessayez."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ne mogu se povezati s poslužiteljem. Provjeri vezu i pokušaj ponovno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nem sikerült elérni a kiszolgálót. Ellenőrizd a kapcsolatot, és próbáld újra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Impossibile raggiungere il server. Verifica la connessione e riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "サーバーに接続できません。接続を確認してもう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "서버에 연결할 수 없습니다. 연결을 확인하고 다시 시도하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kunne ikke nå serveren. Sjekk forbindelsen og prøv på nytt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kan je server niet bereiken. Controleer de verbinding en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nie można połączyć się z serwerem. Sprawdź połączenie i spróbuj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Não foi possível alcançar o servidor. Verifique a conexão e tente novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Não foi possível alcançar o servidor. Verifique a ligação e tente novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
