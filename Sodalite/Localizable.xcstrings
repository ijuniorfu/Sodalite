    "changelog.0_12_0.playlists.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tvé playlisty z Jellyfinu mají vlastní řádek na ploše a detail, který je přehraje popořadě."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dine Jellyfin-afspilningslister får deres egen række på forsiden og en detaljeside, der spiller dem i rækkefølge."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Deine Jellyfin-Wiedergabelisten bekommen eine eigene Home-Reihe und eine Detailseite, die sie der Reihe nach abspielt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι λίστες αναπαραγωγής σου από το Jellyfin αποκτούν δική τους σειρά στην αρχική και μια σελίδα που τις παίζει με τη σειρά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Your Jellyfin playlists get their own Home row and a detail page that plays through in order."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tus listas de reproducción de Jellyfin tienen su propia fila en Inicio y una página de detalle que las reproduce en orden."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyfin-soittolistasi saavat oman rivin etusivulle ja tietonäkymän, joka toistaa ne järjestyksessä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tes listes de lecture Jellyfin obtiennent leur propre rangée sur l'accueil et une page de détail qui les lit dans l'ordre."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tvoji Jellyfin popisi za reprodukciju dobivaju vlastiti redak na početnoj i stranicu s detaljima koja ih pušta redom."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A Jellyfin-lejátszási listáid saját sort kapnak a kezdőképernyőn, és egy részletező oldalt, amely sorban játssza le őket."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le tue playlist di Jellyfin hanno una riga dedicata nella Home e una pagina di dettaglio che le riproduce in ordine."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyfinのプレイリストがホームに専用の行を持ち、詳細ページから順番に再生できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyfin 재생목록이 홈에 전용 행을 갖고, 상세 페이지에서 순서대로 재생됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyfin-spillelistene dine får sin egen rad på forsiden og en detaljside som spiller dem av i rekkefølge."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Je Jellyfin-afspeellijsten krijgen een eigen rij op het startscherm en een detailpagina die ze op volgorde afspeelt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Twoje listy odtwarzania z Jellyfina mają własny rząd na ekranie głównym i stronę szczegółów, która odtwarza je po kolei."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Suas listas de reprodução do Jellyfin ganham uma linha própria na Início e uma página de detalhes que reproduz tudo em ordem."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As tuas listas de reprodução do Jellyfin ganham uma linha própria no Início e uma página de detalhe que as reproduz por ordem."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Listele tale de redare din Jellyfin primesc un rând propriu pe Acasă și o pagină de detalii care le redă în ordine."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ваши плейлисты Jellyfin получают отдельный ряд на главном экране и страницу с подробностями, которая воспроизводит их по порядку."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tvoje playlisty z Jellyfinu majú vlastný riadok na ploche a detail, ktorý ich prehrá po poradí."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dina Jellyfin-spellistor får en egen rad på startsidan och en detaljsida som spelar upp dem i ordning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyfin çalma listeleriniz Ana ekranda kendi satırını ve hepsini sırayla oynatan bir ayrıntı sayfası kazanır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ваші списки відтворення Jellyfin отримують власний рядок на головному екрані та сторінку з деталями, що відтворює їх по черзі."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "你的 Jellyfin 播放列表在主页拥有专属行，详情页会按顺序连续播放。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "你的 Jellyfin 播放清單在主頁擁有專屬列，詳細頁會按順序連續播放。"
          }
        }
      }
    },
