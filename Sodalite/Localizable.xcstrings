    "changelog.0_10_0.backdrops.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pozadí teď prosvítá celou stránkou detailu a při posouvání tmavne. Tituly bez vlastního pozadí dostanou ambientní plochu z plakátu místo šedé desky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Baggrundsbilleder skinner nu igennem hele detaljesiden og dæmpes, når du ruller. Titler uden baggrundsbillede får en stemningsfuld plakatflade i stedet for en grå plade."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Backdrops scheinen jetzt durch die ganze Detailseite und dimmen beim Scrollen. Titel ohne Backdrop bekommen eine Poster-Fläche in Ambient-Optik statt grauem Hintergrund."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα φόντα διαπερνούν τώρα ολόκληρη τη σελίδα λεπτομερειών και σκουραίνουν καθώς κάνετε κύλιση. Οι τίτλοι χωρίς εικόνα φόντου αποκτούν μια ατμοσφαιρική επιφάνεια από την αφίσα αντί για γκρίζο φόντο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Backdrops now shine through the whole detail page and dim as you scroll. Items without backdrop art get an ambient poster fill instead of a grey plate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los fondos ahora se ven a través de toda la página de detalle y se atenúan al desplazarte. Los títulos sin fondo reciben un relleno ambiental del póster en lugar de una placa gris."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Taustakuvat hohtavat nyt koko tietosivun läpi ja himmenevät vierittäessä. Ilman taustakuvaa olevat nimikkeet saavat julisteesta tehdyn tunnelmataustan harmaan levyn sijaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les arrière-plans transparaissent désormais sur toute la page de détail et s'assombrissent au défilement. Les titres sans arrière-plan reçoivent un fond ambiant tiré de l'affiche au lieu d'une plaque grise."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pozadinske slike sada se protežu cijelom stranicom detalja i zatamnjuju pri pomicanju. Naslovi bez pozadinske slike dobivaju ambijentalnu površinu iz plakata umjesto sive ploče."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A háttérképek mostantól az egész részletoldalon átragyognak, és görgetéskor elhalványulnak. A háttérkép nélküli címek szürke felület helyett a plakátból készült hangulatkitöltést kapnak."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gli sfondi ora risplendono su tutta la pagina di dettaglio e si attenuano durante lo scorrimento. I titoli senza sfondo ricevono un riempimento ambientale dal poster invece di una lastra grigia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "背景アートが詳細ページ全体に広がり、スクロールすると暗くなります。背景アートのない作品には、グレーの背景の代わりにポスターを使ったアンビエント表示が適用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "배경 이미지가 이제 상세 페이지 전체에 펼쳐지고 스크롤하면 어두워집니다. 배경 이미지가 없는 항목에는 회색 판 대신 포스터 기반의 앰비언트 배경이 적용됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bakgrunnsbilder skinner nå gjennom hele detaljsiden og dempes når du blar. Titler uten bakgrunnsbilde får en stemningsfull plakatflate i stedet for en grå plate."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Achtergronden schijnen nu door de hele detailpagina en dimmen terwijl je scrolt. Items zonder achtergrondafbeelding krijgen een sfeervolle postervulling in plaats van een grijs vlak."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tła prześwitują teraz przez całą stronę szczegółów i przyciemniają się podczas przewijania. Pozycje bez grafiki tła otrzymują nastrojowe wypełnienie z plakatu zamiast szarej płyty."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os planos de fundo agora aparecem por toda a página de detalhes e escurecem conforme você rola. Itens sem arte de fundo ganham um preenchimento ambiente do pôster em vez de uma placa cinza."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os fundos aparecem agora em toda a página de detalhe e escurecem ao deslocar. Os itens sem imagem de fundo recebem um preenchimento ambiente do cartaz em vez de uma placa cinzenta."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fundalurile se văd acum pe toată pagina de detalii și se estompează la derulare. Titlurile fără imagine de fundal primesc un fundal ambiental din afiș în locul unei plăci gri."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Фоновые изображения теперь занимают всю страницу деталей и затемняются при прокрутке. Элементы без фона получают атмосферную заливку из постера вместо серой плашки."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pozadia teraz presvitajú celou stránkou detailu a pri posúvaní tmavnú. Tituly bez vlastného pozadia dostanú ambientnú plochu z plagátu namiesto sivej dosky."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bakgrundsbilder lyser nu igenom hela detaljsidan och tonas ned när du rullar. Titlar utan bakgrundsbild får en stämningsfull affischfyllning i stället för en grå platta."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Arka planlar artık ayrıntı sayfasının tamamına yayılıyor ve kaydırdıkça kararıyor. Arka plan görseli olmayan öğeler gri bir zemin yerine afişten türetilen ortam dolgusu alıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Фонові зображення тепер займають усю сторінку деталей і затемнюються під час прокручування. Елементи без фону отримують атмосферну заливку з постера замість сірої плашки."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "背景图现在贯穿整个详情页，并随滚动逐渐变暗。没有背景图的条目会以海报生成的氛围填充取代灰色底板。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "背景圖現在會延伸至整個詳細資料頁，並隨捲動逐漸變暗。沒有背景圖的項目會以海報產生的氛圍填充取代灰色底板。"
          }
        }
      }
    },
