    "changelog.0_6_0.engine.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zásadní vylepšení interního přehrávacího jádra. Podporuje více video formátů včetně AV1 a VP9 s chytřejším směrováním, takže každý soubor ve vaší knihovně se přehraje v nejlepší kvalitě, jakou váš televizor dokáže zobrazit."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stor opgradering af den underliggende videomotor. Understøtter nu flere videoformater, herunder AV1 og VP9, med smartere dirigering, så hver fil i dit bibliotek afspilles i den bedste kvalitet, dit TV kan vise."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Großes Upgrade der Video-Engine. Unterstützt jetzt mehr Videoformate, einschließlich AV1 und VP9, mit intelligenterem Routing, damit jede Datei aus deiner Bibliothek in der bestmöglichen Qualität deines Fernsehers wiedergegeben wird."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Σημαντική αναβάθμιση της υποκείμενης μηχανής βίντεο. Υποστηρίζει περισσότερες μορφές βίντεο, συμπεριλαμβανομένων των AV1 και VP9, με εξυπνότερη δρομολόγηση ώστε κάθε αρχείο της βιβλιοθήκης σου να αναπαράγεται στην καλύτερη δυνατή ποιότητα που μπορεί να εμφανίσει η τηλεόρασή σου."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Major upgrade to the underlying video engine. Supports more video formats including AV1 and VP9, with smarter routing so every file in your library plays with the best quality your TV can show."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gran mejora del motor de vídeo subyacente. Admite más formatos de vídeo, incluidos AV1 y VP9, con un enrutamiento más inteligente para que cada archivo de tu biblioteca se reproduzca con la mejor calidad que pueda mostrar tu televisor."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Merkittävä päivitys taustalla toimivaan videotoisto-ohjelmistoon. Tukee nyt useampia videoformaatteja, kuten AV1- ja VP9-muotoa, ja älykkäämpi reititys varmistaa, että jokainen kirjastosi tiedosto toistuu parhaalla televisiosi tukemalla laadulla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mise à niveau majeure du moteur vidéo sous-jacent. Il prend en charge davantage de formats vidéo, dont AV1 et VP9, avec un routage plus intelligent pour que chaque fichier de votre bibliothèque soit lu dans la meilleure qualité que votre téléviseur puisse afficher."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Velika nadogradnja temeljnog video pogona. Podržava više video formata, uključujući AV1 i VP9, uz pametnije usmjeravanje kako bi se svaka datoteka u vašoj biblioteci reproducirala u najboljoj kvaliteti koju vaš televizor može prikazati."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jelentős fejlesztés a háttérben működő videómotorban. Mostantól több videoformátumot támogat, köztük az AV1-et és a VP9-et, intelligensebb útválasztással, hogy a könyvtárad minden fájlja a tévéd által megjeleníthető legjobb minőségben játssza le."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Importante aggiornamento del motore video sottostante. Supporta più formati video, tra cui AV1 e VP9, con un instradamento più intelligente, così ogni file della tua libreria viene riprodotto con la migliore qualità che il tuo televisore può offrire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "基盤となる再生エンジンを大幅にアップグレード。AV1やVP9を含むより多くの動画形式に対応し、よりスマートな振り分けによって、ライブラリ内のすべてのファイルをテレビが表示できる最高画質で再生します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "기반 비디오 엔진을 대폭 개선했습니다. AV1과 VP9를 포함한 더 많은 영상 포맷을 지원하며, 더 똑똑한 처리 방식으로 라이브러리의 모든 파일을 TV가 표현할 수 있는 최고의 화질로 재생합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stor oppgradering av den underliggende videomotoren. Støtter nå flere videoformater, inkludert AV1 og VP9, med smartere ruting slik at hver fil i biblioteket ditt spilles av med best mulig kvalitet TV-en din kan vise."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Grote upgrade van de onderliggende videoengine. Ondersteunt meer videoformaten, waaronder AV1 en VP9, met slimmere routering zodat elk bestand in je bibliotheek wordt afgespeeld met de beste kwaliteit die je tv kan tonen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Duża aktualizacja silnika wideo. Obsługuje więcej formatów wideo, w tym AV1 i VP9, dzięki inteligentniejszemu kierowaniu, więc każdy plik z biblioteki jest odtwarzany w najlepszej jakości, jaką może wyświetlić Twój telewizor."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Grande atualização do motor de vídeo subjacente. Suporta mais formatos de vídeo, incluindo AV1 e VP9, com roteamento mais inteligente para que cada arquivo da sua biblioteca seja reproduzido com a melhor qualidade que a sua TV pode exibir."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Grande atualização do motor de vídeo subjacente. Suporta mais formatos de vídeo, incluindo AV1 e VP9, com um encaminhamento mais inteligente para que cada ficheiro da sua biblioteca seja reproduzido com a melhor qualidade que o seu televisor consegue apresentar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Actualizare majoră a motorului video intern. Suportă mai multe formate video, inclusiv AV1 și VP9, cu o direcționare mai inteligentă, astfel încât fiecare fișier din biblioteca ta să fie redat la cea mai bună calitate pe care o poate afișa televizorul tău."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Крупное обновление видеодвижка: поддержка большего числа форматов, включая AV1 и VP9, и более умная маршрутизация, благодаря которой каждый файл из вашей библиотеки воспроизводится с наилучшим качеством, доступным вашему телевизору."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zásadná aktualizácia interného prehrávacieho jadra. Podporuje viac video formátov vrátane AV1 a VP9 a vďaka inteligentnejšiemu smerovaniu sa každý súbor vo vašej knižnici prehrá v najlepšej kvalite, akú váš televízor dokáže zobraziť."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stor uppgradering av den underliggande videomotorn. Stöder fler videoformat, inklusive AV1 och VP9, med smartare routing så att varje fil i ditt bibliotek spelas upp i bästa möjliga kvalitet som din TV kan visa."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Temeldeki video motorunda büyük bir iyileştirme. AV1 ve VP9 dahil daha fazla video biçimini destekler; daha akıllı yönlendirme sayesinde kitaplığınızdaki her dosya, TV'nizin gösterebileceği en iyi kalitede oynatılır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Масштабне оновлення базового відеодвигуна. Підтримує більше форматів відео, включно з AV1 та VP9, із розумнішим маршрутизуванням — кожен файл із вашої бібліотеки відтворюється з найкращою якістю, яку здатен показати ваш телевізор."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "视频引擎重大升级，新增对 AV1、VP9 等更多视频格式的支持，并通过更智能的路由，确保媒体库中的每个文件都以电视所能呈现的最佳画质播放。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "底層影片引擎重大升級，支援更多影片格式，包括 AV1 與 VP9，並透過更智慧的分流機制，讓媒體庫中的每個檔案都能以電視所能呈現的最佳畫質播放。"
          }
        }
      }
    },
