    "changelog.0_5_0.pictureSpeed.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "V přehrávači přepínej mezi původním poměrem stran a vyplněním celé obrazovky a aktuální rychlost přehrávání se zobrazí jako trvalý odznak vpravo nahoře, když není 1×."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skift mellem oprindeligt billedformat og fuldskærmsudfyldning direkte fra afspilleren, og se den aktuelle afspilningshastighed som et vedvarende mærke øverst til højre, når den ikke er 1×."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Wechsle im Player zwischen Original-Seitenverhältnis und Vollbild-Modus, und die aktuelle Wiedergabegeschwindigkeit erscheint als dauerhaftes Badge oben rechts, wenn sie nicht 1× ist."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Εναλλάξτε μεταξύ της αρχικής αναλογίας εικόνας και της πλήρους οθόνης μέσα από το πρόγραμμα αναπαραγωγής, και δείτε την τρέχουσα ταχύτητα αναπαραγωγής ως μόνιμο σήμα επάνω δεξιά όταν δεν είναι 1×."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Switch between original aspect ratio and full-screen fill from the player, and see the current playback rate as a persistent badge in the top-right when it's not 1×."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Cambia entre la relación de aspecto original y la pantalla completa desde el reproductor, y mira la velocidad de reproducción actual como una insignia persistente en la esquina superior derecha cuando no es 1×."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vaihda soittimessa alkuperäisen kuvasuhteen ja koko näytön täytön välillä, ja näe nykyinen toistonopeus pysyvänä merkkinä oikeassa yläkulmassa, kun se ei ole 1×."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bascule entre le rapport d'aspect d'origine et le remplissage plein écran depuis le lecteur, et vois la vitesse de lecture actuelle sous forme de badge permanent en haut à droite quand elle n'est pas 1×."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mijenjaj izvorni omjer slike i ispunjavanje cijelog zaslona izravno iz reproduktora, a trenutna brzina reprodukcije prikazuje se kao trajna oznaka u gornjem desnom kutu kad nije 1×."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Válts a lejátszóból az eredeti képarány és a teljes képernyős kitöltés között, és nézd a jelenlegi lejátszási sebességet állandó jelvényként a jobb felső sarokban, ha nem 1×."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Passa tra rapporto d'aspetto originale e schermo intero dal player e vedi la velocità di riproduzione corrente come badge persistente in alto a destra quando non è 1×."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "プレーヤーから元のアスペクト比とフルスクリーン表示を切り替えられ、再生速度が1×でないときは画面右上に常時バッジで表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "플레이어에서 원본 화면비와 전체화면 채우기 사이를 전환할 수 있고, 재생 속도가 1×가 아닐 때 오른쪽 상단에 지속적인 배지로 표시됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bytt mellom opprinnelig sideforhold og fullskjermsutfylling fra spilleren, og se gjeldende avspillingshastighet som et vedvarende merke øverst til høyre når den ikke er 1×."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Wissel in de speler tussen de originele beeldverhouding en volledige beeldvulling, en zie de huidige afspeelsnelheid als een blijvende badge rechtsboven wanneer die niet 1× is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Przełączaj między oryginalnymi proporcjami obrazu a wypełnieniem pełnoekranowym bezpośrednio z odtwarzacza, a aktualna prędkość odtwarzania pojawia się jako stała plakietka w prawym górnym rogu, gdy nie jest równa 1×."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alterne entre proporção original e tela cheia direto no player, e veja a velocidade de reprodução atual como uma insígnia persistente no canto superior direito quando não está em 1×."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alterna entre proporção original e ecrã inteiro directamente no reprodutor, e vê a velocidade de reprodução actual como um emblema persistente no canto superior direito quando não está a 1×."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Comută între raportul de aspect original și umplerea ecranului direct din player, iar viteza curentă de redare apare ca insignă permanentă în colțul din dreapta sus când nu este 1×."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Переключайте оригинальное соотношение сторон и заполнение во весь экран прямо в плеере, а текущая скорость воспроизведения отображается постоянным значком в правом верхнем углу, когда она не равна 1×."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "V prehrávači prepínaj medzi pôvodným pomerom strán a vyplnením celej obrazovky a aktuálna rýchlosť prehrávania sa zobrazí ako trvalý odznak vpravo hore, keď nie je 1×."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Växla mellan ursprungligt bildformat och helskärmsfyllning från spelaren, och se aktuell uppspelningshastighet som ett bestående märke uppe till höger när den inte är 1×."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Oynatıcıdan orijinal en boy oranı ile tam ekran doldurma arasında geçiş yap; mevcut oynatma hızı 1× değilse sağ üstte kalıcı bir rozet olarak görünür."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Перемикай оригінальне співвідношення сторін і заповнення на весь екран прямо в плеєрі, а поточна швидкість відтворення з'являється постійним значком у верхньому правому куті, коли вона не дорівнює 1×."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在播放器中可以在原始宽高比和全屏填充之间切换;当播放速度不是 1× 时,右上角会持续显示当前速度的标记。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在播放器中可在原始長寬比和全螢幕填充之間切換;當播放速度不是 1× 時,右上角會持續顯示目前速度的標記。"
          }
        }
      }
    },
