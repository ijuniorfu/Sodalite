    "changelog.0_13_0.pipSubtitles.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titulky se nyní zobrazují v okně obrazu v obraze a fungují i po přetáčení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Undertekster vises nu i billede i billede-vinduet og virker fortsat efter spoling."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Untertitel erscheinen jetzt im Bild-in-Bild-Fenster und funktionieren auch nach dem Spulen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι υπότιτλοι εμφανίζονται πλέον στο παράθυρο εικόνας σε εικόνα και συνεχίζουν να λειτουργούν μετά την αναζήτηση."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Subtitles now appear inside the PiP window and keep working after seeking."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los subtítulos ahora aparecen en la ventana de imagen dentro de imagen y siguen funcionando después de avanzar o retroceder."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tekstitykset näkyvät nyt kuva kuvassa -ikkunassa ja toimivat myös kelauksen jälkeen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les sous-titres apparaissent désormais dans la fenêtre image dans l'image et continuent de fonctionner après une avance ou un retour rapide."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titlovi se sada prikazuju u prozoru slike u slici i rade i nakon premotavanja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A feliratok mostantól megjelennek a kép a képben ablakban, és tekerés után is működnek."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I sottotitoli ora vengono mostrati nella finestra picture in picture e continuano a funzionare dopo lo scorrimento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ピクチャインピクチャのウインドウに字幕が表示され、シーク後も機能し続けます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "이제 화면 속 화면 창에 자막이 표시되며 탐색 후에도 계속 작동합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Undertekster vises nå i bilde-i-bilde-vinduet og fungerer også etter spoling."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ondertitels verschijnen nu in het beeld-in-beeld-venster en blijven werken na het spoelen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Napisy pojawiają się teraz w oknie obrazu w obrazie i działają także po przewijaniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As legendas agora aparecem na janela de picture in picture e continuam funcionando após avançar ou retroceder."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As legendas aparecem agora na janela de imagem na imagem e continuam a funcionar depois de avançar ou recuar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Subtitrările apar acum în fereastra imagine în imagine și continuă să funcționeze după derulare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Субтитры теперь отображаются в окне «картинка в картинке» и продолжают работать после перемотки."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titulky sa teraz zobrazujú v okne obrazu v obraze a fungujú aj po pretáčaní."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Undertexter visas nu i bild-i-bild-fönstret och fortsätter fungera efter spolning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Altyazılar artık resim içinde resim penceresinde görünüyor ve ileri geri sarmadan sonra da çalışmaya devam ediyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Субтитри тепер відображаються у вікні «картинка в картинці» та продовжують працювати після перемотування."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "字幕现在会显示在画中画窗口中，快进快退后仍可正常显示。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "字幕現在會顯示在畫中畫視窗中，快轉倒轉後仍可正常顯示。"
          }
        }
      }
    },
