    "changelog.0_7_0.liveStats.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds nyní zobrazují živé hodnoty A/V synchronizace, datového toku a vyrovnávací paměti. Volitelně zapni sekci Engine Diagnostics pro hlubší pohled."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds viser nu live tal for A/V-synk, bitrate og buffer. Slå den valgfri Engine Diagnostics-sektion til for et dybere kig."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Die Stats for Nerds zeigen jetzt Live-Werte zu A/V-Sync, Bitrate und Puffer. Optional kannst du eine zusätzliche Engine-Diagnose-Sektion einblenden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα Stats for Nerds δείχνουν τώρα ζωντανές τιμές για A/V συγχρονισμό, ρυθμό bit και buffer. Ενεργοποίησε προαιρετικά την ενότητα Engine Diagnostics για πιο εις βάθος εικόνα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds now show live A/V sync, bitrate, and buffer figures. Toggle the optional Engine Diagnostics section for a deeper look."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds ahora muestra valores en vivo de sincronía A/V, bitrate y búfer. Activa la sección opcional Engine Diagnostics para un análisis más profundo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds näyttää nyt A/V-synkronoinnin, bittinopeuden ja puskurin reaaliaikaiset arvot. Ota lisävalintainen Engine Diagnostics -osio käyttöön syvempää tarkastelua varten."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds affiche désormais des valeurs en direct pour la synchronisation A/V, le débit binaire et le tampon. Active la section optionnelle Engine Diagnostics pour aller plus loin."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds sada prikazuje žive vrijednosti A/V sinkronizacije, brzine prijenosa i međuspremnika. Po želji uključi sekciju Engine Diagnostics za detaljniji pregled."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A Stats for Nerds mostantól élőben mutatja az A/V-szinkront, a bitrátát és a puffert. Mélyebb betekintéshez kapcsold be a nem kötelező Engine Diagnostics részt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds ora mostra valori live di sincronizzazione A/V, bitrate e buffer. Attiva la sezione opzionale Engine Diagnostics per un'analisi più approfondita."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds に A/V 同期、ビットレート、バッファのライブ値が表示されるようになりました。詳細を見たい場合はオプションの Engine Diagnostics セクションを有効化してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds에 A/V 동기, 비트레이트, 버퍼의 실시간 값이 표시됩니다. 더 자세히 보려면 선택 항목인 Engine Diagnostics 섹션을 켜세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds viser nå sanntidsverdier for A/V-synk, bitrate og buffer. Slå på den valgfrie Engine Diagnostics-seksjonen for et dypere blikk."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds toont nu live-waarden voor A/V-sync, bitrate en buffer. Schakel de optionele sectie Engine Diagnostics in voor een diepere blik."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds pokazuje teraz na żywo synchronizację A/V, bitrate i bufor. Włącz opcjonalną sekcję Engine Diagnostics, by spojrzeć głębiej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O Stats for Nerds agora exibe valores ao vivo de sincronia A/V, bitrate e buffer. Ative a seção opcional Engine Diagnostics para uma análise mais profunda."
