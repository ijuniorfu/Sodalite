        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sodalite ist Open Source unter der GPL-3.0 mit App-Store-Ausnahme. Diese App verwendet FFmpeg und die weiteren oben aufgeführten Komponenten."
