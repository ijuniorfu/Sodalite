    "settings.playback.statsForNerds.subtitle" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Přidá k přehrávači tlačítko informací zobrazující kodek, dekodér a podrobnosti kontejneru."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tilføjer en infoknap til afspilleren, der viser codec, dekoder og containerdetaljer."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fügt im Player einen Info-Button hinzu, der Codec-, Decoder- und Container-Infos anzeigt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Προσθέτει ένα κουμπί πληροφοριών στο πρόγραμμα αναπαραγωγής που δείχνει κωδικοποιητή, αποκωδικοποιητή και λεπτομέρειες κοντέινερ."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Add an info button to the player that shows codec, decoder, and container details."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Añade un botón de información al reproductor que muestra códec, decodificador y detalles del contenedor."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lisää soittimeen infopainikkeen, joka näyttää koodekin, dekooderin ja säilön tiedot."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ajoute un bouton d'info dans le lecteur qui affiche le codec, le décodeur et les détails du conteneur."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dodaje gumb za informacije u player koji prikazuje kodek, dekoder i podatke o spremniku."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Egy infógombot ad a lejátszóhoz, amely megjeleníti a kodek-, dekódoló- és tárolóinformációkat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Aggiunge un pulsante info al player che mostra codec, decoder e dettagli del contenitore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "コーデック、デコーダー、コンテナの詳細を表示する情報ボタンをプレーヤーに追加します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "코덱, 디코더, 컨테이너 세부 정보를 표시하는 정보 버튼을 플레이어에 추가합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Legger til en infoknapp i spilleren som viser kodek, dekoder og containerdetaljer."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Voegt een infoknop toe aan de speler met codec-, decoder- en containergegevens."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dodaje przycisk informacji do odtwarzacza pokazujący kodek, dekoder i szczegóły kontenera."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Adiciona um botão de informações ao player que mostra codec, decodificador e detalhes do contêiner."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Adiciona um botão de informações ao leitor que mostra codec, descodificador e detalhes do contentor."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Adaugă un buton info în player care afișează codec, decodor și detalii despre container."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Добавляет в плеер кнопку информации с подробностями о кодеке, декодере и контейнере."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pridá k prehrávaču tlačidlo informácií zobrazujúce kodek, dekodér a podrobnosti kontajnera."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lägger till en infoknapp i spelaren som visar codec, avkodare och containerdetaljer."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Oynatıcıya codec, kod çözücü ve kapsayıcı ayrıntılarını gösteren bir bilgi düğmesi ekler."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
