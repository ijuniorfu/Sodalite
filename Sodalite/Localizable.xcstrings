    "changelog.0_9_0.streaming.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odolnější streamovací připojení udrží přímé přehrávání stabilní i přes pomalé nebo nespolehlivé CDN."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En mere robust streamingforbindelse holder direkte afspilning stabil over langsomme eller upålidelige CDN'er."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Eine widerstandsfähigere Streaming-Verbindung hält die direkte Wiedergabe über langsame oder unzuverlässige CDNs stabil."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Μια πιο ανθεκτική σύνδεση ροής διατηρεί σταθερή την απευθείας αναπαραγωγή σε αργά ή αναξιόπιστα CDN."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A more resilient streaming connection keeps direct playback stable over slow or unreliable CDNs."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una conexión de streaming más resistente mantiene estable la reproducción directa en CDN lentas o poco fiables."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sitkeämpi suoratoistoyhteys pitää suoran toiston vakaana hitailla tai epäluotettavilla CDN-palvelimilla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Une connexion de diffusion plus robuste maintient la lecture directe stable sur les CDN lents ou peu fiables."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Otpornija streaming veza održava izravnu reprodukciju stabilnom čak i preko sporih ili nepouzdanih CDN mreža."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Egy ellenállóbb streamkapcsolat stabilan tartja a közvetlen lejátszást lassú vagy megbízhatatlan CDN-eken is."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una connessione di streaming più resiliente mantiene stabile la riproduzione diretta su CDN lente o inaffidabili."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "接続の耐障害性を高め、低速で不安定な CDN でもダイレクト再生を安定して継続します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "연결 안정성을 강화하여 느리거나 불안정한 CDN에서도 다이렉트 재생을 안정적으로 유지합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En mer robust strømmetilkobling holder direkteavspilling stabil over trege eller upålitelige CDN-er."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Een veerkrachtigere streamingverbinding houdt directe weergave stabiel over trage of onbetrouwbare CDN's."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bardziej odporne połączenie strumieniowe utrzymuje stabilne odtwarzanie bezpośrednie nawet przez wolne lub zawodne sieci CDN."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uma conexão de streaming mais resistente mantém a reprodução direta estável em CDNs lentas ou instáveis."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uma ligação de transmissão mais resistente mantém a reprodução direta estável em CDN lentas ou pouco fiáveis."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O conexiune de streaming mai rezistentă menține redarea directă stabilă pe rețele CDN lente sau nesigure."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Более устойчивое потоковое соединение сохраняет стабильность прямого воспроизведения на медленных или ненадёжных CDN."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odolnejšie streamovacie pripojenie udrží priame prehrávanie stabilné aj cez pomalé alebo nespoľahlivé CDN."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En mer motståndskraftig streaminganslutning håller direktuppspelning stabil över långsamma eller opålitliga CDN:er."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Daha dayanıklı bir yayın bağlantısı, yavaş veya güvenilmez CDN'lerde doğrudan oynatmayı kararlı tutar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Стійкіше потокове з'єднання зберігає стабільність прямого відтворення на повільних або ненадійних CDN."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "更具韧性的连接让直接播放在缓慢或不稳定的 CDN 上也能保持稳定。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "更具韌性的連線讓直接播放在緩慢或不穩定的 CDN 上也能保持穩定。"
          }
        }
      }
    },
