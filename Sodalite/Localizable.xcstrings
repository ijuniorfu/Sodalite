    "changelog.0_5_0.staleSubtitleGhost.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jediný řádek titulků z předchozí epizody se už krátce neobjeví na začátku dalšího přehrávání."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En enkelt linje af forrige episodes undertekster blinker ikke længere kortvarigt ved starten af den næste afspilning."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Eine einzelne Zeile der Untertitel der Vorgänger-Folge taucht nicht mehr kurz beim Start der nächsten Wiedergabe auf."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Μια μεμονωμένη γραμμή υποτίτλων του προηγούμενου επεισοδίου δεν εμφανίζεται πλέον στιγμιαία στην αρχή της επόμενης αναπαραγωγής."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A single line of the previous episode's subtitles no longer briefly flashes at the start of the next playback."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una línea suelta de los subtítulos del episodio anterior ya no aparece brevemente al iniciar la siguiente reproducción."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Edellisen jakson tekstitysten yksittäinen rivi ei enää vilahda hetkellisesti seuraavan toiston alussa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Une ligne isolée des sous-titres de l'épisode précédent n'apparaît plus brièvement au début de la lecture suivante."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jedan redak titlova prethodne epizode više ne treperi na kratko na početku sljedeće reprodukcije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az előző epizód feliratainak egyetlen sora már nem villan fel rövid időre a következő lejátszás indulásakor."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una singola riga dei sottotitoli dell'episodio precedente non lampeggia più all'inizio della riproduzione successiva."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "前エピソードの字幕の1行が、次の再生開始時に一瞬表示される現象がなくなりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "이전 에피소드의 자막 한 줄이 다음 재생 시작 시 잠깐 깜빡이지 않습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En enkelt linje av forrige episodes undertekster blinker ikke lenger kort ved starten av den neste avspillingen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Een losse regel ondertitels van de vorige aflevering verschijnt niet langer kortstondig bij het starten van de volgende afspeelsessie."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pojedyncza linia napisów z poprzedniego odcinka nie miga już na początku kolejnego odtwarzania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uma única linha das legendas do episódio anterior não pisca mais brevemente no início da reprodução seguinte."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uma única linha das legendas do episódio anterior já não aparece brevemente no início da reprodução seguinte."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O singură linie a subtitrărilor episodului precedent nu mai clipește scurt la începutul redării următoare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Одна строка субтитров предыдущей серии больше не мелькает в начале следующего воспроизведения."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jediný riadok titulkov z predchádzajúcej epizódy sa už krátko neobjaví na začiatku ďalšieho prehrávania."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En enskild rad av föregående avsnitts undertexter blinkar inte längre kort i början av nästa uppspelning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Önceki bölümün altyazılarından tek bir satır artık sonraki oynatmanın başında kısa süre belirmiyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Один рядок субтитрів попередньої серії більше не з'являється на короткий час на початку наступного відтворення."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "上一集的一行字幕不会再在下一次播放开始时短暂闪现。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "上一集的一行字幕不會再在下一次播放開始時短暫閃現。"
          }
        }
      }
    },
