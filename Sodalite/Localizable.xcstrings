    "parental.pin.recovery.failed" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ověření se nezdařilo. Zkontrolujte heslo a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kunne ikke bekræfte. Kontrollér adgangskoden, og prøv igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Überprüfung fehlgeschlagen. Überprüfe das Passwort und versuche es erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
