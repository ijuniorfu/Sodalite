    "changelog.0_11_0.liveDirectAudio.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanály, které dodávají obraz a zvuk jako oddělené streamy (ARD a další), se nyní přehrávají přímo v plné kvalitě se zvukem, bez překódování na serveru."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanaler, der leverer video og lyd som separate streams (ARD med flere), afspilles nu direkte i fuld kvalitet med lyd, uden server-transcoding."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sender, die Video und Ton als getrennte Streams liefern (ARD und andere), spielen jetzt direkt in voller Qualität mit Ton, ohne Server-Transkodierung."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Κανάλια που παρέχουν βίντεο και ήχο ως ξεχωριστές ροές (ARD και άλλα) παίζουν πλέον απευθείας σε πλήρη ποιότητα με ήχο, χωρίς διακωδικοποίηση στον διακομιστή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Channels that deliver video and audio as separate streams (ARD and others) now play directly with full quality and sound, no server transcoding."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los canales que entregan vídeo y audio como streams separados (ARD y otros) ahora se reproducen directamente con calidad completa y sonido, sin transcodificación en el servidor."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanavat, jotka toimittavat kuvan ja äänen erillisinä streameina (ARD ja muut), toistuvat nyt suoraan täydellä laadulla ja äänellä ilman palvelimen transkoodausta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les chaînes qui livrent la vidéo et l'audio en flux séparés (ARD et autres) se lisent désormais directement en pleine qualité avec le son, sans transcodage serveur."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanali koji isporučuju video i zvuk kao odvojene streamove (ARD i drugi) sada se reproduciraju izravno u punoj kvaliteti sa zvukom, bez transkodiranja na poslužitelju."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A képet és hangot külön streamként szállító csatornák (ARD és társai) mostantól közvetlenül, teljes minőségben és hanggal játszanak le, szerveroldali átkódolás nélkül."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I canali che forniscono video e audio come stream separati (ARD e altri) ora si riproducono direttamente in piena qualità con l'audio, senza transcodifica sul server."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "映像と音声を別ストリームで配信するチャンネル(ARDなど)も、サーバーでのトランスコードなしにフル画質・音声付きで直接再生できるようになりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "영상과 음성을 별도 스트림으로 제공하는 채널(ARD 등)도 이제 서버 트랜스코딩 없이 전체 화질과 소리로 직접 재생됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanaler som leverer video og lyd som separate strømmer (ARD med flere), spilles nå av direkte i full kvalitet med lyd, uten servertranskoding."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanalen die beeld en geluid als aparte streams leveren (ARD en andere) spelen nu direct af in volle kwaliteit met geluid, zonder servertranscoding."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanały dostarczające obraz i dźwięk jako osobne strumienie (ARD i inne) odtwarzają się teraz bezpośrednio w pełnej jakości z dźwiękiem, bez transkodowania na serwerze."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Canais que entregam vídeo e áudio como streams separados (ARD e outros) agora tocam diretamente em qualidade total com som, sem transcodificação no servidor."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os canais que entregam vídeo e áudio como streams separados (ARD e outros) reproduzem agora diretamente em qualidade total com som, sem transcodificação no servidor."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Canalele care livrează imaginea și sunetul ca fluxuri separate (ARD și altele) se redau acum direct, la calitate completă și cu sunet, fără transcodare pe server."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Каналы, передающие видео и звук отдельными потоками (ARD и другие), теперь воспроизводятся напрямую в полном качестве со звуком, без транскодирования на сервере."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanály, ktoré dodávajú obraz a zvuk ako oddelené streamy (ARD a ďalšie), sa teraz prehrávajú priamo v plnej kvalite so zvukom, bez prekódovania na serveri."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanaler som levererar bild och ljud som separata strömmar (ARD med flera) spelas nu upp direkt i full kvalitet med ljud, utan servertranskodning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Görüntü ve sesi ayrı akışlar olarak sunan kanallar (ARD ve diğerleri) artık sunucu dönüştürmesi olmadan tam kalitede ve sesli olarak doğrudan oynatılıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Канали, що передають відео та звук окремими потоками (ARD та інші), тепер відтворюються напряму в повній якості зі звуком, без транскодування на сервері."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "视频与音频分流传输的频道(如 ARD 等)现在可以全画质带声音直接播放,无需服务器转码。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "影音分流傳輸的頻道(如 ARD 等)現在可以全畫質帶聲音直接播放,無需伺服器轉碼。"
          }
        }
      }
    },
