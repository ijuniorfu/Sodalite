    "settings.licenses.footer" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sodalite je open source pod licencí GPL-3.0 s výjimkou pro App Store. Tato aplikace používá FFmpeg a další výše uvedené komponenty."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sodalite er open source under GPL-3.0 med en App Store-undtagelse. Denne app bruger FFmpeg og de øvrige komponenter, der er nævnt ovenfor."
          }
