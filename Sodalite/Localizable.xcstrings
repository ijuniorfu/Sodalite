          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Beveiligde profielen hebben de pincode nodig om te wisselen, uit te loggen of de instellingen te openen"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
