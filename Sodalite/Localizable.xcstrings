    "changelog.0_11_0.liveResilience.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Krátké výpadky playlistu se nyní opakují neviditelně a přerušená živá relace se znovu připojí na živou hranu, místo aby zamrzla."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Korte playlist-udfald prøves nu igen usynligt, og en afbrudt live-session hopper tilbage til live-kanten i stedet for at fryse."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kurze Playlist-Aussetzer werden jetzt unsichtbar wiederholt, und eine unterbrochene Live-Sitzung steigt wieder an der Live-Kante ein, statt einzufrieren."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Σύντομες διακοπές της λίστας αναπαραγωγής επαναλαμβάνονται πλέον αόρατα, και μια διακοπείσα ζωντανή συνεδρία επανασυνδέεται στο ζωντανό σημείο αντί να παγώνει."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Short playlist hiccups now retry invisibly, and a disrupted live session rejoins at the live edge instead of freezing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los cortes breves de la playlist ahora se reintentan de forma invisible, y una sesión en directo interrumpida se reincorpora al borde en vivo en lugar de congelarse."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lyhyet soittolistakatkokset yritetään nyt uudelleen huomaamattomasti, ja keskeytynyt livesessio liittyy takaisin lähetyksen reunaan jäätymisen sijaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les brèves interruptions de playlist sont désormais réessayées de façon invisible, et une session en direct interrompue rejoint le direct au lieu de se figer."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kratki prekidi playliste sada se nevidljivo ponavljaju, a prekinuta sesija uživo ponovno se priključuje na rub uživo umjesto da se zamrzne."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A rövid playlist-kimaradásokat mostantól észrevétlenül újrapróbálja, a megszakadt élő munkamenet pedig az élő szélnél csatlakozik vissza, fagyás helyett."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le brevi interruzioni della playlist ora vengono ritentate in modo invisibile, e una sessione live interrotta si riaggancia al punto live invece di bloccarsi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "プレイリストの短い途切れは目立たないよう自動的に再試行され、中断されたライブセッションはフリーズせずライブエッジに復帰します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "짧은 재생목록 끊김은 이제 보이지 않게 재시도되며, 중단된 라이브 세션은 멈추는 대신 라이브 지점으로 다시 합류합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Korte spillelistebrudd prøves nå på nytt usynlig, og en avbrutt direktesending blir med igjen på direktekanten i stedet for å fryse."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Korte playlist-haperingen worden nu onzichtbaar opnieuw geprobeerd, en een onderbroken livesessie sluit weer aan op de live-rand in plaats van te bevriezen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Krótkie przerwy playlisty są teraz niewidocznie ponawiane, a przerwana sesja na żywo dołącza ponownie na krawędzi na żywo, zamiast się zawieszać."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Falhas breves de playlist agora são repetidas de forma invisível, e uma sessão ao vivo interrompida volta para a borda ao vivo em vez de congelar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As falhas breves da playlist são agora repetidas de forma invisível, e uma sessão em direto interrompida volta a juntar-se à margem em direto em vez de congelar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Întreruperile scurte ale playlistului sunt acum reîncercate invizibil, iar o sesiune live întreruptă se realătură la marginea live în loc să înghețe."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Короткие сбои плейлиста теперь незаметно повторяются, а прерванная живая сессия возвращается к живому краю вместо зависания."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Krátke výpadky playlistu sa teraz neviditeľne opakujú a prerušená živá relácia sa znova pripojí na živý okraj, namiesto toho aby zamrzla."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Korta spellisteavbrott provas nu om osynligt, och en avbruten livesession ansluter igen vid livekanten i stället för att frysa."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kısa oynatma listesi kesintileri artık görünmez şekilde yeniden deneniyor ve kesilen canlı oturum donmak yerine canlı kenara yeniden katılıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Короткі збої плейлиста тепер непомітно повторюються, а перервана жива сесія повертається до живого краю замість зависання."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "播放列表的短暂中断现在会自动无感重试,中断的直播会重新接入直播边缘,而不会卡住。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "播放清單的短暫中斷現在會自動無感重試,中斷的直播會重新接回直播邊緣,而不會卡住。"
          }
        }
      }
    },
