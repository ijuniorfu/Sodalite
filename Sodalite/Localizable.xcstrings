    "changelog.0_10_0.liveDirect.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Živé kanály se kde to jde přehrávají přímo ze zdroje: start během sekund místo čekání na server, s automatickým záložním režimem, když ho kanál potřebuje."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Live-kanaler afspilles direkte fra kilden, hvor det er muligt: start på sekunder i stedet for at vente på serveren, med automatisk fallback, når en kanal har brug for det."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Live-Sender spielen wo möglich direkt von ihrer Quelle: Start in Sekunden statt Warten auf den Server, mit automatischem Fallback, wenn ein Sender es braucht."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα ζωντανά κανάλια αναπαράγονται απευθείας από την πηγή τους όπου είναι δυνατό: εκκίνηση σε δευτερόλεπτα αντί για αναμονή στον διακομιστή, με αυτόματη εναλλακτική όταν τη χρειάζεται ένα κανάλι."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Live channels play straight from their source where possible: starting in seconds instead of waiting on the server, with automatic fallback when a channel needs it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los canales en directo se reproducen directamente desde su fuente cuando es posible: arrancan en segundos en lugar de esperar al servidor, con respaldo automático cuando un canal lo necesita."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Suorat kanavat toistetaan mahdollisuuksien mukaan suoraan lähteestä: käynnistys sekunneissa palvelimen odottamisen sijaan, ja automaattinen varareitti, kun kanava sitä tarvitsee."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les chaînes en direct sont lues directement depuis leur source lorsque c'est possible : démarrage en quelques secondes au lieu d'attendre le serveur, avec bascule automatique quand une chaîne en a besoin."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanali uživo reproduciraju se izravno iz izvora gdje je to moguće: pokretanje u sekundama umjesto čekanja na poslužitelj, uz automatski rezervni način kad ga kanal treba."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az élő csatornák ahol lehet, közvetlenül a forrásukból játszanak: indulás másodpercek alatt a szerverre várás helyett, automatikus tartalékkal, ha egy csatornának szüksége van rá."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I canali in diretta vengono riprodotti direttamente dalla loro fonte quando possibile: partono in pochi secondi invece di attendere il server, con fallback automatico quando un canale ne ha bisogno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ライブチャンネルは可能な場合ソースから直接再生されます。サーバーを待たずに数秒で開始し、必要なチャンネルでは自動的にフォールバックします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "라이브 채널은 가능한 경우 소스에서 바로 재생됩니다. 서버를 기다리는 대신 몇 초 만에 시작되고, 필요한 채널에서는 자동으로 대체 경로를 사용합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Direktekanaler spilles av rett fra kilden der det er mulig: start på sekunder i stedet for å vente på serveren, med automatisk reserveløsning når en kanal trenger det."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Live zenders spelen waar mogelijk rechtstreeks vanaf hun bron: starten in seconden in plaats van wachten op de server, met automatische terugval wanneer een zender dat nodig heeft."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanały na żywo odtwarzane są tam, gdzie to możliwe, bezpośrednio ze źródła: start w kilka sekund zamiast czekania na serwer, z automatycznym trybem awaryjnym, gdy kanał tego potrzebuje."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Canais ao vivo são reproduzidos direto da fonte sempre que possível: começam em segundos em vez de esperar pelo servidor, com fallback automático quando um canal precisar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os canais em direto são reproduzidos diretamente da fonte sempre que possível: começam em segundos em vez de esperar pelo servidor, com recurso automático quando um canal precisar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Canalele live sunt redate direct de la sursă acolo unde se poate: pornesc în câteva secunde în loc să aștepte serverul, cu revenire automată când un canal are nevoie."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Каналы по возможности воспроизводятся напрямую из источника: запуск за секунды вместо ожидания сервера, с автоматическим резервным режимом, когда он нужен каналу."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Živé kanály sa kde sa dá prehrávajú priamo zo zdroja: štart za pár sekúnd namiesto čakania na server, s automatickým záložným režimom, keď ho kanál potrebuje."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Livekanaler spelas upp direkt från källan där det är möjligt: start på några sekunder i stället för att vänta på servern, med automatisk reservväg när en kanal behöver det."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Canlı kanallar mümkün olduğunda doğrudan kaynağından oynatılır: sunucuyu beklemek yerine saniyeler içinde başlar, gerektiğinde kanal için otomatik yedek yola geçilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Канали за можливості відтворюються напряму з джерела: запуск за лічені секунди замість очікування сервера, з автоматичним резервним режимом, коли він потрібен каналу."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "直播频道在可能时直接从源播放：几秒即可开始，无需等待服务器，频道需要时会自动回退。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "直播頻道在可行時會直接從來源播放：幾秒內即可開始，無需等待伺服器，頻道需要時會自動回退。"
          }
        }
      }
    },
