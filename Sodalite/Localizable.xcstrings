    "changelog.0_9_0.nowPlaying.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systémové ovládání přehrávání už nezůstane prázdné, když se automaticky spustí epizoda nebo přepnete zvukovou stopu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systemets Now Playing-betjening bliver ikke længere tom, når en episode afspilles automatisk, eller du skifter lydspor."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Die Now-Playing-Steuerung des Systems bleibt nicht mehr leer, wenn eine Episode automatisch startet oder du die Tonspur wechselst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα χειριστήρια αναπαραγωγής του συστήματος δεν αδειάζουν πλέον όταν ξεκινά αυτόματα ένα επεισόδιο ή όταν αλλάζετε το κανάλι ήχου."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "The system Now Playing controls no longer go blank when an episode autoplays or you switch the audio track."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los controles de reproducción en curso del sistema ya no se quedan en blanco cuando un episodio se reproduce automáticamente o cambias la pista de audio."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Järjestelmän toistosäätimet eivät enää tyhjene, kun jakso toistuu automaattisesti tai vaihdat ääniraitaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les commandes de lecture en cours du système ne s'effacent plus lorsqu'un épisode démarre automatiquement ou que vous changez de piste audio."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sistemske kontrole reprodukcije više se ne prazne kada se epizoda automatski pokrene ili promijenite zvučni zapis."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A rendszer lejátszásvezérlői többé nem üresednek ki, amikor egy epizód automatikusan elindul, vagy hangsávot váltasz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I controlli In riproduzione del sistema non si svuotano più quando un episodio parte in automatico o cambi la traccia audio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "エピソードの自動再生時や音声トラックの切り替え時に、システムの再生コントロールが空白になる不具合を解消しました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "에피소드 자동 재생이나 오디오 트랙 전환 시 시스템 재생 컨트롤이 비어 보이던 문제를 해결했습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systemets Now Playing-kontroller blir ikke lenger tomme når en episode spilles av automatisk eller du bytter lydspor."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "De Now Playing-bediening van het systeem wordt niet meer leeg wanneer een aflevering automatisch start of je het audiospoor wisselt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systemowe elementy sterowania odtwarzaniem nie znikają już, gdy automatycznie uruchamia się odcinek lub przełączasz ścieżkę dźwiękową."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os controles de reprodução do sistema não ficam mais em branco quando um episódio começa automaticamente ou você troca a faixa de áudio."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os controlos de reprodução do sistema deixam de ficar em branco quando um episódio começa automaticamente ou quando muda a faixa de áudio."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Comenzile de redare ale sistemului nu mai rămân goale atunci când un episod pornește automat sau când schimbi pista audio."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Системные элементы управления воспроизведением больше не пропадают при автозапуске следующей серии или смене звуковой дорожки."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systémové ovládanie prehrávania už nezostane prázdne, keď sa automaticky spustí epizóda alebo prepnete zvukovú stopu."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systemets Now Playing-kontroller blir inte längre tomma när ett avsnitt spelas upp automatiskt eller när du byter ljudspår."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bir bölüm otomatik oynatıldığında veya ses parçasını değiştirdiğinizde sistem Çalınıyor denetimleri artık boş kalmıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Системні елементи керування відтворенням більше не зникають під час автозапуску наступного епізоду чи зміни звукової доріжки."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在单集自动播放或切换音轨时，系统播放控制不再出现空白。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在單集自動播放或切換音軌時，系統播放控制不再出現空白。"
          }
        }
      }
    },
