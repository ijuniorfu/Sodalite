    "support.tipJar.subtitle" : {
      "comment": "Subtitle explaining the Tip Jar section",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jednorázová dýška, bez podmínek. Kupujte, kolik chcete."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Engangsdrikkepenge, ingen betingelser. Køb så mange du vil."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Einmalige Trinkgelder, ohne Bedingungen. So viele, wie du magst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Εφάπαξ φιλοδωρήματα, χωρίς δεσμεύσεις. Αγοράστε όσα θέλετε."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "One-time tips, no strings attached. Buy as many as you like."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Propinas únicas, sin compromisos. Compra tantas como quieras."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kertaluonteiset juomarahat, ei ehtoja. Osta niin monta kuin haluat."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pourboires uniques, sans engagement. Achetez-en autant que vous voulez."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jednokratne napojnice, bez obveza. Kupujte koliko želite."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Egyszeri borravalók, kötöttségek nélkül. Vegyél annyit, amennyit csak akarsz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mance una tantum, senza vincoli. Acquistane quante vuoi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "一回限りのチップ、条件なし。好きなだけ購入できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "일회성 팁, 조건 없음. 원하는 만큼 구매하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Engangs drikkepenger, ingen betingelser. Kjøp så mange du vil."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Eenmalige fooien, geen voorwaarden. Koop er zoveel als je wilt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jednorazowe napiwki, bez zobowiązań. Kup tyle, ile chcesz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gorjetas únicas, sem compromissos. Compre quantas quiser."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gorjetas únicas, sem compromissos. Compre quantas quiser."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bacșișuri unice, fără condiții. Cumpără câte vrei."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Разовые чаевые, без обязательств. Покупайте сколько хотите."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jednorazové prepitné, bez záväzkov. Kúpte si, koľko chcete."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Engångsdricks, inga villkor. Köp så många du vill."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tek seferlik bahşişler, hiçbir şart yok. İstediğiniz kadar satın alın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Одноразові чайові, без зобов'язань. Купуйте скільки завгодно."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "一次性小费，没有附加条件。想买多少就买多少。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "一次性小費，沒有附加條件。想買多少就買多少。"
          }
        }
      }
    },
