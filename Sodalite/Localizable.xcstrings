    "changelog.0_12_0.backdropFix.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tituly bez obrázku na pozadí už neschovávají tlačítka za rozostřením, takže celá stránka je opět použitelná."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titler uden baggrundsbillede skjuler ikke længere knapperne bag en sløring, så hele siden kan bruges igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titel ohne Hintergrundbild verstecken ihre Buttons nicht mehr hinter einem Weichzeichner, die ganze Seite ist wieder bedienbar."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι τίτλοι χωρίς εικόνα φόντου δεν κρύβουν πια τα κουμπιά πίσω από θόλωμα, οπότε όλη η σελίδα είναι ξανά λειτουργική."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titles without backdrop art no longer hide their buttons behind a blur, so the whole page is usable again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los títulos sin imagen de fondo ya no ocultan sus botones tras un desenfoque, así que toda la página vuelve a ser utilizable."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nimikkeet ilman taustakuvaa eivät enää piilota painikkeitaan sumennuksen taakse, joten koko sivu on taas käytettävissä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les titres sans image de fond ne cachent plus leurs boutons derrière un flou, toute la page est de nouveau utilisable."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Naslovi bez pozadinske slike više ne skrivaju svoje tipke iza zamućenja, pa je cijela stranica opet upotrebljiva."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A háttérkép nélküli címek már nem rejtik a gombjaikat egy elmosás mögé, így az egész oldal újra használható."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I titoli senza immagine di sfondo non nascondono più i pulsanti dietro una sfocatura, così l'intera pagina torna utilizzabile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "背景アートのない作品でも、ボタンがぼかしの後ろに隠れなくなり、ページ全体が再び使えるようになりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "배경 아트가 없는 작품도 더는 버튼이 흐림 효과 뒤에 가려지지 않아, 페이지 전체를 다시 사용할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titler uten bakgrunnsbilde skjuler ikke lenger knappene bak en uskarphet, så hele siden er brukbar igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titels zonder achtergrondafbeelding verbergen hun knoppen niet meer achter een vervaging, dus de hele pagina is weer bruikbaar."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tytuły bez grafiki tła nie chowają już przycisków za rozmyciem, więc cała strona znów jest użyteczna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Títulos sem arte de fundo não escondem mais os botões atrás de um desfoque, então a página inteira volta a ser utilizável."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os títulos sem imagem de fundo já não escondem os botões atrás de uma desfocagem, por isso toda a página volta a ser utilizável."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titlurile fără imagine de fundal nu mai ascund butoanele în spatele unui efect de neclaritate, așa că toată pagina e din nou utilizabilă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Тайтлы без фонового изображения больше не прячут кнопки за размытием, поэтому вся страница снова пригодна для использования."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tituly bez obrázka na pozadí už neskrývajú tlačidlá za rozostrením, takže celá stránka je opäť použiteľná."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titlar utan bakgrundsbild döljer inte längre sina knappar bakom en oskärpa, så hela sidan går att använda igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Arka plan görseli olmayan başlıklar artık düğmelerini bir bulanıklığın arkasına gizlemiyor, böylece sayfanın tamamı yeniden kullanılabilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Тайтли без фонового зображення більше не ховають кнопки за розмиттям, тож уся сторінка знову придатна до використання."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "没有背景图的影片不再把按钮藏在模糊之后，整个页面重新可用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "沒有背景圖的影片不再把按鈕藏在模糊之後，整個頁面重新可用。"
          }
        }
      }
    },
