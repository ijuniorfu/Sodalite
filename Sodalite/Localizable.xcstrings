    "changelog.0_5_0.chapterMarkers.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Posuvník zobrazuje značky na hranicích kapitol a vyhrazená rozbalovací nabídka v ovládací liště přeskočí přímo na libovolnou kapitolu. U epizod seriálů skryto, protože data kapitol jsou tam obvykle automaticky generovaný šum."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Søgelinjen viser mærker ved kapitelgrænser, og en dedikeret rullemenu i afspilningslinjen springer direkte til et hvilket som helst kapitel. Skjult for serieafsnit, da kapiteldata dér som regel er automatisk genereret støj."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Die Scrub-Leiste zeigt Markierungen an den Kapitelgrenzen, und ein eigenes Dropdown in der Transportleiste springt direkt zu jedem Kapitel. Bei Serienfolgen ausgeblendet, da Kapitel-Daten dort meist automatisch generiertes Rauschen sind."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Η μπάρα αναζήτησης εμφανίζει σημάνσεις στα όρια των κεφαλαίων και ένα ειδικό αναπτυσσόμενο μενού στη μπάρα ελέγχου μεταβαίνει απευθείας σε οποιοδήποτε κεφάλαιο. Κρυμμένο σε επεισόδια σειρών, καθώς τα δεδομένα κεφαλαίων εκεί είναι συνήθως αυτόματα παραγόμενος θόρυβος."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "The scrub bar shows ticks at chapter boundaries, and a dedicated transport-bar dropdown jumps you straight to any chapter. Hidden for series episodes since chapter data on those is usually auto-generated noise."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La barra de búsqueda muestra marcas en los límites de los capítulos y un menú dedicado en la barra de transporte salta directo a cualquier capítulo. Oculto en episodios de series, ya que ahí los datos de capítulos suelen ser ruido generado automáticamente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hakupalkki näyttää merkinnät lukurajoilla, ja erillinen avattava valikko ohjauspalkissa siirtyy suoraan mihin tahansa lukuun. Piilotettu sarjajaksoissa, koska niissä lukutiedot ovat yleensä automaattisesti luotua kohinaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La barre de recherche affiche des repères aux limites des chapitres et un menu dédié dans la barre de lecture saute directement à n'importe quel chapitre. Masqué pour les épisodes de séries, car les données de chapitres y sont généralement du bruit auto-généré."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Traka za pretraživanje prikazuje oznake na granicama poglavlja, a posebna padajuća izbornika u kontrolnoj traci skače izravno na bilo koje poglavlje. Skriveno za epizode serija jer su podaci o poglavljima ondje obično automatski generirani šum."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A keresősáv jelzéseket mutat a fejezethatároknál, és a vezérlősávban egy külön legördülő menü közvetlenül bármelyik fejezetre ugrik. Sorozatepizódoknál elrejtve, mivel a fejezetadatok ott általában automatikusan generált zaj."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La barra di scrub mostra tacche ai confini dei capitoli e un menu dedicato nella barra dei controlli salta direttamente a qualsiasi capitolo. Nascosto per gli episodi delle serie, dato che lì i dati dei capitoli sono di solito rumore generato automaticamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "シークバーがチャプター境界に目盛りを表示し、トランスポートバーの専用メニューから任意のチャプターへ直接ジャンプできます。シリーズのエピソードでは、チャプター情報が通常自動生成のノイズなので非表示にしています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "스크럽 바가 챕터 경계에 눈금을 표시하고, 전송 바의 전용 드롭다운에서 어떤 챕터로든 바로 이동할 수 있습니다. 시리즈 에피소드에서는 챕터 데이터가 보통 자동 생성된 잡음이므로 숨겨집니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Søkelinjen viser merker ved kapittelgrenser, og en egen nedtrekksmeny i kontrollinjen hopper rett til hvilket som helst kapittel. Skjult for serieepisoder siden kapitteldata der vanligvis er automatisk generert støy."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "De scrubbalk toont streepjes op hoofdstukgrenzen, en een speciaal dropdownmenu in de transportbalk springt rechtstreeks naar elk hoofdstuk. Verborgen voor serieafleveringen omdat hoofdstukgegevens daar meestal automatisch gegenereerde ruis zijn."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pasek scrubbingu pokazuje znaczniki na granicach rozdziałów, a dedykowane menu w pasku odtwarzania przeskakuje bezpośrednio do dowolnego rozdziału. Ukryty dla odcinków seriali, ponieważ dane rozdziałów to tam zwykle automatycznie generowany szum."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A barra de busca mostra marcações nos limites dos capítulos, e um menu dedicado na barra de transporte salta direto para qualquer capítulo. Ocultado em episódios de séries, já que ali os dados de capítulos costumam ser ruído gerado automaticamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A barra de pesquisa mostra marcas nos limites dos capítulos, e um menu dedicado na barra de transporte salta directamente para qualquer capítulo. Oculto em episódios de séries, uma vez que aí os dados de capítulos costumam ser ruído gerado automaticamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bara de derulare afișează marcaje la limitele capitolelor, iar un meniu derulant dedicat din bara de control sare direct la orice capitol. Ascuns pentru episoadele de seriale, deoarece datele de capitol acolo sunt de obicei zgomot generat automat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Полоса перемотки показывает риски на границах глав, а отдельное выпадающее меню в панели управления переходит к любой главе. Скрыто для эпизодов сериалов, так как там данные глав обычно являются автоматически сгенерированным шумом."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Posuvník zobrazuje značky na hraniciach kapitol a vyhradená rozbaľovacia ponuka v ovládacej lište preskočí priamo na ľubovoľnú kapitolu. Pri epizódach seriálov skryté, pretože dáta kapitol sú tam zvyčajne automaticky generovaný šum."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sökningslisten visar markeringar vid kapitelgränser, och en särskild rullgardinsmeny i kontrollraden hoppar direkt till valfritt kapitel. Dold för serieavsnitt eftersom kapiteldata där oftast är automatiskt genererat brus."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sarma çubuğu bölüm sınırlarında işaretler gösterir ve oynatma çubuğundaki özel açılır menü doğrudan herhangi bir bölüme atlar. Bölüm verisi genelde otomatik üretilmiş gürültü olduğu için dizi bölümlerinde gizlenir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Смуга перемотування показує позначки на межах розділів, а окреме спливне меню в панелі керування переходить безпосередньо до будь-якого розділу. Приховано для епізодів серіалів, оскільки там дані розділів зазвичай є автоматично згенерованим шумом."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "进度条会在章节边界显示刻度,播放栏中的专用菜单可直接跳转到任意章节。剧集单集中通常的章节数据是自动生成的杂讯,因此对剧集隐藏此功能。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "進度條會在章節邊界顯示刻度,播放列中的專用選單可直接跳到任何章節。因為劇集單集中的章節資料通常是自動產生的雜訊,所以對劇集隱藏此功能。"
          }
        }
      }
    },
