    "player.error.liveRetuneExhausted" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Živý přenos opakovaně selhává. Zkuste kanál znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Livestreamen fejler hele tiden. Prøv kanalen igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Der Livestream schlägt immer wieder fehl. Bitte versuche es mit dem Sender erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Η ζωντανή ροή αποτυγχάνει συνεχώς. Δοκιμάστε ξανά το κανάλι."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "The live stream keeps failing. Please try the channel again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La emisión en directo falla continuamente. Vuelve a intentarlo con el canal."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Suora lähetys epäonnistuu toistuvasti. Kokeile kanavaa uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le flux en direct échoue sans cesse. Veuillez réessayer la chaîne."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Prijenos uživo stalno ne uspijeva. Pokušajte ponovno s kanalom."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az élő adás folyamatosan megszakad. Próbáld újra a csatornát."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lo streaming in diretta continua a interrompersi. Riprova con il canale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ライブ配信が繰り返し失敗しています。もう一度チャンネルをお試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "라이브 스트림이 계속 실패합니다. 채널을 다시 시도해 주세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Direktestrømmen feiler hele tiden. Prøv kanalen på nytt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "De livestream blijft mislukken. Probeer de zender opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Transmisja na żywo wciąż zawodzi. Spróbuj ponownie włączyć kanał."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A transmissão ao vivo continua falhando. Tente o canal novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A transmissão em direto continua a falhar. Tente novamente o canal."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Transmisiunea live eșuează în mod repetat. Încearcă din nou canalul."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Прямая трансляция постоянно прерывается. Попробуйте включить канал ещё раз."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Živý prenos opakovane zlyháva. Skúste kanál znova."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Livesändningen misslyckas hela tiden. Prova kanalen igen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
