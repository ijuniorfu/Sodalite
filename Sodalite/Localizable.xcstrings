    "changelog.0_9_0.episodeNowPlaying.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systémový název v ovládání přehrávání teď zahrnuje název seriálu a číslo série i epizody."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systemets Now Playing-titel indeholder nu seriens navn samt sæson- og episodenummer."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Der Now-Playing-Titel des Systems enthält jetzt den Seriennamen sowie Staffel- und Episodennummer."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ο τίτλος στην οθόνη αναπαραγωγής του συστήματος περιλαμβάνει τώρα το όνομα της σειράς και τον αριθμό κύκλου και επεισοδίου."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "The system Now Playing title now folds in the series name and the season and episode number."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "El título de reproducción en curso del sistema ahora incluye el nombre de la serie y el número de temporada y episodio."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Järjestelmän toistonäkymän otsikko sisältää nyt sarjan nimen sekä kauden ja jakson numeron."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le titre de la lecture en cours du système intègre désormais le nom de la série ainsi que le numéro de saison et d'épisode."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sistemski naslov reprodukcije sada uključuje naziv serije te broj sezone i epizode."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A rendszer lejátszási címe mostantól tartalmazza a sorozat nevét, valamint az évad és az epizód számát."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Il titolo In riproduzione del sistema ora include il nome della serie e il numero di stagione ed episodio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "システムの再生画面のタイトルに、シリーズ名とシーズン・エピソード番号を表示するようになりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "시스템 재생 화면 제목에 시리즈 이름과 시즌, 에피소드 번호가 함께 표시됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systemets Now Playing-tittel inneholder nå seriens navn samt sesong- og episodenummer."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "De Now Playing-titel van het systeem bevat nu de serienaam en het seizoens- en afleveringsnummer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systemowy tytuł odtwarzania zawiera teraz nazwę serialu oraz numer sezonu i odcinka."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O título de reprodução do sistema agora inclui o nome da série e o número da temporada e do episódio."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O título de reprodução do sistema inclui agora o nome da série e o número da temporada e do episódio."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titlul de redare al sistemului include acum numele serialului, precum și numărul sezonului și al episodului."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Системный заголовок экрана воспроизведения теперь включает название сериала, а также номер сезона и серии."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systémový názov v ovládaní prehrávania teraz zahŕňa názov seriálu a číslo série aj epizódy."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Systemets Now Playing-titel innehåller nu seriens namn samt säsongs- och avsnittsnummer."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sistem Çalınıyor başlığı artık dizi adını, sezon ve bölüm numarasını da içeriyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Системний заголовок екрана відтворення тепер містить назву серіалу, а також номер сезону та епізоду."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "系统播放界面的标题现在会包含剧集名称以及季数和集数。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "系統播放畫面的標題現在會包含影集名稱以及季數與集數。"
          }
        }
      }
    },
