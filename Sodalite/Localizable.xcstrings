    "changelog.0_9_0.artwork.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vyberte si, jak vypadá grafika v sekci Pokračovat ve sledování a na obrazovce přehrávání, od celých pozadí po snímky z epizod."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vælg, hvordan billederne til Fortsæt med at se og Now Playing ser ud, fra fulde baggrunde til stillbilleder fra episoder."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Wähle, wie das Artwork für „Weiterschauen“ und Now Playing aussieht, von ganzen Hintergrundbildern bis zu Episodenbildern."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Επιλέξτε πώς εμφανίζονται τα εικαστικά στη «Συνέχιση παρακολούθησης» και στην οθόνη αναπαραγωγής, από πλήρη φόντα έως στιγμιότυπα επεισοδίων."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Choose how the Continue Watching and Now Playing artwork looks, from full backdrops to episode stills."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Elige cómo se ven las imágenes de Seguir viendo y de la pantalla de reproducción en curso, desde fondos completos hasta fotogramas de episodios."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Valitse, miltä Jatka katsomista- ja toistonäkymän kuvitus näyttää, taustakuvista jaksojen pysäytyskuviin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Choisissez l'apparence des visuels de Reprendre la lecture et de l'écran de lecture en cours, des arrière-plans complets aux images d'épisodes."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odaberite kako izgleda grafika u odjeljku Nastavi gledati i na zaslonu za reprodukciju, od cijelih pozadina do kadrova iz epizoda."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Válaszd ki, hogyan néz ki a Megtekintés folytatása és a lejátszási képernyő grafikája, a teljes háttérképektől az epizódkockákig."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Scegli l'aspetto delle immagini di Continua a guardare e della schermata In riproduzione, dagli sfondi completi ai fotogrammi degli episodi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "「続けて見る」や再生画面のアートワークを、全画面の背景からエピソードの場面写真まで自由に選べます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "이어 보기와 재생 화면의 아트워크를 전체 배경부터 에피소드 장면 이미지까지 원하는 대로 선택하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Velg hvordan bildene for Fortsett å se og Now Playing ser ut, fra fulle bakgrunner til stillbilder fra episoder."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kies hoe de illustraties bij Verder kijken en Now Playing eruitzien, van volledige achtergronden tot stills van afleveringen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Wybierz, jak wygląda grafika w sekcji Kontynuuj oglądanie i na ekranie odtwarzania, od pełnych teł po kadry z odcinków."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Escolha como ficam as imagens de Continuar assistindo e da tela de reprodução, de fundos completos a fotos dos episódios."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Escolha o aspeto das imagens de Continuar a ver e do ecrã de reprodução, desde fundos completos a fotogramas dos episódios."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alege cum arată imaginile de la Continuă vizionarea și de pe ecranul de redare, de la fundaluri complete la cadre din episoade."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Выбирайте, как выглядят обложки в разделе «Продолжить просмотр» и на экране воспроизведения: от полных фонов до кадров из серий."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vyberte si, ako vyzerá grafika v sekcii Pokračovať v sledovaní a na obrazovke prehrávania, od celých pozadí po snímky z epizód."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Välj hur bilderna för Fortsätt titta och Now Playing ser ut, från fullständiga bakgrunder till stillbilder från avsnitt."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "İzlemeye Devam Et ve Çalınıyor görsellerinin nasıl görüneceğini, tam arka planlardan bölüm karelerine kadar seçin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Обирайте, як виглядають обкладинки в розділі «Продовжити перегляд» і на екрані відтворення: від повних тл до кадрів з епізодів."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "自由选择“继续观看”和播放界面的封面图样式，从全屏背景图到单集剧照皆可。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "自由選擇「繼續觀看」與播放畫面的封面圖樣式，從全螢幕背景圖到單集劇照皆可。"
          }
        }
      }
    },
