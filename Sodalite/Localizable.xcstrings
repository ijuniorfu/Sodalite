    "search.hint.connectSeerr" : {
      "comment": "Hint shown under search.hint.startTyping when Seerr isn't connected yet",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Připojte Seerr v Nastavení, abyste mohli prohledávat i katalog nových filmů a seriálů."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Forbind Seerr i Indstillinger for også at søge i kataloget efter nye film og serier."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Verbinde Seerr in den Einstellungen, um auch im Katalog nach neuen Filmen und Serien zu suchen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Σύνδεσε το Seerr στις Ρυθμίσεις για να αναζητάς επίσης νέες ταινίες και σειρές στον κατάλογο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Connect Seerr in Settings to also search the catalog for new movies and shows."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Conecta Seerr en Ajustes para buscar también en el catálogo nuevas películas y series."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Yhdistä Seerr asetuksissa, jotta voit hakea myös luettelosta uusia elokuvia ja sarjoja."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Connectez Seerr dans les Réglages pour rechercher aussi dans le catalogue de nouveaux films et séries."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Poveži Seerr u Postavkama kako bi pretraživao i katalog za nove filmove i serije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Csatlakoztasd a Seerr-t a Beállításokban, hogy a katalógusban is kereshess új filmeket és sorozatokat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
