    "catalog.notify.denied.hint" : {
      "comment" : "Shown when the user denied notification permission (iOS)",
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povolte oznámení pro Sodalite v Nastavení iOS, abyste to mohli používat."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivér notifikationer for Sodalite i iOS-indstillingerne for at bruge dette."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiviere Benachrichtigungen für Sodalite in den iOS-Einstellungen, um das zu nutzen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ενεργοποιήστε τις ειδοποιήσεις για το Sodalite στις Ρυθμίσεις iOS για να το χρησιμοποιήσετε."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
