    "changelog.0_7_0.hdrRouting.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Čistší zpracování profilů 5, 8.1 a 8.4 na panelech bez DV, přesnější metadata HDR10+ a stabilnější přepínání režimu zobrazení mezi epizodami."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Renere håndtering af Profil 5, 8.1 og 8.4 på paneler uden DV, mere præcise HDR10+-metadata og mere stabile skift af visningstilstand mellem episoder."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sauberere Behandlung von Profil 5, 8.1 und 8.4 auf Nicht-DV-Panels, genauere HDR10+-Metadaten und verlässlichere Display-Mode-Wechsel zwischen Episoden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Πιο καθαρός χειρισμός των Profile 5, 8.1 και 8.4 σε οθόνες χωρίς DV, ακριβέστερα μεταδεδομένα HDR10+ και πιο σταθερές αλλαγές λειτουργίας οθόνης μεταξύ επεισοδίων."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Cleaner Profile 5, 8.1, and 8.4 handling on non-DV panels, more accurate HDR10+ metadata, and steadier display-mode switches between episodes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tratamiento más limpio de los Perfiles 5, 8.1 y 8.4 en paneles sin DV, metadatos HDR10+ más precisos y cambios de modo de visualización más estables entre episodios."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Profiilien 5, 8.1 ja 8.4 selkeämpi käsittely paneeleilla ilman DV-tukea, tarkemmat HDR10+-metatiedot ja vakaammat näyttötilan vaihdot jaksojen välillä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gestion plus propre des Profils 5, 8.1 et 8.4 sur les écrans non DV, métadonnées HDR10+ plus précises et changements de mode d'affichage plus stables entre les épisodes."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Čišća obrada Profila 5, 8.1 i 8.4 na panelima bez DV-a, točniji HDR10+ metapodaci i stabilnije promjene načina prikaza između epizoda."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tisztább Profile 5-, 8.1- és 8.4-kezelés DV-mentes panelekon, pontosabb HDR10+ metaadatok és stabilabb képernyőmód-váltások az epizódok között."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gestione più pulita dei Profili 5, 8.1 e 8.4 su pannelli non DV, metadati HDR10+ più accurati e passaggi di modalità di visualizzazione più stabili tra episodi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "非 DV パネルでのプロファイル 5、8.1、8.4 の処理がよりクリーンになり、HDR10+ メタデータがより正確に、エピソード間のディスプレイモード切替もより安定しました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "비DV 패널에서 프로필 5, 8.1, 8.4 처리가 더 깔끔해지고, HDR10+ 메타데이터가 더 정확해졌으며, 에피소드 간 디스플레이 모드 전환이 더 안정적입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Renere håndtering av Profil 5, 8.1 og 8.4 på paneler uten DV, mer nøyaktige HDR10+-metadata og stødigere bytter av visningsmodus mellom episoder."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Schonere afhandeling van Profielen 5, 8.1 en 8.4 op niet-DV-panelen, nauwkeurigere HDR10+-metadata en stabielere weergavemoduswisselingen tussen afleveringen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Czystsza obsługa profili 5, 8.1 i 8.4 na panelach bez DV, dokładniejsze metadane HDR10+ i bardziej stabilne przełączanie trybu wyświetlania między odcinkami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tratamento mais limpo dos Perfis 5, 8.1 e 8.4 em painéis sem DV, metadados HDR10+ mais precisos e trocas de modo de exibição mais estáveis entre episódios."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tratamento mais limpo dos Perfis 5, 8.1 e 8.4 em painéis sem DV, metadados HDR10+ mais precisos e trocas de modo de visualização mais estáveis entre episódios."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tratare mai curată a Profilurilor 5, 8.1 și 8.4 pe ecrane fără DV, metadate HDR10+ mai precise și comutări mai stabile ale modului de afișare între episoade."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Чище обработка профилей 5, 8.1 и 8.4 на панелях без DV, точнее метаданные HDR10+ и стабильнее переключения режима отображения между эпизодами."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Čistejšie spracovanie profilov 5, 8.1 a 8.4 na paneloch bez DV, presnejšie metadáta HDR10+ a stabilnejšie prepínanie režimu zobrazenia medzi epizódami."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Renare hantering av Profil 5, 8.1 och 8.4 på paneler utan DV, mer exakt HDR10+-metadata och stabilare byten av visningsläge mellan avsnitt."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV olmayan panellerde Profil 5, 8.1 ve 8.4'ün daha temiz işlenmesi, daha doğru HDR10+ üst verileri ve bölümler arasında daha kararlı görüntü modu geçişleri."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Чистіша обробка профілів 5, 8.1 і 8.4 на панелях без DV, точніші метадані HDR10+ і стабільніші перемикання режиму відображення між епізодами."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在非 DV 面板上对 Profile 5、8.1 与 8.4 的处理更干净,HDR10+ 元数据更精确,剧集之间的显示模式切换更稳定。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在非 DV 面板上對 Profile 5、8.1 與 8.4 的處理更乾淨,HDR10+ 中繼資料更精確,劇集之間的顯示模式切換更穩定。"
          }
        }
      }
    },
