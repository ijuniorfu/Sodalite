    "catalog.allRequests.confirm.decline.message" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ bude zamítnuto. Lze stále smazat později."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ afvises. Det kan stadig slettes senere."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ wird abgelehnt. Kann später noch gelöscht werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Το %@ θα απορριφθεί. Μπορεί να διαγραφεί αργότερα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ will be declined. You can still delete it later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ será rechazado. Puede eliminarse más adelante."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ hylätään. Sen voi silti poistaa myöhemmin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ sera refusé. Il pourra encore être supprimé plus tard."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ će biti odbijeno. Može se obrisati i kasnije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ el lesz utasítva. Később még törölhető."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ verrà rifiutato. Può essere eliminato in seguito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ は却下されます。後で削除することもできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@이(가) 거절됩니다. 나중에 삭제할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ avvises. Det kan fortsatt slettes senere."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ wordt afgewezen. Het kan later nog worden verwijderd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ zostanie odrzucone. Można je usunąć później."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ será recusado. Ainda pode ser excluído depois."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ será recusado. Ainda pode ser eliminado mais tarde."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ va fi refuzat. Poate fi șters și mai târziu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ будет отклонён. Его можно удалить позже."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ bude zamietnuté. Neskôr ho možno stále zmazať."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ avvisas. Det kan fortfarande raderas senare."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
