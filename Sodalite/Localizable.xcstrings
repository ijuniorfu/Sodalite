    "changelog.0_13_0.smoothSeeking.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skok zpět ve videu je nyní okamžitý a zvuk zůstává po přetočení synchronní."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Spring tilbage i en video sker nu øjeblikkeligt, og lyden forbliver synkron efter spoling."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zurückspringen im Video geht jetzt sofort, und der Ton bleibt nach dem Spulen synchron."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Η μετάβαση προς τα πίσω σε ένα βίντεο είναι πλέον άμεση και ο ήχος παραμένει συγχρονισμένος μετά την αναζήτηση."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jumping back in a video is now instant, and audio stays in sync after seeking."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Retroceder en un vídeo ahora es instantáneo y el audio se mantiene sincronizado después de desplazarse."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Taaksepäin hyppääminen videossa on nyt välitöntä, ja ääni pysyy synkronoituna kelauksen jälkeen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Revenir en arrière dans une vidéo est désormais instantané et le son reste synchronisé après la navigation."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skok unatrag u videozapisu sada je trenutačan, a zvuk ostaje sinkroniziran nakon premotavanja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A videóban való visszaugrás mostantól azonnali, és a hang tekerés után is szinkronban marad."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tornare indietro in un video ora è istantaneo e l'audio resta sincronizzato dopo lo scorrimento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ビデオ内の巻き戻しが瞬時になり、シーク後も音声が同期したままになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "이제 비디오에서 뒤로 이동이 즉시 이루어지며 탐색 후에도 오디오가 동기화된 상태로 유지됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Å hoppe tilbake i en video skjer nå umiddelbart, og lyden forblir synkronisert etter spoling."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Terugspringen in een video gaat nu direct en het geluid blijft synchroon na het spoelen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Przeskakiwanie wstecz w wideo jest teraz natychmiastowe, a dźwięk pozostaje zsynchronizowany po przewijaniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Voltar em um vídeo agora é instantâneo e o áudio permanece sincronizado após a navegação."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Recuar num vídeo é agora instantâneo e o áudio mantém-se sincronizado depois de navegar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Saltul înapoi într-un videoclip este acum instantaneu, iar sunetul rămâne sincronizat după derulare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Переход назад в видео теперь мгновенный, а звук остаётся синхронизированным после перемотки."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skok späť vo videu je teraz okamžitý a zvuk zostáva po pretočení synchronizovaný."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Att hoppa bakåt i en video sker nu direkt och ljudet förblir synkat efter spolning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Videoda geri atlama artık anında gerçekleşiyor ve sarmadan sonra ses senkronize kalıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Перехід назад у відео тепер миттєвий, а звук залишається синхронізованим після перемотування."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "视频回跳现在即刻完成，快进快退后音画保持同步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "影片回跳現在即刻完成，快轉倒轉後音畫保持同步。"
          }
        }
      }
    },
