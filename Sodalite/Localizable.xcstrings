    "delete.confirm.movie.body" : {
      "comment": "Body text of the movie delete confirmation sheet",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Soubor bude trvale odstraněn ze serveru Jellyfin."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filen fjernes permanent fra din Jellyfin-server."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Die Datei wird dauerhaft vom Jellyfin-Server entfernt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Το αρχείο θα διαγραφεί οριστικά από τον διακομιστή Jellyfin."
          }
        },
        "en" : {
