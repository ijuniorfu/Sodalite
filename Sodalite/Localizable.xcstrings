    "changelog.0_10_0.nowPlaying.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Epizody zobrazují v Ovládacím centru seriál a epizodu na dvou samostatných řádcích, jako jiné video aplikace."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Episoder viser serie og episode på to separate linjer i Kontrolcenter, ligesom andre videoapps."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Episoden zeigen Serie und Folge im Control Center auf zwei Zeilen, wie in anderen Video-Apps."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα επεισόδια εμφανίζουν τη σειρά και το επεισόδιο σε δύο ξεχωριστές γραμμές στο Κέντρο ελέγχου, όπως άλλες εφαρμογές βίντεο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Episodes show series and episode on two separate lines in Control Center, like other video apps."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los episodios muestran la serie y el episodio en dos líneas separadas en el Centro de control, como otras apps de vídeo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jaksot näyttävät sarjan ja jakson kahdella erillisellä rivillä Ohjauskeskuksessa, kuten muutkin videosovellukset."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les épisodes affichent la série et l'épisode sur deux lignes distinctes dans le Centre de contrôle, comme les autres apps vidéo."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Epizode prikazuju seriju i epizodu u dva odvojena retka u Kontrolnom centru, kao i druge videoaplikacije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az epizódok a sorozatot és az epizódot két külön sorban jelenítik meg a Vezérlőközpontban, mint más videóappok."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gli episodi mostrano serie ed episodio su due righe separate nel Centro di Controllo, come le altre app video."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "エピソードはコントロールセンターでシリーズ名とエピソード名を2行に分けて表示します。ほかのビデオアプリと同じ表示です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "에피소드는 제어 센터에서 시리즈와 에피소드를 두 줄로 나누어 표시합니다. 다른 비디오 앱과 같은 방식입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Episoder viser serie og episode på to separate linjer i Kontrollsenter, som andre videoapper."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Afleveringen tonen serie en aflevering op twee aparte regels in het Bedieningspaneel, net als andere video-apps."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odcinki pokazują serial i odcinek w dwóch osobnych wierszach w Centrum sterowania, jak w innych aplikacjach wideo."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os episódios mostram a série e o episódio em duas linhas separadas na Central de Controle, como outros apps de vídeo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os episódios mostram a série e o episódio em duas linhas separadas na Central de controlo, como outras apps de vídeo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Episoadele afișează serialul și episodul pe două rânduri separate în Centrul de control, ca alte aplicații video."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Для эпизодов в Пункте управления сериал и серия отображаются двумя отдельными строками, как в других видеоприложениях."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Epizódy zobrazujú v Ovládacom centre seriál a epizódu v dvoch samostatných riadkoch, ako iné video aplikácie."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Avsnitt visar serie och avsnitt på två separata rader i Kontrollcenter, precis som andra videoappar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bölümler, Denetim Merkezi'nde dizi ve bölümü diğer video uygulamalarındaki gibi iki ayrı satırda gösterir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Для епізодів у Центрі керування серіал і епізод відображаються двома окремими рядками, як в інших відеозастосунках."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "剧集会在控制中心分两行显示剧名和单集信息，与其他视频 App 一致。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "影集會在控制中心分兩行顯示影集名稱與單集資訊，與其他影片 App 一致。"
          }
        }
      }
    },
