    "settings.appearance.cwImage.subtitle" : {
      "comment": "Subtitle for the Continue Watching image picker",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Který obrázek použijí karty v Pokračovat ve sledování a Další na řadě."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
