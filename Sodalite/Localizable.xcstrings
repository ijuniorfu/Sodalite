    "changelog.0_5_0.subtitleRework.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Každý formát titulků — včetně bitmapových formátů jako PGS, DVB a HDMV — se nyní dekóduje uvnitř aplikace místo extrakce na straně serveru. Přizpůsobte barvu textu, styl pozadí, velikost písma a nastavte zpoždění pro jednotlivé stopy, když je zvuk mimo synchronizaci."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alle undertekstformater — også bitmap-formater som PGS, DVB og HDMV — afkodes nu inde i appen i stedet for via serverside-udtræk. Tilpas tekstfarve, baggrundsstil og skriftstørrelse, og indstil en forsinkelse pr. spor, når lyden er ude af sync."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jedes Untertitel-Format — auch Bitmap-Formate wie PGS, DVB und HDMV — wird jetzt direkt in der App dekodiert, ohne Umweg über die Server-Extraktion. Textfarbe, Hintergrundstil und Schriftgröße sind anpassbar; bei Audio-Versatz lässt sich pro Spur ein Delay einstellen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Κάθε μορφή υποτίτλων — συμπεριλαμβανομένων μορφών bitmap όπως PGS, DVB και HDMV — αποκωδικοποιείται πλέον μέσα στην εφαρμογή αντί να περνάει από εξαγωγή στον διακομιστή. Προσαρμόστε χρώμα κειμένου, στυλ φόντου, μέγεθος γραμματοσειράς και ρυθμίστε καθυστέρηση ανά κανάλι όταν ο ήχος δεν είναι συγχρονισμένος."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Every subtitle format (including bitmap formats like PGS, DVB and HDMV) now decodes inside the app instead of going through server-side extraction. Customise text colour, background style, font size, and dial in a per-track delay when audio is out of sync."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Todos los formatos de subtítulos — incluidos los formatos de mapa de bits como PGS, DVB y HDMV — se decodifican ahora dentro de la app en lugar de pasar por la extracción del servidor. Personaliza el color del texto, el estilo de fondo, el tamaño de letra y configura un retardo por pista cuando el audio está desincronizado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kaikki tekstitysmuodot — mukaan lukien bittikarttamuodot kuten PGS, DVB ja HDMV — puretaan nyt sovelluksen sisällä palvelinpohjaisen poiminnan sijaan. Säädä tekstin väriä, taustatyyliä, fonttikokoa ja aseta raitakohtainen viive, kun ääni ei ole synkronissa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tous les formats de sous-titres — y compris les formats bitmap comme PGS, DVB et HDMV — sont désormais décodés dans l'app au lieu de passer par l'extraction côté serveur. Personnalise la couleur du texte, le style de fond, la taille de police et règle un décalage par piste quand l'audio est désynchronisé."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Svaki format titlova — uključujući bitmap formate poput PGS, DVB i HDMV — sada se dekodira unutar aplikacije umjesto preko serverske ekstrakcije. Prilagodi boju teksta, stil pozadine, veličinu fonta i postavi kašnjenje po traci kad je zvuk izvan sinkronizacije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Minden feliratformátum — beleértve a bitkép-formátumokat, például PGS-t, DVB-t és HDMV-t — mostantól az alkalmazáson belül kerül dekódolásra a szerveroldali kinyerés helyett. Testre szabhatod a szövegszínt, a háttérstílust, a betűméretet, és sávonként késleltetést állíthatsz be, ha a hang nincs szinkronban."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ogni formato di sottotitoli — inclusi i formati bitmap come PGS, DVB e HDMV — viene ora decodificato all'interno dell'app invece di passare dall'estrazione lato server. Personalizza il colore del testo, lo stile dello sfondo, la dimensione del carattere e imposta un ritardo per traccia quando l'audio è fuori sync."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "PGS・DVB・HDMVなどのビットマップ形式を含むすべての字幕形式を、サーバー側の抽出ではなくアプリ内でデコードします。文字色・背景スタイル・フォントサイズをカスタマイズでき、音声のずれに合わせてトラック単位で遅延を設定できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "PGS, DVB, HDMV 같은 비트맵 형식을 포함한 모든 자막 형식을 서버 측 추출 대신 앱 내부에서 디코딩합니다. 텍스트 색상, 배경 스타일, 글꼴 크기를 사용자화하고, 오디오 싱크가 어긋날 때 트랙별 딜레이를 조정하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alle undertekstformater — inkludert bitmap-formater som PGS, DVB og HDMV — dekodes nå inne i appen i stedet for via uthenting på serversiden. Tilpass tekstfarge, bakgrunnsstil og skriftstørrelse, og still inn en forsinkelse per spor når lyden er ute av synk."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Elk ondertitelingsformaat — inclusief bitmapformaten zoals PGS, DVB en HDMV — wordt nu in de app gedecodeerd in plaats van via serverextractie. Pas tekstkleur, achtergrondstijl en lettergrootte aan en stel per track een vertraging in wanneer de audio niet synchroon loopt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Każdy format napisów — w tym formaty bitmapowe takie jak PGS, DVB i HDMV — jest teraz dekodowany w aplikacji zamiast przez ekstrakcję po stronie serwera. Dostosuj kolor tekstu, styl tła, rozmiar czcionki i ustaw opóźnienie dla każdej ścieżki, gdy audio nie jest zsynchronizowane."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Todos os formatos de legenda — incluindo formatos bitmap como PGS, DVB e HDMV — agora são decodificados dentro do app em vez de passar pela extração no servidor. Personalize a cor do texto, o estilo de fundo, o tamanho da fonte e ajuste um atraso por faixa quando o áudio estiver dessincronizado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Todos os formatos de legenda — incluindo formatos bitmap como PGS, DVB e HDMV — são agora descodificados dentro da app em vez de passar pela extracção no servidor. Personaliza a cor do texto, o estilo de fundo, o tamanho da letra e ajusta um atraso por faixa quando o áudio está dessincronizado."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fiecare format de subtitrare — inclusiv formate bitmap precum PGS, DVB și HDMV — se decodează acum în interiorul aplicației în loc să treacă prin extragere pe server. Personalizează culoarea textului, stilul de fundal, dimensiunea fontului și setează o întârziere pentru fiecare pistă când sunetul este desincronizat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Каждый формат субтитров — включая растровые форматы PGS, DVB и HDMV — теперь декодируется внутри приложения, а не через серверное извлечение. Настройте цвет текста, стиль фона, размер шрифта и задержку по каждой дорожке, когда звук рассинхронизирован."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Každý formát titulkov — vrátane bitmapových formátov ako PGS, DVB a HDMV — sa teraz dekóduje vnútri aplikácie namiesto extrakcie na strane servera. Prispôsobte farbu textu, štýl pozadia, veľkosť písma a nastavte oneskorenie pre jednotlivé stopy, keď zvuk nie je synchronizovaný."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alla undertextformat — inklusive bitmappformat som PGS, DVB och HDMV — avkodas nu inne i appen istället för via serverbaserad extrahering. Anpassa textfärg, bakgrundsstil, teckenstorlek och ställ in en fördröjning per spår när ljudet är ur sync."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Her altyazı biçimi — PGS, DVB ve HDMV gibi bitmap biçimleri dahil — artık sunucu tarafı çıkarma yerine uygulama içinde çözülür. Metin rengini, arka plan stilini ve yazı boyutunu özelleştirin; ses uyumsuzsa parça başına gecikme ayarlayın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Кожен формат субтитрів — включно з растровими форматами PGS, DVB і HDMV — тепер декодується всередині застосунку, а не через серверне витягування. Налаштуйте колір тексту, стиль фону, розмір шрифту й затримку для кожної доріжки, коли аудіо розсинхронізоване."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "包括 PGS、DVB 和 HDMV 等位图格式在内的所有字幕格式现在在 App 内部解码,而不再依赖服务器端提取。可自定义文字颜色、背景样式、字体大小,并在音频不同步时为每条轨道设置延迟。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "包括 PGS、DVB 和 HDMV 等點陣圖格式在內的所有字幕格式現在於 App 內部解碼,不再依賴伺服器端擷取。可自訂文字顏色、背景樣式、字型大小,並在音訊不同步時為每條軌道設定延遲。"
          }
        }
      }
    },
