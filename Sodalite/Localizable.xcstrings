    "changelog.0_5_0.uiAutoHide.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Po klepnutí doleva nebo doprava bez dalšího stisku rozhraní přehrávače po 5 s zmizí místo aby zůstávalo na obraze donekonečna."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Efter at have trykket til venstre eller højre uden at trykke på noget andet forsvinder afspillerens grænseflade efter 5 sek. i stedet for at blive på billedet i det uendelige."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nach einem Links/Rechts-Tipp ohne weitere Eingaben blendet die Player-UI nach 5 Sekunden aus, statt unendlich auf dem Bild zu bleiben."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Μετά από πάτημα αριστερά/δεξιά χωρίς άλλη ενέργεια, το UI του προγράμματος αναπαραγωγής σβήνει μετά από 5 δευτ. αντί να μένει συνεχώς πάνω στην εικόνα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "After tapping left / right and not pressing anything else, the player UI fades after 5 s instead of sitting on the picture indefinitely."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tras pulsar izquierda o derecha y no presionar nada más, la interfaz del reproductor se desvanece tras 5 s en lugar de quedarse sobre la imagen indefinidamente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vasemmalle/oikealle napautuksen jälkeen ilman muuta painallusta soittimen käyttöliittymä haalistuu 5 sekunnin kuluttua sen sijaan että jäisi kuvan päälle loputtomiin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Après un appui à gauche ou à droite sans autre action, l'interface du lecteur disparaît au bout de 5 s au lieu de rester sur l'image indéfiniment."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nakon dodira lijevo/desno bez daljnjeg pritiska, sučelje reproduktora se zatamni nakon 5 s umjesto da neograničeno ostaje na slici."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bal/jobb érintés után további megnyomás nélkül a lejátszó kezelőfelülete 5 mp után eltűnik, ahelyett hogy folyamatosan a képen maradna."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dopo aver toccato sinistra o destra senza premere altro, l'interfaccia del player scompare dopo 5 s invece di restare sull'immagine all'infinito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "左/右をタップしてその後何も押さないと、プレーヤーUIは画像の上に永遠に残らず、5秒後にフェードアウトします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "왼쪽/오른쪽을 탭한 후 다른 입력이 없으면 플레이어 UI가 화면에 무한정 머물지 않고 5초 후 사라집니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Etter å ha trykket venstre eller høyre uten å trykke noe annet, tones spillergrensesnittet ut etter 5 sek. i stedet for å bli liggende på bildet i det uendelige."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Na links of rechts tikken zonder verder iets te drukken, vervaagt de spelersinterface na 5 sec in plaats van oneindig op het beeld te blijven staan."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Po naciśnięciu w lewo lub w prawo i braku dalszych akcji interfejs odtwarzacza znika po 5 s zamiast pozostawać na obrazie w nieskończoność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Após tocar para a esquerda ou direita sem pressionar mais nada, a interface do player desaparece em 5 s em vez de ficar sobre a imagem indefinidamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Depois de tocar para a esquerda ou direita sem pressionar mais nada, a interface do reprodutor desaparece após 5 s em vez de ficar sobre a imagem indefinidamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "După ce apeși stânga sau dreapta fără să mai apeși altceva, interfața playerului dispare după 5 s în loc să rămână pe imagine la nesfârșit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "После нажатия влево/вправо без дальнейших действий интерфейс плеера исчезает через 5 с вместо того, чтобы оставаться на картинке бесконечно."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Po klepnutí doľava alebo doprava bez ďalšieho stlačenia rozhranie prehrávača po 5 s zmizne namiesto aby ostalo na obraze donekonečna."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Efter ett tryck åt vänster eller höger utan att trycka på något annat tonas spelarens gränssnitt bort efter 5 s istället för att stanna kvar på bilden i evighet."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sol/sağ dokunup başka bir şeye basmadığınızda, oynatıcı arayüzü görüntü üzerinde sonsuza dek kalmak yerine 5 sn sonra kaybolur."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Після натискання вліво/вправо без подальших дій інтерфейс плеєра зникає через 5 с замість того, щоб лишатися на зображенні нескінченно."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "点按左/右后未进行其他操作时,播放器界面会在 5 秒后淡出,而不是无限制停留在画面上。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "點按左/右後未進行其他操作時,播放器介面會在 5 秒後淡出,而不是無限制停留在畫面上。"
          }
        }
      }
    },
