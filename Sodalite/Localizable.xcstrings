    "changelog.0_4_0.siri.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Řekněte „Otevři Sodalite“ Siri Remote, iPhonu nebo HomePodu. Dostupné ve 26 jazycích."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sig „Åbn Sodalite“ til Siri-fjernbetjeningen, iPhone eller HomePod. Tilgængelig på 26 sprog."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sag „Sodalite öffnen“ zur Siri Remote, zum iPhone oder zum HomePod. Verfügbar in 26 Sprachen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Πείτε „Άνοιξε το Sodalite“ στο Siri Remote, στο iPhone ή στο HomePod. Διαθέσιμο σε 26 γλώσσες."
