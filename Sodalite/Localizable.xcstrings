    "changelog.0_10_0.watchedFilter.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrujte každou mřížku knihovny podle možností Vše, Nezhlédnuté nebo Zhlédnuté, ideální pro procházení restů na filmový večer."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrer alle bibliotekets gitre efter Alle, Usete eller Sete, perfekt til at gennemse puljen til filmaftenen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtere jedes Bibliotheks-Grid nach Alle, Ungesehen oder Gesehen, perfekt fürs Stöbern am Filmabend."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Φιλτράρετε κάθε πλέγμα βιβλιοθήκης κατά Όλα, Μη προβεβλημένα ή Προβεβλημένα, ιδανικό για να βρείτε τι θα δείτε στη βραδιά ταινίας."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filter every library grid by All, Unwatched or Watched, perfect for browsing the backlog on movie night."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtra cada cuadrícula de la biblioteca por Todos, No vistos o Vistos, perfecto para repasar los pendientes en la noche de cine."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Suodata jokainen kirjastonäkymä valinnoilla Kaikki, Katsomattomat tai Katsotut, täydellinen katselujonon selaamiseen leffailtana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrez chaque grille de bibliothèque par Tout, Non vus ou Vus, parfait pour parcourir votre liste en retard lors d'une soirée cinéma."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrirajte svaku mrežu medijateke prema Sve, Negledano ili Gledano, savršeno za pregledavanje zaostataka u filmskoj večeri."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Szűrd az összes könyvtárrácsot az Összes, Nem látott vagy Látott lehetőség szerint, tökéletes a lemaradás böngészéséhez filmestén."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtra ogni griglia della libreria per Tutti, Non visti o Visti, perfetto per sfogliare gli arretrati nella serata film."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ライブラリの一覧を「すべて」「未視聴」「視聴済み」で絞り込めます。映画の夜に観たい作品を探すのにぴったりです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "모든 라이브러리 그리드를 전체, 시청 안 함, 시청함으로 필터링할 수 있습니다. 영화 보는 날 밀린 작품을 둘러보기에 안성맞춤입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrer hvert bibliotekrutenett etter Alle, Usett eller Sett, perfekt for å bla i etterslepet på filmkvelden."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filter elk bibliotheekraster op Alles, Niet bekeken of Bekeken, perfect om op filmavond door je achterstand te bladeren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtruj każdą siatkę biblioteki według opcji Wszystkie, Nieobejrzane lub Obejrzane, idealne do przeglądania zaległości w wieczór filmowy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtre cada grade da biblioteca por Todos, Não assistidos ou Assistidos, perfeito para explorar a lista de pendentes na noite de cinema."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtre cada grelha da biblioteca por Todos, Não vistos ou Vistos, perfeito para explorar os pendentes na noite de cinema."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrează fiecare grilă de bibliotecă după Toate, Nevizionate sau Vizionate, perfect pentru a răsfoi restanțele în seara de film."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Фильтруйте любую сетку библиотеки по параметрам Все, Непросмотренные или Просмотренные, идеально для выбора фильма на вечер."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrujte každú mriežku knižnice podľa možností Všetky, Nepozreté alebo Pozreté, ideálne na prehliadanie restov vo filmový večer."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrera varje biblioteksrutnät efter Alla, Osedda eller Sedda, perfekt för att bläddra i högen på filmkvällen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Her kitaplık ızgarasını Tümü, İzlenmemiş veya İzlenmiş olarak filtreleyin; film gecesinde birikenlere göz atmak için birebir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Фільтруйте будь-яку сітку бібліотеки за параметрами Усі, Непереглянуті чи Переглянуті, ідеально для вибору фільму на вечір."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "可按全部、未观看或已观看筛选每个媒体库网格，电影之夜挑片再合适不过。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "可依全部、未觀看或已觀看篩選每個媒體庫網格，電影之夜挑片再適合不過。"
          }
        }
      }
    },
