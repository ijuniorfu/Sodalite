          "stringUnit" : {
            "state": "translated",
            "value": "观看统计"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "觀看統計"
          }
        }
      }
    },
    "changelog.0_12_0.versionPicker.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Když má film nebo epizoda na serveru více verzí, před spuštěním si vybereš, která se přehraje."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Når en film eller et afsnit har flere versioner på serveren, vælger du, hvilken der skal afspilles, før den starter."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Wenn ein Film oder eine Episode mehrere Versionen auf deinem Server hat, wählst du vor dem Start, welche abgespielt wird."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Όταν μια ταινία ή ένα επεισόδιο έχει πάνω από μία εκδοχή στον διακομιστή σου, διαλέγεις ποια θα παιχτεί πριν ξεκινήσει."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "When a movie or episode has more than one version on your server, pick which one to play before it starts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Cuando una película o un episodio tiene más de una versión en tu servidor, eliges cuál reproducir antes de empezar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kun elokuvalla tai jaksolla on palvelimellasi useampi versio, valitset ennen toistoa, mikä niistä toistetaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Quand un film ou un épisode a plusieurs versions sur ton serveur, tu choisis laquelle lire avant le démarrage."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kad film ili epizoda ima više verzija na tvom poslužitelju, prije početka biraš koju ćeš pustiti."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ha egy filmnek vagy epizódnak több verziója is van a kiszolgálódon, indítás előtt kiválaszthatod, melyik induljon el."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Quando un film o un episodio ha più versioni sul tuo server, scegli quale riprodurre prima dell'avvio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "映画やエピソードにサーバー上で複数のバージョンがある場合、再生前にどれを再生するか選べます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "영화나 에피소드에 서버상 여러 버전이 있을 때, 재생 전에 어떤 버전을 재생할지 고를 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Når en film eller episode har flere versjoner på serveren, velger du hvilken som skal spilles av før den starter."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Als een film of aflevering meerdere versies op je server heeft, kies je vóór het afspelen welke je wilt zien."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gdy film lub odcinek ma na serwerze więcej niż jedną wersję, przed odtworzeniem wybierasz, którą uruchomić."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Quando um filme ou episódio tem mais de uma versão no seu servidor, você escolhe qual reproduzir antes de começar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Quando um filme ou episódio tem mais do que uma versão no teu servidor, escolhes qual reproduzir antes de começar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Când un film sau un episod are mai multe versiuni pe serverul tău, alegi care să fie redată înainte de pornire."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Если у фильма или эпизода на сервере несколько версий, перед началом вы выбираете, какую воспроизвести."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Keď má film alebo epizóda na serveri viac verzií, pred spustením si vyberieš, ktorá sa prehrá."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "När en film eller ett avsnitt har flera versioner på servern väljer du vilken som ska spelas upp innan den startar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bir film ya da bölümün sunucunuzda birden fazla sürümü olduğunda, başlamadan önce hangisinin oynatılacağını seçersiniz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Коли у фільму чи епізоду на сервері кілька версій, перед запуском ви обираєте, яку відтворити."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "当影片或剧集在服务器上有多个版本时，可在播放前选择要播放哪一个。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "當影片或劇集在伺服器上有多個版本時，可在播放前選擇要播放哪一個。"
          }
        }
      }
    },
