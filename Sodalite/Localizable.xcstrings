    "changelog.0_12_0.rewatchNextUp.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Seriály, které jsi už dokoukal, se mohou znovu objevit v řadě Další, když začneš opětovné sledování."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serier, du allerede har set færdig, kan dukke op i Næste igen, når du starter et gensyn."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bereits abgeschlossene Serien können wieder unter „Als Nächstes“ erscheinen, wenn du sie erneut ansiehst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Σειρές που έχεις ήδη ολοκληρώσει μπορούν να εμφανιστούν ξανά στο Επόμενο, όταν ξεκινάς επανάληψη."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Series you have already finished can appear in Next Up again when you start a rewatch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Las series que ya terminaste pueden volver a aparecer en Siguiente cuando empiezas a verlas de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jo loppuun katsomasi sarjat voivat ilmestyä taas Seuraavaksi-riville, kun aloitat uudelleenkatselun."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les séries que tu as déjà terminées peuvent réapparaître dans À suivre quand tu commences à les revoir."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serije koje si već završio mogu se ponovno pojaviti u retku Sljedeće kad počneš ponovno gledanje."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A már befejezett sorozatok újra megjelenhetnek a Következő sorban, amikor újranézésbe kezdesz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le serie che hai già finito possono ricomparire in Prossimo quando inizi a rivederle."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "見終わったシリーズも、再視聴を始めると「次の再生」に再び表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "이미 다 본 시리즈도 다시 보기를 시작하면 ‘다음’에 다시 나타날 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serier du allerede har sett ferdig, kan dukke opp i Neste igjen når du starter et gjensyn."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Series die je al hebt uitgekeken, kunnen weer in Volgende verschijnen wanneer je opnieuw begint te kijken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Seriale, które już skończyłeś, mogą znów pojawić się w rzędzie Następne, gdy zaczynasz oglądać je ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Séries que você já terminou podem aparecer de novo em Próximo quando você começa a rever."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As séries que já terminaste podem voltar a aparecer em A seguir quando começas a revê-las."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serialele pe care le-ai terminat deja pot reapărea în Următorul când începi o revizionare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Сериалы, которые вы уже досмотрели, могут снова появиться в разделе «Далее», когда вы начинаете повторный просмотр."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Seriály, ktoré si už dopozeral, sa môžu znova objaviť v riadku Ďalšie, keď začneš opätovné pozeranie."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serier du redan sett klart kan dyka upp i Nästa igen när du börjar titta om."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zaten bitirdiğiniz diziler, yeniden izlemeye başladığınızda Sırada'da tekrar görünebilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Серіали, які ви вже завершили, можуть знову з'явитися в рядку «Наступне», коли ви починаєте повторний перегляд."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "已经看完的剧集，在你开始重温时可重新出现在“接下来”中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "已經看完的影集，在你開始重溫時可重新出現在「接下來」中。"
          }
        }
      }
    },
