    "settings.playback.subtitle.weight.subtitle" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tučné se lépe čte na rušném obraze, normální odpovídá tloušťce rozhraní tvOS."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fed læses bedre på travle billeder, regulær passer til tvOS-UI-vægten."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fett liest sich besser bei bewegtem Bild, normal entspricht der tvOS-UI-Stärke."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Το έντονο διαβάζεται καλύτερα σε ανήσυχο βίντεο, το κανονικό ταιριάζει με το πάχος του tvOS UI."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bold reads better against busy video, regular matches tvOS UI weight."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La negrita se lee mejor sobre vídeo con detalle, la normal coincide con el peso de la interfaz de tvOS."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lihavoitu erottuu paremmin rauhattomalla kuvalla, normaali vastaa tvOS-käyttöliittymän paksuutta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le gras se lit mieux sur des vidéos chargées, le normal correspond au poids de l'interface tvOS."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Podebljano se bolje čita na pokretnoj slici, obično odgovara težini tvOS sučelja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Félkövér jobban olvasható mozgalmas képen, a szokásos a tvOS UI vastagságához igazodik."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Il grassetto si legge meglio su video movimentati, il normale corrisponde al peso dell'interfaccia tvOS."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ボールドは動きのある映像でも読みやすく、レギュラーは tvOS UI と同じ太さです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "굵게는 복잡한 영상 위에서 잘 읽히고, 보통은 tvOS UI 굵기와 같습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fet leses bedre mot travle bilder, regulær matcher tvOS-skriftvekten."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vet leest beter tegen druk beeld, normaal komt overeen met het tvOS-gewicht."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pogrubienie lepiej czytelne na ruchliwym tle, normalne odpowiada wadze interfejsu tvOS."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Negrito lê melhor sobre vídeo agitado, regular combina com o peso da interface tvOS."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Negrito lê-se melhor sobre vídeo agitado, normal corresponde à espessura da interface tvOS."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Aldin se citește mai bine pe imagini agitate, normal corespunde grosimii UI tvOS."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Жирный читается лучше на сложном фоне, обычный соответствует толщине интерфейса tvOS."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tučné sa lepšie číta na rušnom obraze, normálne zodpovedá hrúbke rozhrania tvOS."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fet läses bättre mot rörig video, normal matchar tvOS-gränssnittets vikt."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kalın hareketli görüntüde daha okunaklı, normal tvOS arayüz kalınlığıyla eşleşir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Жирний краще читається на жвавому відео, звичайний відповідає товщині інтерфейсу tvOS."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "粗体在繁忙画面上更易读，常规与 tvOS 界面字重一致。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "粗體在繁忙畫面上更易讀，正常與 tvOS 介面字重一致。"
          }
