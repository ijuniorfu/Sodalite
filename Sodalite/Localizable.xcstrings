    "settings.cloudSync.enabled.subtitle" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Udržujte servery, přihlášení a nastavení synchronizované na všech svých zařízeních"
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hold servere, logins og indstillinger synkroniseret på alle dine enheder"
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Halte Server, Anmeldungen und Einstellungen auf all deinen Geräten synchron"
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Διατηρήστε διακομιστές, συνδέσεις και ρυθμίσεις συγχρονισμένα σε όλες τις συσκευές σας"
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Keep servers, logins, and settings in sync on all your devices"
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mantén servidores, inicios de sesión y ajustes sincronizados en todos tus dispositivos"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pidä palvelimet, kirjautumiset ja asetukset synkronoituina kaikilla laitteillasi"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gardez serveurs, identifiants et réglages synchronisés sur tous vos appareils"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Održavajte poslužitelje, prijave i postavke sinkroniziranima na svim svojim uređajima"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tartsa szinkronban a kiszolgálókat, bejelentkezéseket és beállításokat minden eszközén"
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mantieni server, accessi e impostazioni sincronizzati su tutti i tuoi dispositivi"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "すべてのデバイスでサーバー、ログイン、設定を同期された状態に保ちます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "모든 기기에서 서버, 로그인, 설정을 동기화된 상태로 유지합니다"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hold servere, innlogginger og innstillinger synkronisert på alle enhetene dine"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Houd servers, aanmeldingen en instellingen gesynchroniseerd op al je apparaten"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Utrzymuj serwery, logowania i ustawienia zsynchronizowane na wszystkich urządzeniach"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mantenha servidores, logins e ajustes sincronizados em todos os seus dispositivos"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mantenha servidores, inícios de sessão e definições sincronizados em todos os seus dispositivos"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Păstrează serverele, autentificările și setările sincronizate pe toate dispozitivele tale"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Держите серверы, входы и настройки синхронизированными на всех ваших устройствах"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
