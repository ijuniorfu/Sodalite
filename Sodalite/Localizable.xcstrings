    "changelog.0_4_0.topshelf.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pokračovat ve sledování a Další epizody se nyní zobrazují nad dokem, když zaměříte ikonu Sodalite."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fortsæt med at se og Næste afsnit vises nu over docken, når du fokuserer på Sodalite-ikonet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Weiterschauen und Als Nächstes erscheinen jetzt über dem Dock, wenn du das Sodalite-Icon fokussierst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Η Συνέχεια παρακολούθησης και τα Επόμενα επεισόδια εμφανίζονται τώρα πάνω από το dock όταν εστιάζετε το εικονίδιο του Sodalite."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Continue Watching and Next Up now appear above the dock when you focus the Sodalite icon."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Seguir viendo y A continuación aparecen ahora sobre el dock al enfocar el icono de Sodalite."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jatka katsomista ja Seuraavaksi näkyvät nyt telakan yläpuolella, kun korostat Sodalite-kuvaketta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Continuer à regarder et À suivre apparaissent maintenant au-dessus du dock quand vous focalisez l'icône Sodalite."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nastavi gledati i Sljedeća epizoda sada se pojavljuju iznad doka kada fokusirate ikonu Sodalite."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A Megtekintés folytatása és a Következő most a dokk fölött jelenik meg, amikor a Sodalite ikont kiemeled."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Continua a guardare e Prossimo episodio ora compaiono sopra il dock quando metti a fuoco l'icona di Sodalite."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sodaliteのアイコンにフォーカスすると、視聴を再開と次のエピソードがDockの上に表示されるようになりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sodalite 아이콘에 포커스하면 계속 시청과 다음 회차가 Dock 위에 표시됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fortsett å se og Neste episode vises nå over dokken når du fokuserer Sodalite-ikonet."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Verder kijken en Volgende verschijnen nu boven het dock wanneer je het Sodalite-pictogram focust."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kontynuuj oglądanie i Następny odcinek pojawiają się teraz nad dokiem po wyróżnieniu ikony Sodalite."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Continuar assistindo e A seguir agora aparecem acima do dock ao focar o ícone do Sodalite."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Continuar a ver e A seguir aparecem agora acima da dock ao focar o ícone do Sodalite."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Continuă vizionarea și Următorul apar acum deasupra dock-ului când focalizezi pictograma Sodalite."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Продолжить просмотр и Далее теперь отображаются над dock-ом при наведении на иконку Sodalite."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pokračovať v sledovaní a Ďalšia epizóda sa teraz zobrazujú nad dockom, keď zaostríte ikonu Sodalite."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fortsätt titta och Nästa avsnitt visas nu ovanför dockan när du fokuserar Sodalite-ikonen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "İzlemeye Devam Et ve Sırada artık Sodalite simgesine odaklandığında dock'un üstünde görünür."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Продовжити перегляд і Далі тепер з'являються над доком, коли ви фокусуєте іконку Sodalite."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "聚焦 Sodalite 图标时，继续观看和接下来现在会出现在程序坞上方。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "聚焦 Sodalite 圖示時，繼續觀看和接下來現在會出現在程式塢上方。"
          }
        }
      }
    },
