        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Grazie per averci pensato"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ご検討ありがとうございます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "고려해 주셔서 감사합니다"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Takk for at du vurderer det"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bedankt dat je het overweegt"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dziękujemy za rozważenie"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Obrigado por considerar"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Obrigado por considerar"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mulțumim că iei în considerare"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Спасибо, что задумались о поддержке"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ďakujeme, že zvažujete"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tack för att du överväger"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Düşündüğün için teşekkürler"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Дякуємо, що розглядаєте"
