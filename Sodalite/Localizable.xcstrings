    "changelog.0_12_0.liveOverview.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nová karta přehledu otevírá živé TV s řádky kategorií podle toho, co právě běží, jako v nativním průvodci Jellyfinu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En ny oversigtsfane åbner live-tv med kategorirækker over det, der sendes lige nu, ligesom den native Jellyfin-guide."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ein neuer Übersichts-Tab öffnet Live-TV mit Kategoriereihen, die zeigen, was gerade läuft, wie im nativen Jellyfin-Guide."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Μια νέα καρτέλα επισκόπησης ανοίγει τη ζωντανή TV με σειρές κατηγοριών για ό,τι παίζει τώρα, όπως ο εγγενής οδηγός του Jellyfin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A new overview tab opens Live TV with category rows of what's on right now, mirroring the native Jellyfin guide."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una nueva pestaña de resumen abre la TV en directo con filas por categoría de lo que se emite ahora, como la guía nativa de Jellyfin."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uusi yleisnäkymä-välilehti avaa suoran TV:n kategoriariveillä siitä, mitä juuri nyt näytetään, kuten Jellyfinin natiivi opas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un nouvel onglet d'aperçu ouvre la TV en direct avec des rangées par catégorie de ce qui passe maintenant, comme le guide natif de Jellyfin."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nova kartica pregleda otvara TV uživo s redovima kategorija onoga što se trenutačno prikazuje, poput izvornog vodiča Jellyfina."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Egy új áttekintő lap nyitja meg az élő TV-t kategóriasorokkal arról, ami épp megy, akárcsak a natív Jellyfin-műsorújság."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una nuova scheda panoramica apre la TV in diretta con righe per categoria di ciò che è in onda adesso, come la guida nativa di Jellyfin."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "新しい概要タブがライブTVを開き、いま放送中の番組をカテゴリ別の行で、Jellyfinネイティブの番組表のように表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "새 개요 탭이 실시간 TV를 열어, 지금 방송 중인 프로그램을 카테고리 행으로 보여 줍니다. Jellyfin 기본 가이드와 같은 방식입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En ny oversiktsfane åpner direkte-TV med kategorirader over det som sendes nå, akkurat som den native Jellyfin-guiden."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Een nieuw overzichtstabblad opent live-tv met categorierijen van wat er nu speelt, net als de native Jellyfin-gids."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nowa karta przeglądu otwiera telewizję na żywo z rzędami kategorii tego, co leci teraz, tak jak natywny przewodnik Jellyfina."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uma nova aba de visão geral abre a TV ao vivo com linhas por categoria do que está passando agora, como o guia nativo do Jellyfin."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Um novo separador de vista geral abre a TV em direto com linhas por categoria do que está a passar agora, tal como o guia nativo do Jellyfin."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O nouă filă de prezentare deschide TV-ul în direct cu rânduri pe categorii pentru ce se difuzează acum, ca ghidul nativ Jellyfin."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Новая вкладка обзора открывает эфирное ТВ с рядами категорий того, что идёт сейчас, как в родном гиде Jellyfin."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nová karta prehľadu otvára živé TV s riadkami kategórií podľa toho, čo práve beží, ako v natívnom sprievodcovi Jellyfinu."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En ny översiktsflik öppnar live-TV med kategorirader över det som sänds just nu, precis som den inbyggda Jellyfin-guiden."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Yeni bir genel görünüm sekmesi, şu anda yayında olanları kategori satırlarıyla canlı TV'de açar; tıpkı Jellyfin'in yerel rehberi gibi."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Нова вкладка огляду відкриває ефірне ТБ з рядами категорій того, що йде зараз, як у рідному гіді Jellyfin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "新的总览标签页打开直播电视，按分类行显示正在播出的节目，与 Jellyfin 原生指南一致。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "新的總覽分頁開啟直播電視，按分類列顯示正在播出的節目，與 Jellyfin 原生指南一致。"
          }
        }
      }
    },
