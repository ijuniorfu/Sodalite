        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Could not verify. Check the password and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "No se pudo verificar. Comprueba la contraseña e inténtalo de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vahvistus epäonnistui. Tarkista salasana ja yritä uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Échec de la vérification. Vérifiez le mot de passe et réessayez."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Provjera nije uspjela. Provjerite lozinku i pokušajte ponovno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az ellenőrzés sikertelen. Ellenőrizd a jelszót, és próbáld újra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Verifica non riuscita. Controlla la password e riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "確認できませんでした。パスワードを確認してもう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "확인할 수 없습니다. 비밀번호를 확인하고 다시 시도하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kunne ikke bekrefte. Kontroller passordet og prøv igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Verifiëren mislukt. Controleer het wachtwoord en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nie udało się zweryfikować. Sprawdź hasło i spróbuj ponownie."
          }
        },
        "pt-BR" : {
