    "changelog.0_11_0.reliability.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kompletní dvojitá revize opravila desítky problémů v přehrávání, profilech, přepínání serverů, živé TV a hudbě."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En komplet dobbelt gennemgang rettede dusinvis af fejl i afspilning, profiler, serverskift, live-tv og musik."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Eine vollständige zweifache Überprüfung hat Dutzende Probleme bei Wiedergabe, Profilen, Serverwechsel, Live TV und Musik behoben."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ένας πλήρης διπλός έλεγχος διόρθωσε δεκάδες προβλήματα σε αναπαραγωγή, προφίλ, εναλλαγή διακομιστών, ζωντανή TV και μουσική."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A full two-pass review fixed dozens of issues across playback, profiles, server switching, Live TV, and music."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una revisión doble completa corrigió decenas de problemas en reproducción, perfiles, cambio de servidor, TV en directo y música."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Täysi kaksinkertainen tarkastus korjasi kymmeniä ongelmia toistossa, profiileissa, palvelimen vaihdossa, live-TV:ssä ja musiikissa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Une revue complète en deux passes a corrigé des dizaines de problèmes dans la lecture, les profils, le changement de serveur, la TV en direct et la musique."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Potpuni dvostruki pregled ispravio je desetke problema u reprodukciji, profilima, promjeni poslužitelja, TV-u uživo i glazbi."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Egy teljes, kétmenetes átvizsgálás tucatnyi hibát javított a lejátszásban, a profiloknál, a szerverváltásnál, az élő TV-ben és a zenében."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Una revisione completa in due passate ha corretto decine di problemi in riproduzione, profili, cambio server, Live TV e musica."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "アプリ全体を2回にわたり総点検し、再生、プロファイル、サーバー切替、ライブTV、ミュージックの数十件の問題を修正しました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "앱 전체를 두 차례 점검하여 재생, 프로필, 서버 전환, 라이브 TV, 음악에서 수십 건의 문제를 수정했습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En fullstendig dobbel gjennomgang rettet dusinvis av problemer i avspilling, profiler, serverbytte, direkte-TV og musikk."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Een volledige dubbele controle verhielp tientallen problemen in afspelen, profielen, serverwissel, live-tv en muziek."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pełny dwukrotny przegląd naprawił dziesiątki problemów w odtwarzaniu, profilach, przełączaniu serwerów, telewizji na żywo i muzyce."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uma revisão completa em duas passadas corrigiu dezenas de problemas em reprodução, perfis, troca de servidor, TV ao vivo e música."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uma revisão completa em duas passagens corrigiu dezenas de problemas na reprodução, perfis, mudança de servidor, TV em direto e música."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O verificare completă în două treceri a corectat zeci de probleme la redare, profiluri, schimbarea serverului, TV live și muzică."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Полная двухэтапная проверка исправила десятки проблем в воспроизведении, профилях, смене сервера, живом ТВ и музыке."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kompletná dvojitá kontrola opravila desiatky problémov v prehrávaní, profiloch, prepínaní serverov, živej TV a hudbe."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En fullständig dubbel genomgång rättade tiotals problem i uppspelning, profiler, serverbyte, live-tv och musik."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tam kapsamlı iki aşamalı bir inceleme; oynatma, profiller, sunucu değişimi, canlı TV ve müzikte onlarca sorunu düzeltti."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Повна дворазова перевірка виправила десятки проблем у відтворенні, профілях, зміні сервера, живому ТБ і музиці."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "对整个应用进行了两轮全面检查,修复了播放、配置文件、服务器切换、直播电视和音乐中的数十个问题。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "對整個應用程式進行了兩輪全面檢查,修正了播放、設定檔、伺服器切換、直播電視和音樂中的數十個問題。"
          }
        }
      }
    },
