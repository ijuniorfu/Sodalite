    "changelog.0_9_0.playbackSync.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Přeskočení úvodu a závěru i překryv další epizody se teď přesně shodují s videem, i po přetočení nebo obnovení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Spring over intro og outro samt overlejringen til næste episode flugter nu præcist med videoen, selv efter spoling eller genoptagelse."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Intro- und Outro-Sprünge und das Nächste-Episode-Overlay sitzen jetzt exakt auf dem Bild, auch nach Spulen oder Fortsetzen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Η παράλειψη εισαγωγής και τίτλων τέλους και η επικάλυψη επόμενου επεισοδίου ευθυγραμμίζονται τώρα ακριβώς με το βίντεο, ακόμη και μετά από αναζήτηση ή συνέχιση."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Intro and outro skips and the next-episode overlay now line up exactly with the video, even after seeking or resuming."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los saltos de intro y outro y la superposición del próximo episodio ahora coinciden exactamente con el vídeo, incluso después de buscar o reanudar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alku- ja lopputunnusten ohitukset sekä seuraavan jakson peite osuvat nyt täsmälleen videon kanssa, myös kelauksen tai jatkamisen jälkeen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les sauts d'intro et d'outro et la superposition d'épisode suivant s'alignent désormais exactement sur la vidéo, même après une recherche ou une reprise."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Preskakanje uvoda i odjavne špice te prekrivni sloj sljedeće epizode sada se točno poklapaju s videom, čak i nakon premotavanja ili nastavka."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A főcím- és stáblista-átugrás, valamint a következő epizód rátét mostantól pontosan illeszkedik a videóhoz, még tekerés vagy folytatás után is."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I salti di intro e outro e l'overlay dell'episodio successivo ora si allineano esattamente al video, anche dopo una ricerca o una ripresa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "シーンスキップ（イントロ・アウトロ）や次のエピソードのオーバーレイが、シークや再開後でも映像とぴったり揃います。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "인트로와 아웃로 건너뛰기, 다음 에피소드 오버레이가 탐색이나 이어보기 이후에도 영상과 정확히 맞춰집니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hopp over intro og outro samt neste episode-overlegget ligger nå nøyaktig på linje med videoen, selv etter spoling eller gjenopptakelse."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Het overslaan van intro en outro en de overlay voor de volgende aflevering lopen nu exact gelijk met de video, zelfs na het zoeken of hervatten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pomijanie intra i napisów końcowych oraz nakładka następnego odcinka pokrywają się teraz dokładnie z obrazem, nawet po przewinięciu lub wznowieniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os pulos de abertura e encerramento e a sobreposição do próximo episódio agora ficam perfeitamente alinhados com o vídeo, mesmo depois de avançar ou retomar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os saltos de abertura e de encerramento e a sobreposição do episódio seguinte ficam agora perfeitamente alinhados com o vídeo, mesmo após avançar ou retomar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sărirea peste intro și outro și suprapunerea pentru episodul următor se aliniază acum exact cu imaginea, chiar și după derulare sau reluare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Пропуск заставки и финальных титров, а также подсказка о следующей серии теперь точно совпадают с видео, даже после перемотки или возобновления."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Preskočenie úvodu a záveru aj prekrytie ďalšej epizódy sa teraz presne zhodujú s videom, aj po pretočení alebo obnovení."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hoppen över intro och outro samt nästa avsnitt-överlägget ligger nu exakt i linje med videon, även efter spolning eller återupptagning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Açılış ve kapanış atlamaları ile sonraki bölüm katmanı, ileri sarma veya devam ettirme sonrasında bile artık videoyla tam olarak hizalanıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Пропуск заставки й фінальних титрів, а також підказка про наступний епізод тепер точно збігаються з відео, навіть після перемотки чи відновлення."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "片头片尾跳过和下一集浮层现在与画面精确对齐，即使在拖动或恢复播放后也是如此。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "片頭片尾跳過與下一集浮層現在會與畫面精確對齊，即使在拖曳或恢復播放後亦然。"
          }
        }
      }
    },
