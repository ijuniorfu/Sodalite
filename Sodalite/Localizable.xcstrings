    "multiServer.remove.confirm.message %@" : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tím se odstraní všechny profily, tokeny a Seerr relace pro „%@“. Samotný server tím není ovlivněn."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dette sletter alle profiler, tokens og Seerr-sessioner for \"%@\". Selve serveren påvirkes ikke."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alle Profile, Tokens und Seerr-Sitzungen für \"%@\" werden gelöscht. Der Server selbst ist nicht betroffen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Αυτό διαγράφει όλα τα προφίλ, tokens και τις συνεδρίες Seerr για «%@». Ο διακομιστής δεν επηρεάζεται."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "This deletes all profiles, tokens, and Seerr sessions for \"%@\". The server itself is not affected."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Esto elimina todos los perfiles, tokens y sesiones de Seerr de \"%@\". El servidor en sí no se ve afectado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tämä poistaa kaikki profiilit, tunnisteet ja Seerr-istunnot palvelimelta \"%@\". Palvelimeen itseensä ei vaikuteta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Cela supprime tous les profils, jetons et sessions Seerr pour « %@ ». Le serveur lui-même n'est pas affecté."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Time se brišu svi profili, tokeni i Seerr sesije za \"%@\". Sam poslužitelj nije pogođen."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ez törli az összes profilt, tokent és Seerr-munkamenetet a következőhöz: „%@”. Magát a kiszolgálót ez nem érinti."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Verranno eliminati tutti i profili, i token e le sessioni Seerr per \"%@\". Il server stesso non è interessato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "「%@」のすべてのプロファイル、トークン、Seerr セッションが削除されます。サーバー自体は影響を受けません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "\"%@\"의 모든 프로필, 토큰, Seerr 세션이 삭제됩니다. 서버 자체에는 영향이 없습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dette sletter alle profiler, tokens og Seerr-økter for \"%@\". Selve serveren påvirkes ikke."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hiermee worden alle profielen, tokens en Seerr-sessies voor \"%@\" verwijderd. De server zelf wordt niet beïnvloed."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Spowoduje to usunięcie wszystkich profili, tokenów i sesji Seerr dla „%@”. Sam serwer pozostanie nienaruszony."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Isto exclui todos os perfis, tokens e sessões Seerr de \"%@\". O servidor em si não é afetado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Isto elimina todos os perfis, tokens e sessões Seerr de \"%@\". O servidor em si não é afetado."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Aceasta șterge toate profilurile, token-urile și sesiunile Seerr pentru „%@”. Serverul în sine nu este afectat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Это удалит все профили, токены и сеансы Seerr для «%@». Сам сервер не будет затронут."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tým sa odstránia všetky profily, tokeny a Seerr relácie pre „%@“. Samotný server tým nie je ovplyvnený."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detta tar bort alla profiler, tokens och Seerr-sessioner för \"%@\". Själva servern påverkas inte."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bu işlem, \"%@\" için tüm profilleri, jetonları ve Seerr oturumlarını siler. Sunucunun kendisi etkilenmez."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Це видалить усі профілі, токени та сеанси Seerr для «%@». Сам сервер не зазнає змін."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "这将删除“%@”的所有用户、令牌和 Seerr 会话。服务器本身不受影响。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "這將移除「%@」的所有使用者、權杖及 Seerr 工作階段。伺服器本身不受影響。"
          }
        }
      }
    },
