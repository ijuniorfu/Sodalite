    "changelog.0_4_1.detailLoading.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmy a seriály se otevírají v jednom kroku — všechny sekce se načítají paralelně, žádné mezi-překreslení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Film og serier åbnes på én gang — alle sektioner hentes parallelt uden mellem-genoptegninger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filme und Serien öffnen sich in einem Zug — alle Sektionen werden parallel geladen, kein Zwischen-Repaint."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ταινίες και σειρές ανοίγουν με μία κίνηση — κάθε ενότητα φορτώνεται παράλληλα, χωρίς ενδιάμεσες ανανεώσεις."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Movies and series open in one shot, every section fetched in parallel, no mid-render flicker."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Películas y series se abren en un solo paso — cada sección se descarga en paralelo, sin parpadeos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Elokuvat ja sarjat avautuvat kerralla — kaikki osiot ladataan rinnakkain, ei välivilkuntaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Films et séries s'ouvrent d'un seul coup — chaque section chargée en parallèle, sans clignotement."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmovi i serije otvaraju se u jednom potezu — svaki odjeljak se učitava paralelno, bez treperenja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmek és sorozatok egy lépésben nyílnak meg — minden szakasz párhuzamosan töltődik, villogás nélkül."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Film e serie si aprono in un colpo solo — ogni sezione caricata in parallelo, senza flicker."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "映画やシリーズが一度に開きます — すべてのセクションを並列で取得し、途中の再描画なし。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "영화와 시리즈가 한 번에 열립니다 — 모든 섹션이 병렬로 로드되며 중간 깜박임이 없습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmer og serier åpnes i ett trekk — hver seksjon hentes parallelt, uten flimring."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Films en series openen in één keer — elke sectie parallel opgehaald, geen tussentijds geflikker."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmy i seriale otwierają się od razu — każda sekcja ładowana równolegle, bez migotania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmes e séries abrem de uma vez — cada seção carregada em paralelo, sem piscadas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmes e séries abrem de uma vez — cada secção carregada em paralelo, sem piscadelas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmele și serialele se deschid dintr-o singură mișcare — fiecare secțiune încărcată în paralel."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Фильмы и сериалы открываются одним движением — каждый раздел загружается параллельно, без мерцания."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmy a seriály sa otvárajú naraz — každá sekcia sa načítava paralelne, bez prekresľovania."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmer och serier öppnas i ett svep — varje sektion hämtas parallellt, inget mellanläge-blink."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmler ve diziler tek seferde açılır — her bölüm paralel yüklenir, ara kararma yok."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Фільми та серіали відкриваються одним кроком — кожен розділ завантажується паралельно, без мерехтіння."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "电影和剧集一次性打开 — 各部分并行加载,无中途重绘。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "電影和劇集一次性打開 — 各部分並行載入,無中途重繪。"
          }
        }
      }
    },
