      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O všechny vybrané sezóny už bylo požádáno nebo jsou už dostupné"
          }
        },
        "da" : {
          "stringUnit" : {
