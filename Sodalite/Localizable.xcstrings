    "settings.playback.preferLossless.subtitle" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bezeztrátové FLAC až do 7.1 kanálů. Doporučeno pro AVR s vícekanálovým LPCM přes HDMI. Vypnuto použije EAC3 5.1 pro soundbary."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tabsfri FLAC op til 7.1 kanaler. Anbefales til AVR'er med flerkanals LPCM via HDMI. Fra bruger EAC3 5.1 til soundbar-kompatibilitet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Verlustfreies FLAC bis zu 7.1 Kanäle. Empfohlen für AVRs mit Mehrkanal-LPCM über HDMI. Aus nutzt EAC3 5.1 für Soundbar-Kompatibilität."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "FLAC χωρίς απώλειες έως 7.1 κανάλια. Προτείνεται για AVR με πολυκάναλο LPCM μέσω HDMI. Ανενεργό: EAC3 5.1 για soundbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lossless FLAC up to 7.1 channels. Recommended for AVRs with multichannel LPCM over HDMI. Off uses EAC3 5.1 for soundbar compatibility."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "FLAC sin pérdida hasta 7.1 canales. Recomendado para AVR con LPCM multicanal por HDMI. Desactivado usa EAC3 5.1 para barras de sonido."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Häviötön FLAC jopa 7.1 kanavaa. Suositellaan AVR-laitteille, joissa monikanavainen LPCM HDMI:n kautta. Pois: EAC3 5.1 soundbareille."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "FLAC sans perte jusqu'à 7.1 canaux. Recommandé pour AVR avec LPCM multicanal via HDMI. Désactivé utilise EAC3 5.1 pour les barres de son."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bezgubitni FLAC do 7.1 kanala. Preporučeno za AVR uređaje s višekanalnim LPCM preko HDMI. Isključeno koristi EAC3 5.1 za soundbarove."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Veszteségmentes FLAC akár 7.1 csatornáig. AVR-ekhez ajánlott többcsatornás LPCM HDMI-n át. Ki: EAC3 5.1 hangprojektorokhoz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "FLAC senza perdita fino a 7.1 canali. Consigliato per AVR con LPCM multicanale via HDMI. Off usa EAC3 5.1 per le soundbar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ロスレスFLAC、最大7.1チャンネル。HDMI経由のマルチチャンネルLPCM対応AVRに推奨。オフではサウンドバー互換のEAC3 5.1を使用。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "무손실 FLAC, 최대 7.1채널. HDMI 멀티채널 LPCM AVR에 권장. 끄면 사운드바 호환을 위해 EAC3 5.1 사용."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tapsfri FLAC opptil 7.1 kanaler. Anbefales for AVR-er med flerkanals LPCM over HDMI. Av bruker EAC3 5.1 for soundbar-kompatibilitet."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lossless FLAC tot 7.1 kanalen. Aanbevolen voor AVR's met meerkanaals LPCM via HDMI. Uit gebruikt EAC3 5.1 voor soundbar-compatibiliteit."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bezstratny FLAC do 7.1 kanałów. Zalecane dla AVR z wielokanałowym LPCM przez HDMI. Wył.: EAC3 5.1 dla zgodności z soundbarami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "FLAC sem perdas até 7.1 canais. Recomendado para AVRs com LPCM multicanal via HDMI. Desativado usa EAC3 5.1 para soundbars."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "FLAC sem perdas até 7.1 canais. Recomendado para AVRs com LPCM multicanal via HDMI. Desativado usa EAC3 5.1 para soundbars."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "FLAC fără pierderi până la 7.1 canale. Recomandat pentru AVR cu LPCM multicanal prin HDMI. Dezactivat: EAC3 5.1 pentru soundbar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "FLAC без потерь до 7.1 каналов. Рекомендуется для AVR с многоканальным LPCM через HDMI. Выкл.: EAC3 5.1 для саундбаров."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bezstratové FLAC až do 7.1 kanálov. Odporúčané pre AVR s viackanálovým LPCM cez HDMI. Vypnuté použije EAC3 5.1 pre soundbary."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Förlustfri FLAC upp till 7.1 kanaler. Rekommenderas för AVR med flerkanals LPCM via HDMI. Av använder EAC3 5.1 för soundbars."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kayıpsız FLAC, 7.1 kanala kadar. HDMI üzerinden çok kanallı LPCM destekli AVR'ler için önerilir. Kapalı: soundbar için EAC3 5.1."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "FLAC без втрат до 7.1 каналів. Рекомендовано для AVR з багатоканальним LPCM через HDMI. Вимк.: EAC3 5.1 для саундбарів."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "无损 FLAC,最高 7.1 声道。建议用于通过 HDMI 支持多声道 LPCM 的 AVR。关闭时使用 EAC3 5.1 以兼容条形音箱。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "無損 FLAC,最高 7.1 聲道。建議用於透過 HDMI 支援多聲道 LPCM 的 AVR。關閉時使用 EAC3 5.1 以相容 Soundbar。"
          }
        }
      }
    },
