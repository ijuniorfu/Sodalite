    "changelog.0_8_0.castPages.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Klepnutím na člena obsazení otevřete jeho fotku, životopis a kompletní filmografii. Každý titul vás přenese do knihovny, pokud jej máte, jinak do žádosti."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tryk på et besætningsmedlem for at åbne foto, biografi og hele filmografien. Hver titel fører til dit bibliotek, hvis du har den, ellers til anmodningen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tippe auf ein Besetzungsmitglied, um Foto, Biografie und die komplette Filmografie zu öffnen. Jeder Titel führt in deine Library, wenn du ihn hast, sonst in den Anfrage-Flow."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Πατήστε ένα μέλος του καστ για να ανοίξετε τη φωτογραφία, τη βιογραφία και πλήρη φιλμογραφία. Κάθε τίτλος σας πηγαίνει στη βιβλιοθήκη σας αν τον έχετε, αλλιώς στο αίτημα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tap any cast member to open their photo, biography, and full filmography. Each title takes you to your library if you own it, or to the request flow if you don't."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Toca cualquier miembro del reparto para ver su foto, biografía y filmografía completa. Cada título te lleva a tu biblioteca si lo tienes, o al flujo de solicitud si no."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Avaa näyttelijän kuva, elämäkerta ja koko filmografia napauttamalla. Jokainen nimike vie kirjastoosi, jos omistat sen, muuten pyyntönäkymään."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Touchez un membre du casting pour ouvrir sa photo, sa biographie et sa filmographie complète. Chaque titre vous mène à votre bibliothèque si vous le possédez, sinon vers la demande."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dodirnite člana glumačke postave da otvorite njegovu fotografiju, biografiju i cijelu filmografiju. Svaki naslov vodi u vašu knjižnicu ako ga imate, inače na zahtjev."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Koppints egy szereplőre a fotó, az életrajz és a teljes filmográfia megnyitásához. Minden cím a könyvtáradba visz, ha megvan, különben a kéréshez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tocca un membro del cast per aprire foto, biografia e filmografia completa. Ogni titolo ti porta nella tua libreria se lo possiedi, altrimenti al flusso di richiesta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "キャストをタップすると、写真、経歴、出演作品の一覧が開きます。各作品は、所有していればライブラリへ、なければリクエスト画面へ移動します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "출연진을 탭하면 사진, 약력, 전체 작품 목록이 열립니다. 각 작품은 보유 중이면 라이브러리로, 아니면 요청 화면으로 이동합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Trykk på et rollemedlem for å åpne bildet, biografien og hele filmografien. Hver tittel tar deg til biblioteket ditt hvis du har den, ellers til forespørselen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tik op een castlid om de foto, biografie en volledige filmografie te openen. Elke titel brengt je naar je bibliotheek als je die hebt, anders naar de aanvraag."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dotknij członka obsady, aby otworzyć zdjęcie, biografię i pełną filmografię. Każdy tytuł przeniesie cię do biblioteki, jeśli go masz, albo do zgłoszenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Toque em qualquer membro do elenco para abrir a foto, biografia e filmografia completa. Cada título leva você à sua biblioteca, se já tiver, ou ao fluxo de solicitação."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Toque em qualquer membro do elenco para abrir a foto, biografia e filmografia completa. Cada título leva-o à sua biblioteca, se já a tiver, ou ao fluxo de pedido."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Atinge orice membru al distribuției pentru a deschide fotografia, biografia și filmografia completă. Fiecare titlu te duce în biblioteca ta dacă îl ai, sau la cerere dacă nu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Нажмите на актёра, чтобы открыть его фото, биографию и полную фильмографию. Каждый фильм откроется в вашей библиотеке, если он у вас есть, иначе — в запросе."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Klepnutím na člena obsadenia otvoríte jeho fotku, životopis a kompletnú filmografiu. Každý titul vás prenesie do knižnice, ak ho máte, inak do žiadosti."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tryck på en rollmedlem för att öppna foto, biografi och hela filmografin. Varje titel tar dig till ditt bibliotek om du har den, annars till begäran."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bir oyuncuya dokunarak fotoğrafını, biyografisini ve tüm filmografisini açın. Her başlık, sahipseniz kütüphanenize, değilseniz istek akışına götürür."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Торкніться актора, щоб відкрити його фото, біографію та повну фільмографію. Кожен фільм відкриється у вашій бібліотеці, якщо він у вас є, інакше — у запиті."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "点按任意演员即可查看其照片、简介和完整影视作品。若你已拥有该作品，会跳转到媒体库，否则进入请求流程。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "點按任意演員即可查看其照片、簡介和完整影視作品。若你已擁有該作品，會跳轉到媒體庫，否則進入請求流程。"
          }
        }
      }
    },
