        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O Stats for Nerds mostra agora valores ao vivo de sincronização A/V, taxa de bits e buffer. Ativa a secção opcional Engine Diagnostics para uma análise mais detalhada."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stats for Nerds afișează acum valori în direct pentru sincronizarea A/V, bitrate și buffer. Activează opțional secțiunea Engine Diagnostics pentru o privire mai detaliată."
          }
        },
        "ru" : {
