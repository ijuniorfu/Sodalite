    "changelog.0_11_0.requestFilters.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Přepnutí filtru stavu během načítání už nenechá seznam prázdný."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skift af statusfilter, mens anmodninger stadig indlæses, efterlader ikke længere listen tom."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ein Wechsel des Statusfilters während des Ladens lässt die Liste nicht mehr leer zurück."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Η αλλαγή φίλτρου κατάστασης κατά τη φόρτωση δεν αφήνει πλέον τη λίστα κενή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Switching the status filter while requests are still loading no longer leaves the list empty."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Cambiar el filtro de estado mientras las solicitudes aún cargan ya no deja la lista vacía."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tilasuodattimen vaihtaminen latauksen aikana ei enää jätä listaa tyhjäksi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Changer de filtre de statut pendant le chargement ne laisse plus la liste vide."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Promjena filtra statusa tijekom učitavanja više ne ostavlja popis praznim."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A státuszszűrő váltása betöltés közben többé nem hagyja üresen a listát."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Cambiare il filtro di stato mentre le richieste si caricano non lascia più la lista vuota."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "読み込み中にステータスフィルターを切り替えても、リストが空のままになりません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "로딩 중에 상태 필터를 전환해도 목록이 비어 있지 않습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Å bytte statusfilter mens forespørslene fortsatt lastes, etterlater ikke lenger listen tom."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Het wisselen van statusfilter tijdens het laden laat de lijst niet langer leeg achter."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Przełączenie filtra statusu podczas ładowania nie zostawia już pustej listy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Trocar o filtro de status enquanto os pedidos ainda carregam não deixa mais a lista vazia."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mudar o filtro de estado enquanto os pedidos ainda carregam já não deixa a lista vazia."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Schimbarea filtrului de stare în timpul încărcării nu mai lasă lista goală."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Переключение фильтра статуса во время загрузки больше не оставляет список пустым."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Prepnutie filtra stavu počas načítavania už nenechá zoznam prázdny."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Att byta statusfilter medan förfrågningar fortfarande läses in lämnar inte längre listan tom."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Yükleme sırasında durum filtresini değiştirmek artık listeyi boş bırakmıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Перемикання фільтра статусу під час завантаження більше не залишає список порожнім."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在加载过程中切换状态筛选不再导致列表为空。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在載入過程中切換狀態篩選不再導致清單為空。"
          }
        }
      }
    },
