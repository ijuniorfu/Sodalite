    "catalog.allRequests.confirm.delete.message" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ bude odebráno z Jellyseerr. Soubor zůstane beze změny, pokud byl již stažen."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ fjernes fra Jellyseerr. Filen forbliver uændret, hvis den allerede er downloadet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ wird aus Jellyseerr entfernt. Die Datei bleibt unverändert wenn schon heruntergeladen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Το %@ θα αφαιρεθεί από το Jellyseerr. Το αρχείο παραμένει ανέγγιχτο αν έχει ήδη ληφθεί."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ will be removed from Jellyseerr. The file stays untouched if already downloaded."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ se eliminará de Jellyseerr. El archivo no se toca si ya se ha descargado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ poistetaan Jellyseerrista. Tiedosto pysyy muuttumattomana, jos se on jo ladattu."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ sera supprimé de Jellyseerr. Le fichier reste intact s'il a déjà été téléchargé."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ bit će uklonjen iz Jellyseerr-a. Datoteka ostaje nepromijenjena ako je već preuzeta."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ törlődik a Jellyseerrből. A fájl érintetlen marad, ha már letöltötték."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ verrà rimosso da Jellyseerr. Il file rimane invariato se già scaricato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ は Jellyseerr から削除されます。すでにダウンロード済みの場合、ファイルはそのまま残ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@이(가) Jellyseerr에서 제거됩니다. 이미 다운로드된 경우 파일은 그대로 유지됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ fjernes fra Jellyseerr. Filen forblir uendret hvis den allerede er lastet ned."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ wordt verwijderd uit Jellyseerr. Het bestand blijft ongewijzigd als het al gedownload is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ zostanie usunięte z Jellyseerr. Plik pozostaje bez zmian, jeśli został już pobrany."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ será removido do Jellyseerr. O arquivo permanece intacto se já foi baixado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ será removido do Jellyseerr. O ficheiro permanece intacto se já foi transferido."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ va fi eliminat din Jellyseerr. Fișierul rămâne neatins dacă a fost deja descărcat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ будет удалён из Jellyseerr. Файл останется нетронутым, если уже загружен."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ bude odstránené z Jellyseerr. Súbor zostane nezmenený, ak bol už stiahnutý."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ tas bort från Jellyseerr. Filen förblir orörd om den redan har laddats ned."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ Jellyseerr'den kaldırılacak. Dosya zaten indirildiyse değişmeden kalır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ буде видалено з Jellyseerr. Файл залишиться без змін, якщо вже завантажено."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ 将从 Jellyseerr 中移除。如果已下载,文件保持不变。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "%@ 將從 Jellyseerr 中移除。如果已下載,檔案保持不變。"
          }
        }
      }
    },
