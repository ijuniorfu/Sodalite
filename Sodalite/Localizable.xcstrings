    "parental.profiles.subtitle" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Chráněné profily vyžadují PIN k přepnutí, odhlášení nebo otevření nastavení"
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Beskyttede profiler kræver PIN-koden for at skifte væk, logge ud eller åbne indstillinger"
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Geschützte Profile benötigen die PIN zum Wechseln, Abmelden oder Öffnen der Einstellungen"
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα προστατευμένα προφίλ χρειάζονται το PIN για εναλλαγή, αποσύνδεση ή άνοιγμα ρυθμίσεων"
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Protected profiles need the PIN to switch away, log out, or open settings"
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los perfiles protegidos necesitan el PIN para cambiar de perfil, cerrar sesión o abrir los ajustes"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Suojatut profiilit vaativat PIN-koodin profiilin vaihtoon, uloskirjautumiseen tai asetusten avaamiseen"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les profils protégés nécessitent le code PIN pour en changer, se déconnecter ou ouvrir les réglages"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zaštićeni profili trebaju PIN za promjenu profila, odjavu ili otvaranje postavki"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A védett profilok PIN-kódot igényelnek a profilváltáshoz, kijelentkezéshez vagy a beállítások megnyitásához"
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I profili protetti richiedono il PIN per cambiare profilo, disconnettersi o aprire le impostazioni"
