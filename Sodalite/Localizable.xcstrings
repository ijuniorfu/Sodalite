    "changelog.0_7_0.adminRequests.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Správci v Jellyseerru získají v Katalogu novou kartu Všechny požadavky, kde mohou schvalovat, zamítat, mazat a upravovat profil nebo řady u požadavků kteréhokoli uživatele."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr-administratorer får en ny Alle Anmodninger-fane i Katalog, hvor de kan godkende, afvise, slette og redigere profil eller sæsoner for enhver brugers anmodning."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mit Admin-Rechten in Jellyseerr siehst du im Katalog alle Anfragen, kannst genehmigen, ablehnen oder löschen und Profil sowie Staffeln direkt anpassen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι διαχειριστές του Jellyseerr αποκτούν μια νέα καρτέλα Όλα τα Αιτήματα στον Κατάλογο, όπου μπορούν να εγκρίνουν, να απορρίπτουν, να διαγράφουν και να επεξεργάζονται το προφίλ ή τις σεζόν οποιουδήποτε αιτήματος χρήστη."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr admins get a new All Requests tab in Catalog to approve, decline, delete, and edit the profile or seasons of any user's request."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los administradores de Jellyseerr obtienen una nueva pestaña Todas las Solicitudes en Catálogo para aprobar, rechazar, eliminar y editar el perfil o las temporadas de la solicitud de cualquier usuario."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr-järjestelmänvalvojat saavat uuden Kaikki pyynnöt -välilehden Luettelossa, jossa he voivat hyväksyä, hylätä, poistaa ja muokata kenen tahansa käyttäjän pyynnön profiilia tai kausia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les administrateurs Jellyseerr disposent d'un nouvel onglet Toutes les Demandes dans le Catalogue pour approuver, refuser, supprimer et modifier le profil ou les saisons de la demande de tout utilisateur."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Administratori u Jellyseerru dobivaju novu karticu Svi Zahtjevi u Katalogu za odobravanje, odbijanje, brisanje i uređivanje profila ili sezona bilo kojeg korisničkog zahtjeva."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A Jellyseerr-adminisztrátorok új Összes kérés fület kapnak a Katalógusban, ahol bármely felhasználó kérését jóváhagyhatják, elutasíthatják, törölhetik, és szerkeszthetik annak profilját vagy évadait."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gli amministratori di Jellyseerr ottengono una nuova scheda Tutte le Richieste in Catalogo per approvare, rifiutare, eliminare e modificare il profilo o le stagioni della richiesta di qualsiasi utente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr の管理者は、カタログに新しい「すべてのリクエスト」タブが追加され、任意のユーザーのリクエストを承認、却下、削除したり、プロファイルやシーズンを編集したりできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr 관리자는 카탈로그에 새로 추가된 모든 요청 탭에서 모든 사용자 요청을 승인, 거부, 삭제하거나 프로필 또는 시즌을 편집할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr-administratorer får en ny Alle Forespørsler-fane i Katalog for å godkjenne, avslå, slette og redigere profil eller sesonger for en hvilken som helst brukers forespørsel."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr-beheerders krijgen een nieuw tabblad Alle Verzoeken in Catalogus om verzoeken van elke gebruiker goed te keuren, af te wijzen, te verwijderen en het profiel of de seizoenen ervan te bewerken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Administratorzy Jellyseerr otrzymują nową kartę Wszystkie prośby w Katalogu, gdzie mogą zatwierdzać, odrzucać, usuwać oraz edytować profil lub sezony prośby dowolnego użytkownika."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os administradores do Jellyseerr ganham uma nova aba Todas as Solicitações no Catálogo para aprovar, recusar, excluir e editar o perfil ou as temporadas da solicitação de qualquer usuário."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os administradores do Jellyseerr passam a ter um novo separador Todos os Pedidos no Catálogo para aprovar, recusar, eliminar e editar o perfil ou as temporadas do pedido de qualquer utilizador."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Administratorii Jellyseerr primesc o filă nouă Toate Cererile în Catalog pentru a aproba, respinge, șterge și edita profilul sau sezoanele cererii oricărui utilizator."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Администраторы Jellyseerr получают новую вкладку Все запросы в Каталоге, где можно одобрять, отклонять, удалять и редактировать профиль или сезоны запроса любого пользователя."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Správcovia v Jellyseerri získajú v Katalógu novú kartu Všetky požiadavky, kde môžu schvaľovať, zamietať, mazať a upravovať profil alebo série v požiadavkách ktoréhokoľvek používateľa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr-administratörer får en ny flik Alla Förfrågningar i Katalog för att godkänna, avvisa, ta bort och redigera profil eller säsonger för vilken som helst användares förfrågan."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr yöneticileri Katalog'da yeni bir Tüm İstekler sekmesi alır; herhangi bir kullanıcının isteğini onaylayabilir, reddedebilir, silebilir ve profilini ya da sezonlarını düzenleyebilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Адміністратори Jellyseerr отримують у Каталозі нову вкладку Усі запити, де можна затверджувати, відхиляти, видаляти та редагувати профіль або сезони запиту будь-якого користувача."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr 管理员在目录中获得新的“所有请求”标签页,可批准、拒绝、删除任意用户的请求,并编辑其配置文件或季。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyseerr 管理員在目錄中獲得新的「所有請求」分頁,可核准、拒絕、刪除任意使用者的請求,並編輯其設定檔或季。"
          }
        }
      }
    },
