    "changelog.0_11_0.subtitleLongCues.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titulky delší než minutu, běžné u obrazových stop, už nemizí předčasně."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Undertekster, der står længere end et minut, almindeligt på billedbaserede spor, forsvinder ikke længere for tidligt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Untertitel, die länger als eine Minute stehen, üblich bei bildbasierten Spuren, verschwinden nicht mehr zu früh."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Υπότιτλοι που διαρκούν πάνω από ένα λεπτό, συνηθισμένοι σε υπότιτλους εικόνας, δεν εξαφανίζονται πια πρόωρα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Subtitle cues longer than a minute, common on image-based tracks, no longer disappear too early."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los subtítulos que duran más de un minuto, habituales en pistas de imagen, ya no desaparecen antes de tiempo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Yli minuutin kestävät tekstitykset, jotka ovat yleisiä kuvapohjaisilla raidoilla, eivät enää katoa liian aikaisin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les sous-titres affichés plus d'une minute, courants sur les pistes images, ne disparaissent plus trop tôt."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titlovi dulji od minute, uobičajeni na slikovnim zapisima, više ne nestaju prerano."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az egy percnél tovább megjelenő feliratok, amelyek képalapú sávoknál gyakoriak, többé nem tűnnek el idő előtt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I sottotitoli che durano più di un minuto, comuni nelle tracce a immagini, non scompaiono più in anticipo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "画像ベースの字幕トラックに多い1分を超える字幕が、早く消えてしまうことがなくなりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "이미지 기반 트랙에서 흔한 1분 이상 표시되는 자막이 더 이상 일찍 사라지지 않습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Undertekster som vises lenger enn ett minutt, vanlig på bildebaserte spor, forsvinner ikke lenger for tidlig."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ondertitels die langer dan een minuut in beeld staan, gebruikelijk bij beeldgebaseerde sporen, verdwijnen niet meer te vroeg."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Napisy wyświetlane dłużej niż minutę, częste na ścieżkach obrazkowych, nie znikają już przedwcześnie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Legendas exibidas por mais de um minuto, comuns em trilhas baseadas em imagem, não somem mais cedo demais."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As legendas apresentadas durante mais de um minuto, comuns em faixas baseadas em imagem, já não desaparecem cedo demais."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Subtitrările afișate mai mult de un minut, frecvente pe pistele bazate pe imagini, nu mai dispar prea devreme."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Субтитры длительностью более минуты, обычные для графических дорожек, больше не исчезают раньше времени."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titulky dlhšie než minútu, bežné pri obrazových stopách, už nemiznú predčasne."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Undertexter som visas längre än en minut, vanligt på bildbaserade spår, försvinner inte längre för tidigt."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Görüntü tabanlı parçalarda yaygın olan bir dakikadan uzun altyazılar artık erken kaybolmuyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Субтитри тривалістю понад хвилину, звичні для графічних доріжок, більше не зникають передчасно."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "持续超过一分钟的字幕(常见于图像字幕轨)不再过早消失。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "持續超過一分鐘的字幕(常見於圖像字幕軌)不再過早消失。"
          }
        }
      }
    },
