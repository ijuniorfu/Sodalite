          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Witamy na pokładzie! Pakiet Wspierający odblokowany."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bem-vindo a bordo! Pacote de Apoio desbloqueado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bem-vindo a bordo! Pacote de Apoio desbloqueado."
