    "changelog.0_9_0.music.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Procházejte a přehrávejte svou hudbu z Jellyfinu na nativní tvOS obrazovce přehrávání s obalem alba a posuvníkem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gennemse og afspil din Jellyfin-musik med en indbygget Now Playing-skærm til tvOS, komplet med omslag og spoling."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Durchstöbere und spiele deine Jellyfin-Musik mit einem nativen tvOS-Now-Playing-Bildschirm, inklusive Coverbild und Scrubbing."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Περιηγηθείτε και ακούστε τη μουσική σας από το Jellyfin σε μια εγγενή οθόνη αναπαραγωγής tvOS, με εξώφυλλα και αναζήτηση στο χρόνο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Browse and play your Jellyfin music with a native tvOS Now Playing screen, complete with cover art and scrubbing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Explora y reproduce tu música de Jellyfin con una pantalla de reproducción en curso nativa de tvOS, con carátulas y avance dentro de las pistas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Selaa ja toista Jellyfin-musiikkiasi natiivilla tvOS:n toistonäkymällä, mukana kansikuvat ja kelaus."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Parcourez et écoutez votre musique Jellyfin grâce à un écran de lecture en cours natif sur tvOS, avec pochettes et navigation dans les morceaux."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pregledavajte i reproducirajte svoju Jellyfin glazbu na izvornom tvOS zaslonu za reprodukciju, s omotom albuma i premotavanjem."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Böngészd és játszd le a Jellyfin zenédet egy natív tvOS lejátszási képernyőn, borítóképpel és tekeréssel együtt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sfoglia e ascolta la tua musica Jellyfin con una schermata In riproduzione nativa per tvOS, completa di copertine e scorrimento dei brani."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ネイティブの tvOS 再生画面で Jellyfin のミュージックを再生。カバーアートやシークバーにも対応しています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "커버 아트와 탐색 기능을 갖춘 네이티브 tvOS 재생 화면으로 Jellyfin 음악을 둘러보고 재생하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bla gjennom og spill av Jellyfin-musikken din med en innebygd Now Playing-skjerm for tvOS, komplett med omslagsbilder og spoling."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Blader door je Jellyfin-muziek en speel deze af met een native tvOS Now Playing-scherm, compleet met albumhoezen en scrubben."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Przeglądaj i odtwarzaj swoją muzykę z Jellyfina na natywnym ekranie odtwarzania tvOS, z okładką albumu i przewijaniem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Navegue e ouça suas músicas do Jellyfin com uma tela de reprodução nativa do tvOS, com capas dos álbuns e avanço dentro das faixas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Explore e reproduza a sua música do Jellyfin com um ecrã de reprodução nativo do tvOS, com capas dos álbuns e avanço dentro das faixas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Răsfoiește și ascultă muzica ta din Jellyfin printr-un ecran de redare nativ tvOS, cu coperte și derulare prin piese."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Просматривайте и слушайте свою музыку из Jellyfin на нативном экране воспроизведения tvOS с обложками и перемоткой."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Prechádzajte a prehrávajte svoju hudbu z Jellyfinu na natívnej tvOS obrazovke prehrávania s obalom albumu a posuvníkom."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bläddra bland och spela upp din Jellyfin-musik med en inbyggd Now Playing-skärm för tvOS, komplett med omslagsbilder och spolning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jellyfin müziklerinizi, kapak görselleri ve ileri/geri sarma desteğiyle birlikte yerel bir tvOS Çalınıyor ekranında gözatın ve çalın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Переглядайте та слухайте свою музику з Jellyfin на нативному екрані відтворення tvOS з обкладинками та перемоткою."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "通过原生 tvOS 播放界面浏览和播放你的 Jellyfin 音乐，支持封面图和进度拖动。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "透過原生 tvOS 播放畫面瀏覽與播放你的 Jellyfin 音樂，支援封面圖與進度拖曳。"
          }
        }
      }
    },
