    "multiServer.urls.unreachable.message %@" : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ neodpověděl. Přesto můžete uložit, Sodalite to zkusí automaticky znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ svarede ikke. Du kan gemme alligevel, Sodalite prøver automatisk igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hat nicht geantwortet. Du kannst trotzdem speichern, Sodalite versucht es automatisch erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το %@ δεν αποκρίθηκε. Μπορείτε να αποθηκεύσετε ούτως ή άλλως, το Sodalite θα προσπαθήσει ξανά αυτόματα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ did not respond. You can save anyway; Sodalite retries automatically."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ no respondió. Puedes guardar de todos modos, Sodalite lo reintenta automáticamente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ei vastannut. Voit silti tallentaa, Sodalite yrittää automaattisesti uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ n'a pas répondu. Vous pouvez enregistrer quand même, Sodalite réessaie automatiquement."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nije odgovorio. Svejedno možete spremiti, Sodalite automatski pokušava ponovno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A(z) %@ nem válaszolt. Így is elmentheted, a Sodalite automatikusan újrapróbálkozik."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ non ha risposto. Puoi salvare comunque, Sodalite riprova automaticamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ が応答しませんでした。そのまま保存できます。Sodalite が自動的に再試行します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@이(가) 응답하지 않았습니다. 그래도 저장할 수 있으며, Sodalite가 자동으로 다시 시도합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ svarte ikke. Du kan lagre likevel, Sodalite prøver automatisk på nytt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ heeft niet gereageerd. Je kunt toch opslaan, Sodalite probeert het automatisch opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nie odpowiedział. Możesz mimo to zapisać, Sodalite spróbuje ponownie automatycznie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ não respondeu. Você pode salvar mesmo assim, o Sodalite tenta novamente automaticamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ não respondeu. Pode guardar mesmo assim, o Sodalite tenta novamente automaticamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nu a răspuns. Poți salva oricum, Sodalite reîncearcă automat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ не ответил. Вы можете сохранить в любом случае, Sodalite повторит попытку автоматически."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ neodpovedal. Napriek tomu môžete uložiť, Sodalite to skúsi automaticky znova."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ svarade inte. Du kan spara ändå, Sodalite försöker igen automatiskt."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ yanıt vermedi. Yine de kaydedebilirsiniz, Sodalite otomatik olarak yeniden dener."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ не відповів. Ви все одно можете зберегти, Sodalite повторить спробу автоматично."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 未响应。您仍然可以保存，Sodalite 会自动重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 未回應。您仍然可以儲存，Sodalite 會自動重試。"
          }
        }
      }
    },
