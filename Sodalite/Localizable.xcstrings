            "value": "Artık Kırpılan Sekme Yok"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Вкладки більше не обрізаються"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
