    "changelog.0_10_0.tabBar.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lišta karet se u delších jazyků sama rozšíří, takže se žádný popisek neořízne."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fanelinjen gør sig selv bredere til længere sprog, så ingen etiket bliver skåret af."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Die Tab-Leiste verbreitert sich für längere Sprachen, kein Label wird mehr abgeschnitten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Η γραμμή καρτελών πλαταίνει μόνη της για πιο μακροσκελείς γλώσσες, ώστε καμία ετικέτα να μην κόβεται."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "The tab bar widens itself for longer languages, so no label gets cut off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La barra de pestañas se ensancha sola para los idiomas más largos, así ninguna etiqueta queda cortada."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Välilehtipalkki levenee itsestään pidemmille kielille, joten yksikään nimike ei leikkaudu."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La barre d'onglets s'élargit d'elle-même pour les langues plus longues, aucun libellé n'est donc coupé."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Traka kartica sama se proširuje za dulje jezike, pa nijedna oznaka više nije odrezana."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A fülsáv hosszabb nyelveknél magától kiszélesedik, így egyetlen felirat sem vágódik le."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La barra delle schede si allarga da sola per le lingue più lunghe, così nessuna etichetta viene tagliata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "タブバーが長い言語に合わせて自動的に広がるため、ラベルが見切れることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "탭 막대가 긴 언어에 맞춰 스스로 넓어져 어떤 레이블도 잘리지 않습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fanelinjen utvider seg selv for lengre språk, så ingen etikett blir kuttet av."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "De tabbalk maakt zichzelf breder voor langere talen, zodat geen enkel label wordt afgekapt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pasek kart sam się poszerza dla dłuższych języków, więc żadna etykieta nie jest ucinana."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A barra de abas se alarga sozinha para idiomas mais longos, então nenhum rótulo fica cortado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A barra de separadores alarga-se sozinha para idiomas mais longos, pelo que nenhuma etiqueta fica cortada."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bara de file se lărgește singură pentru limbile mai lungi, astfel nicio etichetă nu mai este tăiată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Панель вкладок сама расширяется для длинных языков, поэтому ни одна надпись не обрезается."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lišta kariet sa pri dlhších jazykoch sama rozšíri, takže sa žiadny popisok neoreže."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Flikraden breddar sig själv för längre språk, så ingen etikett klipps av."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sekme çubuğu daha uzun diller için kendiliğinden genişler, böylece hiçbir etiket kesilmez."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Панель вкладок сама розширюється для довших мов, тому жоден напис не обрізається."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "标签栏会为较长的语言自动加宽，任何标签都不会被截断。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "標籤列會為較長的語言自動加寬，任何標籤都不會被截斷。"
          }
        }
      }
    },
    "changelog.0_10_0.tabBar.title" : {
      "comment": "0.10.0 What's New highlight title",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Konec oříznutých karet"
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ikke flere afskårne faner"
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Keine abgeschnittenen Tabs"
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τέλος στις κομμένες καρτέλες"
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "No more clipped tabs"
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Adiós a las pestañas cortadas"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ei enää leikkautuvia välilehtiä"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fini les onglets tronqués"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nema više odrezanih kartica"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nincs több levágott fül"
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Niente più schede tagliate"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "タブの見切れを解消"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "잘리는 탭 없음"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ikke flere avkuttede faner"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Geen afgekapte tabbladen meer"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Koniec z przyciętymi kartami"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Chega de abas cortadas"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fim dos separadores cortados"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gata cu filele tăiate"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Вкладки больше не обрезаются"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Koniec orezaných kariet"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Inga fler avklippta flikar"
          }
        },
        "tr" : {
          "stringUnit" : {
