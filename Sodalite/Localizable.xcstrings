    "changelog.1_0_0.playback.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Řada oprav posouvání, titulků, Dolby Vision a načítání dělá z této verze nejspolehlivější dosud."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En stribe rettelser til spoling, undertekster, Dolby Vision og buffering gør dette til den mest stabile udgave hidtil."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zahlreiche Verbesserungen bei Spulen, Untertiteln, Dolby Vision und Puffern machen dies zur bisher zuverlässigsten Version."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πλήθος διορθώσεων σε αναζήτηση, υπότιτλους, Dolby Vision και προφόρτωση κάνουν αυτή την έκδοση την πιο αξιόπιστη μέχρι τώρα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A wave of fixes to seeking, subtitles, Dolby Vision and buffering makes this the most reliable release yet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Multitud de correcciones en el avance, los subtítulos, Dolby Vision y el almacenamiento en búfer hacen de esta la versión más fiable hasta ahora."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lukuisat korjaukset kelaukseen, tekstityksiin, Dolby Visioniin ja puskurointiin tekevät tästä luotettavimman version tähän mennessä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De nombreux correctifs sur la navigation, les sous-titres, le Dolby Vision et la mise en mémoire tampon en font la version la plus fiable à ce jour."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niz ispravaka za premotavanje, titlove, Dolby Vision i međuspremanje čini ovo dosad najpouzdanijim izdanjem."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Számos javítás a tekerésben, feliratokban, Dolby Visionben és pufferelésben teszi ezt a valaha volt legmegbízhatóbb kiadássá."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una serie di correzioni per lo scorrimento, i sottotitoli, il Dolby Vision e il buffering rendono questa la versione più affidabile di sempre."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シーク、字幕、Dolby Vision、バッファリングへの数々の改善で、これまでで最も安定したリリースになりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "탐색, 자막, Dolby Vision, 버퍼링에 대한 다양한 개선으로 지금까지 가장 안정적인 버전이 되었습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En rekke rettelser for spoling, undertekster, Dolby Vision og bufring gjør dette til den mest pålitelige utgaven så langt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Talloze verbeteringen aan spoelen, ondertitels, Dolby Vision en bufferen maken dit de betrouwbaarste versie tot nu toe."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mnóstwo poprawek przewijania, napisów, Dolby Vision i buforowania sprawia, że to najbardziej niezawodna wersja w historii."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma série de correções na busca, legendas, Dolby Vision e no buffer torna esta a versão mais confiável até agora."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma série de correções na navegação, legendas, Dolby Vision e no buffer torna esta a versão mais fiável até agora."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O serie de remedieri pentru derulare, subtitrări, Dolby Vision și stocare în buffer fac din aceasta cea mai fiabilă versiune de până acum."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Множество исправлений перемотки, субтитров, Dolby Vision и буферизации делают эту версию самой стабильной на сегодня."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Množstvo opráv pri posúvaní, titulkoch, Dolby Vision a načítavaní robí z tejto verzie doteraz najspoľahlivejšiu."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En rad förbättringar av spolning, undertexter, Dolby Vision och buffring gör detta till den mest pålitliga versionen hittills."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sarma, altyazılar, Dolby Vision ve arabelleğe almadaki çok sayıda düzeltme, bunu şimdiye kadarki en kararlı sürüm yapıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Багато виправлень перемотування, субтитрів, Dolby Vision і буферизації роблять цю версію найнадійнішою досі."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "针对快进、字幕、Dolby Vision 和缓冲的大量修复，让这成为迄今最稳定的版本。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "針對快轉、字幕、Dolby Vision 和緩衝的大量修復，讓這成為迄今最穩定的版本。"
          }
        }
      }
    },
