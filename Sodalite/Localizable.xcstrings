            "value": "Tervetuloa! Tukijapaketti avattu."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bienvenue à bord ! Pack de soutien débloqué."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dobrodošli! Podržavateljski paket otključan."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Üdvözlünk! Támogatói csomag feloldva."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Benvenuto a bordo! Pacchetto Sostenitore sbloccato."
