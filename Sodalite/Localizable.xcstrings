    "settings.profile.launch.default.detail" : {
      "comment": "Explanation under 'Use default profile' option",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Přeskočí výběr a automaticky přihlásí výchozí profil."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Spring vælgeren over og log ind som standardprofilen automatisk."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Die Auswahl überspringen und direkt mit dem Standardprofil anmelden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Παρακάμπτει την επιλογή και συνδέεται αυτόματα με το προεπιλεγμένο προφίλ."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Skip the picker and sign in as the default profile automatically."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
