    "player.error.liveUnavailable.body" : {
      "comment": "Error body when a live channel cannot be opened server-side (dead upstream source)",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Server nemohl otevřít stream tohoto kanálu. Zdroj kanálu může být offline. Zkuste to později."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serveren kunne ikke åbne kanalens stream. Kanalens kilde er muligvis offline. Prøv igen senere."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Der Server konnte den Stream dieses Senders nicht öffnen. Die Quelle des Senders ist möglicherweise offline. Versuche es später erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ο διακομιστής δεν μπόρεσε να ανοίξει τη ροή αυτού του καναλιού. Η πηγή του καναλιού ενδέχεται να είναι εκτός σύνδεσης. Δοκιμάστε ξανά αργότερα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "The server could not open this channel's stream. The channel's source may be offline. Try again later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "El servidor no pudo abrir la transmisión de este canal. Es posible que la fuente del canal esté fuera de línea. Inténtalo de nuevo más tarde."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Palvelin ei voinut avata tämän kanavan lähetystä. Kanavan lähde voi olla poissa käytöstä. Yritä myöhemmin uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le serveur n'a pas pu ouvrir le flux de cette chaîne. La source de la chaîne est peut-être hors ligne. Réessayez plus tard."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Poslužitelj nije mogao otvoriti stream ovog kanala. Izvor kanala je možda izvan mreže. Pokušajte ponovno kasnije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A szerver nem tudta megnyitni a csatorna adatfolyamát. Lehet, hogy a csatorna forrása nem érhető el. Próbáld újra később."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Il server non è riuscito ad aprire lo stream di questo canale. La sorgente del canale potrebbe essere offline. Riprova più tardi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "サーバーがこのチャンネルのストリームを開けませんでした。チャンネルのソースがオフラインの可能性があります。後でもう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "서버가 이 채널의 스트림을 열 수 없습니다. 채널 소스가 오프라인일 수 있습니다. 나중에 다시 시도하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serveren kunne ikke åpne kanalens strøm. Kanalens kilde kan være frakoblet. Prøv igjen senere."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "De server kon de stream van deze zender niet openen. De bron van de zender is mogelijk offline. Probeer het later opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serwer nie mógł otworzyć strumienia tego kanału. Źródło kanału może być offline. Spróbuj ponownie później."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O servidor não conseguiu abrir a transmissão deste canal. A fonte do canal pode estar offline. Tente novamente mais tarde."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O servidor não conseguiu abrir a emissão deste canal. A fonte do canal poderá estar offline. Tente novamente mais tarde."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serverul nu a putut deschide fluxul acestui canal. Sursa canalului ar putea fi offline. Încearcă din nou mai târziu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Серверу не удалось открыть поток этого канала. Источник канала может быть недоступен. Повторите попытку позже."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Server nemohol otvoriť stream tohto kanála. Zdroj kanála môže byť offline. Skúste to neskôr."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Servern kunde inte öppna kanalens ström. Kanalens källa kan vara offline. Försök igen senare."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sunucu bu kanalın yayınını açamadı. Kanalın kaynağı çevrimdışı olabilir. Daha sonra tekrar deneyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Сервер не зміг відкрити потік цього каналу. Джерело каналу може бути недоступним. Спробуйте пізніше."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "服务器无法打开此频道的串流。频道源可能已离线。请稍后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "伺服器無法開啟此頻道的串流。頻道來源可能已離線。請稍後再試。"
          }
        }
      }
    },
