    "changelog.0_7_0.deletion.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odstraň filmy, seriály nebo jednotlivé řady ze své knihovny. Pokud je připojen Jellyseerr, odpovídající záznamy v Radarru a Sonarru se zároveň vyčistí."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fjern film, serier eller enkelte sæsoner fra dit bibliotek. Når Jellyseerr er forbundet, ryddes tilsvarende poster i Radarr og Sonarr også op."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Entferne Filme, Serien oder einzelne Staffeln aus deiner Bibliothek. Bei verbundenem Jellyseerr werden passende Radarr- und Sonarr-Einträge gleich mit aufgeräumt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Αφαίρεσε ταινίες, σειρές ή μεμονωμένες σεζόν από τη βιβλιοθήκη σου. Όταν το Jellyseerr είναι συνδεδεμένο, καθαρίζονται και οι αντίστοιχες εγγραφές σε Radarr και Sonarr."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Remove movies, series, or individual seasons from your library. When Jellyseerr is connected, matching Radarr and Sonarr entries are cleaned up too."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Elimina películas, series o temporadas concretas de tu biblioteca. Si Jellyseerr está conectado, las entradas correspondientes en Radarr y Sonarr también se limpian."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Poista elokuvia, sarjoja tai yksittäisiä kausia kirjastostasi. Kun Jellyseerr on yhdistetty, vastaavat tietueet Radarrissa ja Sonarrissa siivotaan myös."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Supprime des films, des séries ou des saisons individuelles de ta bibliothèque. Si Jellyseerr est connecté, les entrées correspondantes dans Radarr et Sonarr sont également nettoyées."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ukloni filmove, serije ili pojedinačne sezone iz svoje biblioteke. Kada je Jellyseerr povezan, čiste se i odgovarajući zapisi u Radarru i Sonarru."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Távolíts el filmeket, sorozatokat vagy egyes évadokat a könyvtáradból. Ha a Jellyseerr csatlakoztatva van, a megfelelő Radarr- és Sonarr-bejegyzések is törlődnek."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Elimina film, serie o singole stagioni dalla tua libreria. Quando Jellyseerr è connesso, anche le voci corrispondenti in Radarr e Sonarr vengono ripulite."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ライブラリから映画、シリーズ、または個別のシーズンを削除できます。Jellyseerr が接続されている場合、対応する Radarr および Sonarr のエントリも整理されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "라이브러리에서 영화, 시리즈 또는 개별 시즌을 삭제할 수 있습니다. Jellyseerr가 연결되어 있으면 해당 Radarr 및 Sonarr 항목도 함께 정리됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fjern filmer, serier eller enkeltsesonger fra biblioteket. Når Jellyseerr er tilkoblet, ryddes også tilsvarende oppføringer i Radarr og Sonarr opp."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Verwijder films, series of afzonderlijke seizoenen uit je bibliotheek. Als Jellyseerr is verbonden, worden bijbehorende vermeldingen in Radarr en Sonarr ook opgeruimd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Usuń filmy, seriale lub pojedyncze sezony ze swojej biblioteki. Gdy Jellyseerr jest połączony, odpowiednie wpisy w Radarr i Sonarr również zostają wyczyszczone."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Remova filmes, séries ou temporadas específicas da sua biblioteca. Quando o Jellyseerr está conectado, as entradas correspondentes no Radarr e no Sonarr também são limpas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Remove filmes, séries ou temporadas específicas da tua biblioteca. Quando o Jellyseerr está ligado, as entradas correspondentes no Radarr e no Sonarr também são limpas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Elimină filme, seriale sau sezoane individuale din biblioteca ta. Când Jellyseerr este conectat, intrările corespunzătoare din Radarr și Sonarr sunt și ele curățate."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Удаляй фильмы, сериалы или отдельные сезоны из своей библиотеки. Если подключён Jellyseerr, соответствующие записи в Radarr и Sonarr тоже очищаются."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odstráň filmy, seriály alebo jednotlivé série zo svojej knižnice. Ak je pripojený Jellyseerr, vyčistia sa aj zodpovedajúce záznamy v Radarri a Sonarri."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ta bort filmer, serier eller enskilda säsonger från ditt bibliotek. När Jellyseerr är anslutet städas motsvarande poster i Radarr och Sonarr också upp."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kütüphanenden film, dizi veya tek tek sezonları kaldır. Jellyseerr bağlıyken Radarr ve Sonarr'daki eşleşen kayıtlar da temizlenir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Видаляй фільми, серіали чи окремі сезони зі своєї бібліотеки. Якщо підключено Jellyseerr, відповідні записи в Radarr і Sonarr теж очищаються."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "从你的媒体库中删除电影、剧集或单独的季。当 Jellyseerr 连接后,Radarr 与 Sonarr 中对应的条目也会一并清理。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "從你的媒體庫中刪除電影、劇集或單獨的季。當 Jellyseerr 連線後,Radarr 與 Sonarr 中對應的項目也會一併清理。"
          }
        }
      }
    },
