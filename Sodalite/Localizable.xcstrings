    "delete.confirm.cascade.seasonsFootnote" : {
      "comment": "Footnote shown when individual seasons are selected (cascade can only remove the whole series)",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr může odstranit pouze celý seriál, nikoli jednotlivé sezóny. Pro úklid v *arr stacku smažte celý seriál."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr kan kun fjerne hele serien, ikke enkelte sæsoner. Slet hele serien for også at rydde op i *arr-stakken."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr kann nur die komplette Serie entfernen, keine einzelnen Staffeln. Um auch im *arr-Stack aufzuräumen, lösche die ganze Serie."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Το Radarr / Sonarr μπορεί να αφαιρέσει μόνο ολόκληρη τη σειρά, όχι μεμονωμένες σεζόν. Για να καθαρίσεις και τη στοίβα *arr, διέγραψε ολόκληρη τη σειρά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr can only remove the entire series, not individual seasons. To also clean up the *arr stack, delete the whole series."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr solo puede eliminar la serie completa, no temporadas individuales. Para limpiar también el stack *arr, elimina toda la serie."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr voi poistaa vain koko sarjan, ei yksittäisiä tuotantokausia. Poista koko sarja, jos haluat siivota myös *arr-pinon."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr ne peut supprimer que la série complète, pas des saisons individuelles. Pour nettoyer aussi la stack *arr, supprimez toute la série."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr može ukloniti samo cijelu seriju, ne pojedinačne sezone. Da bi se počistio i *arr stack, izbriši cijelu seriju."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A Radarr / Sonarr csak a teljes sorozatot tudja eltávolítani, az egyes évadokat nem. Az *arr verem rendbetételéhez töröld az egész sorozatot."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr può rimuovere solo l'intera serie, non singole stagioni. Per ripulire anche lo stack *arr, elimina la serie intera."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarrは個別のシーズンではなく、シリーズ全体のみ削除できます。*arrスタックも整理するにはシリーズ全体を削除してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr는 개별 시즌이 아닌 전체 시리즈만 제거할 수 있습니다. *arr 스택도 정리하려면 시리즈 전체를 삭제하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr kan bare fjerne hele serien, ikke enkeltsesonger. Slett hele serien for også å rydde opp i *arr-stakken."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr kan alleen de hele serie verwijderen, geen losse seizoenen. Verwijder de hele serie om ook de *arr-stack op te ruimen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr może usunąć tylko cały serial, nie poszczególne sezony. Aby uporządkować również stack *arr, usuń cały serial."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr só pode remover a série inteira, não temporadas individuais. Para limpar também o stack *arr, exclua a série completa."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O Radarr / Sonarr só consegue remover a série inteira, não temporadas individuais. Para limpar também a stack *arr, elimina a série completa."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr poate elimina doar întregul serial, nu sezoane individuale. Pentru a curăța și stiva *arr, șterge serialul complet."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr может удалить только весь сериал, а не отдельные сезоны. Чтобы также очистить стек *arr, удалите сериал целиком."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr dokáže odstrániť iba celý seriál, nie jednotlivé sezóny. Ak chcete upratať aj *arr stack, zmažte celý seriál."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr kan bara ta bort hela serien, inte enskilda säsonger. Radera hela serien för att även rensa *arr-stacken."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr yalnızca diziyi tamamen kaldırabilir, sezonları tek tek değil. *arr yığınını da temizlemek için tüm diziyi sil."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr може видалити лише весь серіал, а не окремі сезони. Щоб також очистити *arr стек, видаліть весь серіал."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr 只能移除整个剧集,无法移除单个季。如需同时清理 *arr 套件,请删除整部剧集。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Radarr / Sonarr 只能移除整個劇集,無法移除單一季。如需同時清理 *arr 套件,請刪除整部劇集。"
          }
        }
      }
    },
