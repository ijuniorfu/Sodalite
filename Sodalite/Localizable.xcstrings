    "settings.playback.buffer.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Načítá více dopředu pro plynulé přehrávání z pomalých síťových disků (WebDAV, rclone). Větší vyrovnávací paměť zkracuje hloubku převíjení zpět na rychlých serverech."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buffer længere frem for jævn afspilning fra langsomme netværksdrev (WebDAV, rclone). Større buffere reducerer tilbagespolingsdybden på hurtige servere."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lädt weiter voraus für flüssige Wiedergabe von langsamen Netzlaufwerken (WebDAV, rclone). Größere Puffer verringern die Rückspultiefe auf schnellen Servern."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Προφόρτωση περισσότερου περιεχομένου για ομαλή αναπαραγωγή από αργούς δίσκους δικτύου (WebDAV, rclone). Τα μεγαλύτερα buffer μειώνουν το βάθος επαναφοράς σε γρήγορους διακομιστές."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buffer further ahead for smooth playback from slow network drives (WebDAV, rclone). Larger buffers reduce rewind depth on fast servers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Almacena más contenido por adelantado para una reproducción fluida desde unidades de red lentas (WebDAV, rclone). Los búferes más grandes reducen la profundidad de rebobinado en servidores rápidos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puskuroi enemmän etukäteen sujuvaa toistoa varten hitailta verkkoasemilta (WebDAV, rclone). Suuremmat puskurit lyhentävät taaksepäin kelaamisen syvyyttä nopeilla palvelimilla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Met davantage en mémoire tampon pour une lecture fluide depuis des lecteurs réseau lents (WebDAV, rclone). Des tampons plus grands réduisent la profondeur de rembobinage sur les serveurs rapides."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Učitava više unaprijed za glatku reprodukciju sa sporih mrežnih pogona (WebDAV, rclone). Veći međuspremnici smanjuju dubinu premotavanja unatrag na brzim poslužiteljima."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Több tartalmat tölt be előre a zökkenőmentes lejátszáshoz lassú hálózati meghajtókról (WebDAV, rclone). A nagyobb pufferek csökkentik a visszatekerés mélységét gyors kiszolgálókon."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Precarica più contenuto per una riproduzione fluida da unità di rete lente (WebDAV, rclone). Buffer più grandi riducono la profondità di riavvolgimento su server veloci."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "低速なネットワークドライブ（WebDAV、rclone）からのスムーズな再生のため、先読みを増やします。バッファを大きくすると、高速なサーバーでの巻き戻し可能な範囲が短くなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "느린 네트워크 드라이브(WebDAV, rclone)에서 매끄러운 재생을 위해 더 많이 미리 버퍼링합니다. 버퍼가 클수록 빠른 서버에서 되감기 가능 범위가 줄어듭니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buffer lenger frem for jevn avspilling fra trege nettverksstasjoner (WebDAV, rclone). Større buffere reduserer tilbakespolingsdybden på raske servere."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buffert verder vooruit voor soepele weergave vanaf trage netwerkschijven (WebDAV, rclone). Grotere buffers verkleinen de terugspoeldiepte op snelle servers."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buforuje więcej z wyprzedzeniem dla płynnego odtwarzania z wolnych dysków sieciowych (WebDAV, rclone). Większe bufory zmniejszają głębokość przewijania do tyłu na szybkich serwerach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Armazena mais conteúdo à frente para reprodução suave a partir de unidades de rede lentas (WebDAV, rclone). Buffers maiores reduzem a profundidade de retrocesso em servidores rápidos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coloca mais conteúdo em buffer com antecedência para uma reprodução fluida a partir de unidades de rede lentas (WebDAV, rclone). Buffers maiores reduzem a profundidade de retrocesso em servidores rápidos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Încarcă mai mult în avans pentru redare fluidă de pe unități de rețea lente (WebDAV, rclone). Bufferele mai mari reduc adâncimea de derulare înapoi pe serverele rapide."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Буферизует больше данных заранее для плавного воспроизведения с медленных сетевых дисков (WebDAV, rclone). Больший буфер уменьшает глубину перемотки назад на быстрых серверах."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Načíta viac vopred pre plynulé prehrávanie z pomalých sieťových diskov (WebDAV, rclone). Väčšia vyrovnávacia pamäť skracuje hĺbku pretáčania dozadu na rýchlych serveroch."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buffrar längre fram för jämn uppspelning från långsamma nätverksenheter (WebDAV, rclone). Större buffertar minskar bakåtspolningsdjupet på snabba servrar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yavaş ağ sürücülerinden (WebDAV, rclone) akıcı oynatma için daha fazla önbelleğe alır. Daha büyük arabellekler, hızlı sunucularda geri sarma derinliğini azaltır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Буферизує більше даних заздалегідь для плавного відтворення з повільних мережевих дисків (WebDAV, rclone). Більший буфер зменшує глибину перемотування назад на швидких серверах."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为从缓慢的网络驱动器（WebDAV、rclone）流畅播放而预先缓冲更多内容。缓冲越大，在高速服务器上可回退的范围越小。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "為了從緩慢的網路磁碟機（WebDAV、rclone）流暢播放而預先緩衝更多內容。緩衝越大，在高速伺服器上可倒轉的範圍越小。"
          }
        }
      }
    },
