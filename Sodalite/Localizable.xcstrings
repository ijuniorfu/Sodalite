    "changelog.0_9_0.detailLogos.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Obrazovky s detaily teď zobrazují logotyp názvu nad pozadím a kompletní popisy epizod, s možností loga vypnout."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detaljeskærme lader nu titellogoet svæve over baggrunden og viser fulde episoderesuméer, med en kontakt til at slå logoerne fra."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detailseiten zeigen das Titel-Logo jetzt schwebend über dem Hintergrund und die vollständige Episodenbeschreibung, mit einem Schalter zum Ausblenden der Logos."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι οθόνες λεπτομερειών εμφανίζουν τώρα το λογότυπο του τίτλου πάνω από το φόντο και τις πλήρεις περιλήψεις των επεισοδίων, με έναν διακόπτη για την απενεργοποίηση των λογότυπων."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detail screens now float the title logo over the backdrop and show full episode synopses, with a toggle to turn the logos off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Las pantallas de detalle ahora superponen el logotipo del título sobre el fondo y muestran las sinopsis completas de los episodios, con una opción para ocultar los logotipos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tietonäkymät kelluttavat nyt nimilogon taustakuvan päällä ja näyttävät jakson koko kuvauksen. Logot voi myös kytkeä pois."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les écrans de détail affichent désormais le logo du titre sur l'arrière-plan ainsi que les synopsis complets des épisodes, avec une option pour masquer les logos."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zasloni s detaljima sada prikazuju logotip naslova preko pozadine i pune sažetke epizoda, uz mogućnost isključivanja logotipa."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A részletes képernyők mostantól a háttér fölött jelenítik meg a cím logóját és a teljes epizódleírásokat, a logók kikapcsolásának lehetőségével."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le schermate di dettaglio ora sovrappongono il logo del titolo allo sfondo e mostrano le trame complete degli episodi, con un'opzione per nascondere i logo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "詳細画面で背景の上にタイトルロゴを重ねて表示し、エピソードのあらすじを全文表示します。ロゴはオフにも切り替えられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "상세 화면에서 배경 위에 타이틀 로고를 띄우고 에피소드 줄거리를 전체 표시하며, 로고는 끌 수도 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detaljskjermer lar nå tittellogoen sveve over bakgrunnen og viser fulle episodesammendrag, med en bryter for å slå av logoene."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detailschermen laten het titellogo nu boven de achtergrond zweven en tonen volledige samenvattingen van afleveringen, met een schakelaar om de logo's uit te zetten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ekrany szczegółów wyświetlają teraz logotyp tytułu na tle oraz pełne opisy odcinków, z opcją wyłączenia logotypów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As telas de detalhes agora exibem o logotipo do título sobre o fundo e mostram as sinopses completas dos episódios, com uma opção para ocultar os logotipos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os ecrãs de detalhe apresentam agora o logótipo do título sobre o fundo e mostram as sinopses completas dos episódios, com uma opção para ocultar os logótipos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ecranele de detalii afișează acum logoul titlului peste fundal și prezintă rezumatele complete ale episoadelor, cu o opțiune pentru a ascunde logourile."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "На страницах с подробностями логотип названия теперь парит над фоном, отображаются полные описания серий, а логотипы можно отключить переключателем."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Obrazovky s detailmi teraz zobrazujú logo názvu nad pozadím a úplné popisy epizód, s možnosťou logá vypnúť."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Detaljskärmar låter nu titellogotypen sväva över bakgrunden och visar fullständiga avsnittssammanfattningar, med en växel för att stänga av logotyperna."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ayrıntı ekranları artık başlık logosunu arka planın üzerinde gösteriyor ve bölümlerin tam özetlerini sunuyor. Logolar isteğe bağlı olarak kapatılabilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "На сторінках з деталями логотип назви тепер ширяє над тлом, відображаються повні описи епізодів, а логотипи можна вимкнути перемикачем."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "详情页现在会将标题徽标浮于背景图之上，并完整显示单集简介，徽标也可关闭。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "詳細資料頁現在會將標題標誌浮現於背景圖之上，並完整顯示單集劇情簡介，標誌亦可關閉。"
          }
        }
      }
    },
