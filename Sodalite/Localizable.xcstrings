    "settings.cloudSync.push.subtitle" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Použije nastavení tohoto zařízení jako aktuální stav na všech zařízeních"
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gør denne enheds indstillinger til den aktuelle tilstand på alle enheder"
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Die Einstellungen dieses Geräts zum aktuellen Stand auf allen Geräten machen"
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ορίστε τις ρυθμίσεις αυτής της συσκευής ως την τρέχουσα κατάσταση σε όλες τις συσκευές"
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Make this device's settings the current state on all devices"
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Convierte los ajustes de este dispositivo en el estado actual de todos los dispositivos"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Aseta tämän laitteen asetukset nykyiseksi tilaksi kaikilla laitteilla"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Définir les réglages de cet appareil comme état actuel sur tous les appareils"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Primijenite postavke ovog uređaja kao trenutačno stanje na svim uređajima"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A jelen eszköz beállításainak alkalmazása aktuális állapotként minden eszközön"
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Rendi le impostazioni di questo dispositivo lo stato attuale su tutti i dispositivi"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "このデバイスの設定を、すべてのデバイスの現在の状態にします"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "이 기기의 설정을 모든 기기의 현재 상태로 만듭니다"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gjør innstillingene fra denne enheten til gjeldende tilstand på alle enheter"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stel de instellingen van dit apparaat in als de huidige status op alle apparaten"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zastosuj ustawienia tego urządzenia jako bieżący stan na wszystkich urządzeniach"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Torne os ajustes deste dispositivo o estado atual em todos os dispositivos"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Torne as definições deste dispositivo o estado atual em todos os dispositivos"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Aplică setările acestui dispozitiv ca stare curentă pe toate dispozitivele"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Сделать настройки этого устройства текущими на всех устройствах"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Použije nastavenia tohto zariadenia ako aktuálny stav na všetkých zariadeniach"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gör den här enhetens inställningar till det aktuella tillståndet på alla enheter"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bu cihazın ayarlarını tüm cihazlarda geçerli durum yap"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Зробити налаштування цього пристрою поточним станом на всіх пристроях"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "将此设备的设置设为所有设备的当前状态"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "將此裝置的設定設為所有裝置的目前狀態"
          }
        }
      }
    },
