    "changelog.0_11_0.libraryPaging.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrované mřížky při posouvání průběžně načítají další tituly, místo aby skončily u první dávky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrerede gitre indlæser flere titler, mens du scroller, i stedet for at stoppe ved første portion."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gefilterte Raster laden beim Scrollen weitere Titel nach, statt nach dem ersten Schwung zu stoppen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα φιλτραρισμένα πλέγματα συνεχίζουν να φορτώνουν τίτλους καθώς κάνετε κύλιση, αντί να σταματούν στην πρώτη παρτίδα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtered grids keep loading more titles as you scroll instead of stopping at the first batch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Las cuadrículas filtradas siguen cargando títulos al desplazarte, en lugar de detenerse en el primer lote."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Suodatetut ruudukot lataavat lisää nimikkeitä vierittäessä sen sijaan, että pysähtyisivät ensimmäiseen erään."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les grilles filtrées continuent de charger des titres au fil du défilement au lieu de s'arrêter au premier lot."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrirane mreže nastavljaju učitavati naslove dok listate, umjesto da stanu na prvoj seriji."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A szűrt rácsok görgetés közben további címeket töltenek be, ahelyett hogy az első adagnál megállnának."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le griglie filtrate continuano a caricare titoli durante lo scorrimento, invece di fermarsi al primo blocco."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "フィルター付きグリッドは最初のひとまとまりで止まらず、スクロールに合わせてタイトルを読み込み続けます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "필터된 그리드가 첫 묶음에서 멈추지 않고 스크롤할 때마다 타이틀을 계속 불러옵니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrerte rutenett fortsetter å laste inn titler mens du blar, i stedet for å stoppe ved første pulje."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gefilterde rasters blijven titels laden terwijl je scrolt, in plaats van te stoppen bij de eerste lading."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrowane siatki doczytują kolejne tytuły podczas przewijania, zamiast zatrzymywać się na pierwszej partii."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As grades filtradas continuam carregando títulos conforme você rola, em vez de parar no primeiro lote."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As grelhas filtradas continuam a carregar títulos à medida que percorre, em vez de pararem no primeiro lote."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Grilele filtrate continuă să încarce titluri pe măsură ce derulați, în loc să se oprească la primul lot."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Отфильтрованные сетки подгружают новые позиции при прокрутке, а не останавливаются на первой порции."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrované mriežky pri rolovaní priebežne načítavajú ďalšie tituly, namiesto toho aby skončili pri prvej dávke."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrerade rutnät fortsätter läsa in titlar medan du bläddrar, i stället för att stanna vid första omgången."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filtrelenmiş ızgaralar ilk grupta durmak yerine kaydırdıkça yeni içerikler yüklemeye devam ediyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Відфільтровані сітки підвантажують нові позиції під час прокручування, а не зупиняються на першій порції."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "筛选网格会在滚动时持续加载更多内容,而不再停留在第一批。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "篩選網格會在捲動時持續載入更多內容,而不再停在第一批。"
          }
        }
      }
    },
