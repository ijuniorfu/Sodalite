    "changelog.0_9_0.fasterDetail.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odkazy na epizody a seznamy sérií se teď vykreslí okamžitě místo čekání na pomalý server."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dybe links til episoder og sæsonlister vises nu med det samme i stedet for at vente på en langsom server."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Episoden-Deeplinks und Staffellisten erscheinen jetzt sofort, statt auf einen langsamen Server zu warten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι σύνδεσμοι επεισοδίων και οι λίστες κύκλων εμφανίζονται τώρα ακαριαία, χωρίς να περιμένουν έναν αργό διακομιστή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Episode deep links and season lists now paint instantly instead of waiting on a slow server."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los enlaces directos a episodios y las listas de temporadas ahora se cargan al instante, sin esperar a un servidor lento."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jaksojen syvälinkit ja kausilistat piirtyvät nyt välittömästi sen sijaan, että odottaisivat hidasta palvelinta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les liens profonds vers les épisodes et les listes de saisons s'affichent désormais instantanément, sans attendre un serveur lent."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Poveznice na epizode i popisi sezona sada se prikazuju trenutačno umjesto čekanja na spori poslužitelj."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az epizódhivatkozások és évadlisták mostantól azonnal megjelennek, nem kell lassú szerverre várni."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I collegamenti diretti agli episodi e gli elenchi delle stagioni ora si caricano all'istante, senza attendere un server lento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "エピソードのディープリンクやシーズン一覧が、遅いサーバーを待たずに即座に表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "에피소드 딥링크와 시즌 목록이 느린 서버를 기다리지 않고 즉시 표시됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dyplenker til episoder og sesonglister tegnes nå opp umiddelbart i stedet for å vente på en treg server."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Deeplinks naar afleveringen en seizoenslijsten verschijnen nu meteen in plaats van te wachten op een trage server."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Linki do odcinków i listy sezonów renderują się teraz natychmiast zamiast czekać na powolny serwer."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Os links diretos para episódios e as listas de temporadas agora aparecem na hora, sem esperar por um servidor lento."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As ligações diretas para episódios e as listas de temporadas surgem agora de imediato, sem esperar por um servidor lento."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Linkurile directe către episoade și listele de sezoane se afișează acum instantaneu, fără să aștepte un server lent."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ссылки на серии и списки сезонов теперь отображаются мгновенно, не дожидаясь медленного сервера."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odkazy na epizódy a zoznamy sérií sa teraz vykreslia okamžite namiesto čakania na pomalý server."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Djuplänkar till avsnitt och säsongslistor ritas nu upp direkt i stället för att vänta på en långsam server."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bölüm bağlantıları ve sezon listeleri artık yavaş bir sunucuyu beklemek yerine anında görüntüleniyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Посилання на епізоди та списки сезонів тепер відображаються миттєво, не очікуючи на повільний сервер."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "单集深层链接和分季列表现在会即时呈现，无需等待缓慢的服务器。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "單集深層連結與分季清單現在會即時呈現，無需等待緩慢的伺服器。"
          }
        }
      }
    },
