    "changelog.0_12_0.parental.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nastav ochranný PIN pro ochranu profilů a uzamčení změn nastavení, serverů a profilů. Zapomněl jsi ho? Obnov ho svým heslem k Jellyfinu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Indstil en beskyttelses-PIN for at beskytte profiler og låse ændringer af indstillinger, servere og profiler. Glemt den? Gendan med din Jellyfin-adgangskode."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lege eine Eltern-PIN fest, um Profile zu schützen und Änderungen an Einstellungen, Servern und Profilen zu sperren. Vergessen? Stelle sie mit deinem Jellyfin-Passwort wieder her."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Όρισε ένα PIN προστασίας για να προστατεύεις προφίλ και να κλειδώνεις αλλαγές σε ρυθμίσεις, διακομιστές και προφίλ. Το ξέχασες; Επανάφερέ το με τον κωδικό σου στο Jellyfin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Set a Guardian PIN to protect profiles and lock changes to settings, servers and profiles. Forgot it? Recover with your Jellyfin password."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Configura un PIN de protección para proteger perfiles y bloquear cambios en ajustes, servidores y perfiles. ¿Lo olvidaste? Recupéralo con tu contraseña de Jellyfin."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Aseta suoja-PIN, joka suojaa profiilit ja lukitsee asetusten, palvelinten ja profiilien muutokset. Unohtuiko se? Palauta se Jellyfin-salasanallasi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Définis un code PIN de protection pour protéger les profils et verrouiller les modifications des réglages, serveurs et profils. Oublié ? Récupère-le avec ton mot de passe Jellyfin."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Postavi zaštitni PIN za zaštitu profila i zaključavanje promjena postavki, poslužitelja i profila. Zaboravio si ga? Vrati ga svojom Jellyfin lozinkom."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Állíts be egy védő PIN-kódot a profilok védelméhez, és zárold a beállítások, kiszolgálók és profilok módosítását. Elfelejtetted? Állítsd vissza a Jellyfin-jelszavaddal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Imposta un PIN di protezione per proteggere i profili e bloccare le modifiche a impostazioni, server e profili. Dimenticato? Recuperalo con la tua password Jellyfin."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "保護用PINを設定して、プロファイルを保護し、設定・サーバー・プロファイルの変更をロックできます。忘れた場合は、Jellyfinのパスワードで復元できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "보호 PIN을 설정해 프로필을 보호하고 설정, 서버, 프로필 변경을 잠그세요. 잊으셨나요? Jellyfin 비밀번호로 복구할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Angi en beskyttelses-PIN for å beskytte profiler og låse endringer i innstillinger, servere og profiler. Glemt den? Gjenopprett med Jellyfin-passordet ditt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stel een beveiligings-PIN in om profielen te beschermen en wijzigingen aan instellingen, servers en profielen te vergrendelen. Vergeten? Herstel hem met je Jellyfin-wachtwoord."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ustaw kod PIN, aby chronić profile i blokować zmiany ustawień, serwerów i profili. Zapomniałeś go? Odzyskaj go za pomocą hasła do Jellyfina."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Defina um PIN de proteção para proteger perfis e bloquear alterações em ajustes, servidores e perfis. Esqueceu? Recupere com sua senha do Jellyfin."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Define um PIN de proteção para proteger perfis e bloquear alterações a definições, servidores e perfis. Esqueceste-te? Recupera-o com a tua palavra-passe do Jellyfin."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Setează un cod PIN de protecție pentru a proteja profilurile și a bloca modificările setărilor, serverelor și profilurilor. L-ai uitat? Recuperează-l cu parola ta Jellyfin."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Задайте защитный PIN-код, чтобы защитить профили и заблокировать изменение настроек, серверов и профилей. Забыли его? Восстановите с помощью пароля Jellyfin."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nastav ochranný PIN na ochranu profilov a uzamknutie zmien nastavení, serverov a profilov. Zabudol si ho? Obnov ho svojím heslom k Jellyfinu."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ange en skydds-PIN för att skydda profiler och låsa ändringar av inställningar, servrar och profiler. Glömt den? Återställ med ditt Jellyfin-lösenord."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Profilleri korumak ve ayarlar, sunucular ve profillerdeki değişiklikleri kilitlemek için bir koruma PIN'i belirleyin. Unuttunuz mu? Jellyfin parolanızla kurtarın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Установіть захисний PIN-код, щоб захистити профілі та заблокувати зміни налаштувань, серверів і профілів. Забули його? Відновіть за допомогою пароля Jellyfin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "设置保护 PIN 码以保护资料库、锁定对设置、服务器和资料的更改。忘记了？用你的 Jellyfin 密码找回。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "設定保護 PIN 碼以保護設定檔、鎖定對設定、伺服器和設定檔的更改。忘記了？用你的 Jellyfin 密碼找回。"
          }
        }
      }
    },
