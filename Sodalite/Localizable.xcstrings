    "changelog.0_12_0.trailers.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Přehraj místní upoutávku titulu přímo ze serveru tlačítkem na stránce s detaily."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Afspil en titels lokale trailer direkte fra serveren med en knap på detaljesiden."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Spiele den lokalen Trailer eines Titels direkt von deinem Server, über einen Knopf auf der Detailseite."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Παίξε το τοπικό τρέιλερ ενός τίτλου απευθείας από τον διακομιστή σου, με ένα κουμπί στη σελίδα λεπτομερειών."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Play a title's local trailer straight from your server with a button on the detail page."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Reproduce el tráiler local de un título directamente desde tu servidor con un botón en la página de detalle."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Toista nimikkeen paikallinen traileri suoraan palvelimeltasi tietosivun painikkeella."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lis la bande-annonce locale d'un titre directement depuis ton serveur grâce à un bouton sur la page de détail."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pusti lokalnu najavu naslova izravno s tvog poslužitelja gumbom na stranici s detaljima."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Játszd le egy cím helyi előzetesét közvetlenül a kiszolgálódról a részletező oldal egy gombjával."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Riproduci il trailer locale di un titolo direttamente dal tuo server con un pulsante nella pagina di dettaglio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "作品のローカル予告編を、詳細ページのボタンからサーバー上で直接再生できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "상세 페이지의 버튼으로 작품의 로컬 예고편을 서버에서 바로 재생합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Spill av en titts lokale trailer rett fra serveren med en knapp på detaljsiden."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Speel de lokale trailer van een titel rechtstreeks vanaf je server af met een knop op de detailpagina."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odtwórz lokalny zwiastun tytułu prosto z serwera przyciskiem na stronie szczegółów."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Reproduza o trailer local de um título direto do seu servidor com um botão na página de detalhes."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Reproduz o trailer local de um título diretamente do teu servidor com um botão na página de detalhe."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Redă trailerul local al unui titlu direct de pe serverul tău cu un buton de pe pagina de detalii."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Воспроизводите локальный трейлер тайтла прямо с сервера кнопкой на странице с подробностями."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Prehraj lokálnu ukážku titulu priamo zo svojho servera tlačidlom na stránke s detailmi."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Spela en titels lokala trailer direkt från servern med en knapp på detaljsidan."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bir başlığın yerel fragmanını, ayrıntı sayfasındaki bir düğmeyle doğrudan sunucunuzdan oynatın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Відтворюйте локальний трейлер тайтлу прямо з сервера кнопкою на сторінці з деталями."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "通过详情页上的按钮，直接从服务器播放影片的本地预告片。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "透過詳細頁上的按鈕，直接從伺服器播放影片的本地預告片。"
          }
        }
      }
    },
