    "changelog.0_9_0.watched.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Označujte filmy, epizody, série i celé seriály jako zhlédnuté, s odznaky, které ukazují váš postup na úvodní obrazovce i v detailech."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Marker film, episoder, sæsoner og hele serier som set, med mærker der viser din fremgang på hjem- og detaljeskærme."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Markiere Filme, Episoden, Staffeln und ganze Serien als gesehen, mit Badges, die deinen Fortschritt auf der Startseite und den Detailseiten zeigen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Σημειώστε ταινίες, επεισόδια, κύκλους και ολόκληρες σειρές ως ιδωμένα, με σήματα που δείχνουν την πρόοδό σας στην Αρχική και στις οθόνες λεπτομερειών."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mark movies, episodes, seasons and entire series as watched, with badges that show your progress across Home and detail screens."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Marca películas, episodios, temporadas y series enteras como vistas, con insignias que muestran tu progreso en el inicio y en las pantallas de detalle."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Merkitse elokuvat, jaksot, kaudet ja kokonaiset sarjat katsotuiksi. Merkit näyttävät edistymisesi sekä alkunäytöllä että tietonäkymissä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Marquez films, épisodes, saisons et séries entières comme vus, avec des badges qui montrent votre progression sur l'accueil et les écrans de détail."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Označite filmove, epizode, sezone i cijele serije kao pogledane, uz oznake koje prikazuju vaš napredak na početnom zaslonu i u detaljima."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Jelölj filmeket, epizódokat, évadokat és teljes sorozatokat megtekintettként, jelvényekkel, amelyek a kezdőképernyőn és a részletes nézetekben mutatják az előrehaladásodat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Contrassegna film, episodi, stagioni e intere serie come visti, con badge che mostrano i tuoi progressi nella Home e nelle schermate di dettaglio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "映画、エピソード、シーズン、シリーズ全体を視聴済みにでき、ホームや詳細画面で進捗バッジを表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "영화, 에피소드, 시즌, 시리즈 전체를 시청 완료로 표시하고, 홈과 상세 화면에서 진행 상황을 배지로 확인하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Merk filmer, episoder, sesonger og hele serier som sett, med merker som viser fremdriften din på hjem- og detaljskjermer."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Markeer films, afleveringen, seizoenen en complete series als bekeken, met badges die je voortgang tonen op Home- en detailschermen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Oznaczaj filmy, odcinki, sezony i całe seriale jako obejrzane, z plakietkami pokazującymi postęp na ekranie głównym i w szczegółach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Marque filmes, episódios, temporadas e séries inteiras como assistidos, com selos que mostram seu progresso na tela inicial e nas telas de detalhes."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Marque filmes, episódios, temporadas e séries inteiras como vistos, com emblemas que mostram o seu progresso no início e nos ecrãs de detalhe."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Marchează filme, episoade, sezoane și seriale întregi ca vizionate, cu insigne care îți arată progresul pe ecranul principal și pe ecranele de detalii."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Отмечайте фильмы, серии, сезоны и целые сериалы как просмотренные. Значки показывают ваш прогресс на главном экране и в подробных карточках."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Označujte filmy, epizódy, série aj celé seriály ako pozreté, s odznakmi, ktoré ukazujú váš postup na domovskej obrazovke aj v detailoch."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Markera filmer, avsnitt, säsonger och hela serier som visade, med märken som visar dina framsteg på hem- och detaljskärmar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Filmleri, bölümleri, sezonları ve dizilerin tamamını izlendi olarak işaretleyin. Rozetler, ilerlemenizi Ana ekranda ve ayrıntı ekranlarında gösterir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Позначайте фільми, епізоди, сезони та цілі серіали як переглянуті. Значки показують ваш прогрес на головному екрані та на сторінках з деталями."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "可将电影、单集、整季和整部剧集标记为已观看，并在主页和详情页通过角标显示观看进度。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "可將電影、單集、整季與整部影集標記為已觀看，並在主畫面和詳細資料頁以標記顯示觀看進度。"
          }
        }
      }
    },
