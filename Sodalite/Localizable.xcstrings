    "changelog.0_8_0.detailPages.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stránky filmů a seriálů nyní zobrazují obsazení, hodnocení, kde sledovat a podobné tituly. U vlastních titulů z knihovny najdete také slogan, režii, scénář a studia."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Film- og seriesider viser nu rollebesætning, bedømmelser, hvor kan ses og lignende titler. Dine egne bibliotekstitler viser også tagline, instruktør, manuskript og studier."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Film- und Serienseiten zeigen jetzt Besetzung, Bewertungen, wo verfügbar und ähnliche Titel. Bei eigenen Library-Titeln stehen zusätzlich Tagline, Regie, Drehbuch und Studios."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι σελίδες ταινιών και σειρών δείχνουν τώρα το καστ, βαθμολογίες, πού να δείτε και παρόμοιους τίτλους. Οι δικοί σας τίτλοι εμφανίζουν επίσης το σλόγκαν, σκηνοθεσία, σενάριο και στούντιο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Movie and show pages now show the cast, ratings, where to watch, and more like this. Your own library titles also list the tagline, director, writer, and studios."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Las páginas de películas y series ahora muestran el reparto, valoraciones, dónde ver y títulos similares. Tus títulos de la biblioteca también indican el eslogan, dirección, guion y estudios."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Elokuva- ja sarjasivuilla näkyy nyt näyttelijät, arvostelut, mistä katsoa ja samankaltaisia. Oman kirjastosi nimikkeissä näkyvät myös slogan, ohjaus, käsikirjoitus ja studiot."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les pages de films et de séries affichent désormais le casting, les notes, où regarder et des titres similaires. Vos titres de bibliothèque indiquent aussi l'accroche, la réalisation, le scénario et les studios."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stranice filmova i serija sada prikazuju glumačku postavu, ocjene, gdje gledati i slične naslove. Vlastiti naslovi iz knjižnice navode i slogan, redatelja, scenarij i studije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A film- és sorozatoldalak most megjelenítik a szereplőket, értékeléseket, hol nézhető és hasonló címeket. A saját könyvtárad címeinél a szlogen, rendező, forgatókönyv és stúdiók is megjelennek."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le pagine di film e serie ora mostrano il cast, le valutazioni, dove guardare e titoli simili. I titoli della tua libreria indicano anche slogan, regia, sceneggiatura e studi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "映画やシリーズのページにキャスト、評価、配信サービス、関連作品が表示されるようになりました。ライブラリの作品にはキャッチコピー、監督、脚本、制作会社も表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "영화와 시리즈 페이지에 출연진, 평점, 시청 가능한 곳, 비슷한 콘텐츠가 표시됩니다. 라이브러리의 작품에는 태그라인, 감독, 각본, 제작사도 함께 표시됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Film- og seriesider viser nå rollebesetning, vurderinger, hvor du kan se og lignende titler. Egne bibliotektitler viser også slagord, regi, manus og studioer."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Film- en seriepagina's tonen nu de cast, beoordelingen, waar te kijken en vergelijkbare titels. Je eigen bibliotheektitels tonen ook de tagline, regie, scenario en studio's."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Strony filmów i seriali pokazują teraz obsadę, oceny, gdzie obejrzeć i podobne tytuły. Twoje tytuły z biblioteki zawierają też hasło, reżyserię, scenariusz i studia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As páginas de filmes e séries agora mostram o elenco, avaliações, onde assistir e títulos semelhantes. Seus títulos da biblioteca também listam o slogan, direção, roteiro e estúdios."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As páginas de filmes e séries mostram agora o elenco, avaliações, onde ver e títulos semelhantes. Os seus títulos da biblioteca também indicam o slogan, realização, argumento e estúdios."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Paginile filmelor și serialelor afișează acum distribuția, evaluările, unde de vizionat și titluri similare. Titlurile din biblioteca ta listează și sloganul, regia, scenariul și studiourile."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "На страницах фильмов и сериалов теперь показаны актёры, рейтинги, где смотреть и похожее. Для своих фильмов также указаны слоган, режиссёр, сценарий и студии."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stránky filmov a seriálov teraz zobrazujú obsadenie, hodnotenia, kde sledovať a podobné tituly. Pri vlastných tituloch z knižnice nájdete aj slogan, réžiu, scenár a štúdiá."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Film- och seriesidor visar nu rollistan, betyg, var du kan se och liknande titlar. Dina egna bibliotekstitlar visar även slogan, regi, manus och studior."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Film ve dizi sayfaları artık oyuncuları, puanları, nereden izleneceğini ve benzer içerikleri gösteriyor. Kendi kütüphanenizdeki başlıklarda ayrıca slogan, yönetmen, senaryo ve stüdyolar yer alır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Сторінки фільмів і серіалів тепер показують акторів, оцінки, де дивитися та схоже. Для власних фільмів також вказано слоган, режисера, сценарій і студії."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "电影和剧集页面现在会显示演员、评分、观看渠道和相似内容。你的媒体库作品还会列出标语、导演、编剧和制作公司。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "電影和劇集頁面現在會顯示演員、評分、觀看管道和相似內容。你的媒體庫作品還會列出標語、導演、編劇和製作公司。"
          }
        }
      }
    },
