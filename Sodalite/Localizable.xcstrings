    "changelog.0_10_0.channelErrors.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanál s nedostupným zdrojem to teď oznámí hned, místo aby se načítal donekonečna."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En kanal, hvis kilde er offline, siger det med det samme i stedet for at indlæse for evigt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ein Sender mit toter Quelle sagt das jetzt sofort, statt endlos zu laden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ένα κανάλι του οποίου η πηγή είναι εκτός σύνδεσης το αναφέρει αμέσως αντί να φορτώνει επ' αόριστον."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A channel whose source is offline says so right away instead of loading forever."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un canal cuya fuente está fuera de línea lo indica de inmediato en lugar de cargar para siempre."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanava, jonka lähde on poissa käytöstä, kertoo sen heti loputtoman lataamisen sijaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Une chaîne dont la source est hors ligne l'indique immédiatement au lieu de charger indéfiniment."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanal čiji je izvor nedostupan sada to odmah javlja umjesto da se beskonačno učitava."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az a csatorna, amelynek a forrása nem elérhető, ezt azonnal jelzi, ahelyett hogy örökké töltene."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un canale con la sorgente offline ora lo dice subito invece di caricare all'infinito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ソースがオフラインのチャンネルは、いつまでも読み込み続ける代わりに、すぐにその旨を表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "소스가 오프라인인 채널은 무한 로딩 대신 바로 알려줍니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En kanal med en kilde som er frakoblet, sier det med en gang i stedet for å laste evig."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Een zender waarvan de bron offline is, meldt dat nu meteen in plaats van eindeloos te laden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanał, którego źródło jest niedostępne, od razu o tym informuje, zamiast ładować się w nieskończoność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Um canal com a fonte offline avisa isso na hora em vez de carregar para sempre."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Um canal com a fonte offline indica-o de imediato em vez de carregar para sempre."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Un canal a cărui sursă este offline o spune imediat în loc să se încarce la nesfârșit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Канал с недоступным источником сразу сообщает об этом вместо бесконечной загрузки."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kanál s nedostupným zdrojom to teraz oznámi hneď, namiesto nekonečného načítavania."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "En kanal vars källa är offline säger det direkt i stället för att ladda i all evighet."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kaynağı çevrimdışı olan bir kanal, sonsuza dek yüklenmek yerine bunu hemen söyler."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Канал із недоступним джерелом одразу повідомляє про це замість нескінченного завантаження."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "信号源离线的频道会立即提示，而不是一直加载。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "訊號源離線的頻道會立即提示，而不是一直載入。"
          }
        }
      }
    },
    "changelog.0_10_0.channelErrors.title" : {
      "comment": "0.10.0 What's New highlight title",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Srozumitelné chyby kanálů"
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tydelige kanalfejl"
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Klare Sender-Fehler"
          }
        },
