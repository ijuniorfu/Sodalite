    "changelog.0_7_0.uiPolish.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Akcentová barva nyní proudí až do záložkové lišty, Domov se spolehlivě posune zpět nahoru a desítky drobných detailů ohledně fokusu, tónování a přechodů jsou v celé aplikaci uhlazené."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Din accentfarve flyder nu hele vejen til fanelinjen, Hjem ruller pålideligt tilbage til toppen, og snesevis af mindre detaljer omkring fokus, toning og overgange er glattet ud i hele appen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Deine Akzentfarbe wirkt jetzt durchgängig bis in die Tab-Leiste, Home scrollt zuverlässig nach oben, und dutzende kleinere Fokus-, Tönungs- und Übergangsdetails wurden in der ganzen App geglättet."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Το χρώμα τονισμού σου περνά τώρα μέχρι τη γραμμή καρτελών, η Αρχική κυλά αξιόπιστα ξανά στην κορυφή, και δεκάδες μικρότερες λεπτομέρειες εστίασης, χρωματισμού και μεταβάσεων έχουν εξομαλυνθεί σε όλη την εφαρμογή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Your accent colour now flows through to the tab bar, Home scrolls reliably back to the top, and dozens of smaller focus, tinting, and transition details have been smoothed out across the app."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tu color de acento ahora se aplica hasta la barra de pestañas, Inicio vuelve fiablemente al principio, y se han pulido decenas de pequeños detalles de foco, tinte y transiciones en toda la app."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Korostusvärisi yltää nyt välilehtipalkkiin asti, Etusivu vierittää luotettavasti takaisin ylös, ja kymmenet pienemmät kohdistus-, sävytys- ja siirtymäyksityiskohdat on hiottu sileiksi koko sovelluksessa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ta couleur d'accent traverse désormais jusqu'à la barre d'onglets, Accueil revient en haut de façon fiable, et des dizaines de petits détails de focus, de teinte et de transitions ont été lissés dans toute l'app."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tvoja boja naglaska sada se proteže sve do trake kartica, Početna se pouzdano vraća na vrh, a deseci sitnih detalja fokusa, tonova i prijelaza poravnani su u cijeloj aplikaciji."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A kiemelő színed mostantól a fülsávra is átvitt, a Kezdőlap megbízhatóan visszagörget a tetejére, és tucatnyi apró fókusz-, színezés- és átmenetrészlet finomodott az alkalmazás egészében."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Il tuo colore d'accento ora arriva fino alla barra delle schede, Home torna in alto in modo affidabile, e decine di piccoli dettagli di focus, tinta e transizioni sono stati rifiniti in tutta l'app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "アクセントカラーがタブバーまで反映され、ホームは確実に最上部に戻り、フォーカス、ティント、トランジションに関する数十の細かなディテールがアプリ全体で整えられました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "강조 색상이 탭 바까지 이어지고, 홈은 안정적으로 맨 위로 스크롤되며, 포커스, 색조, 전환과 관련된 자잘한 디테일 수십 가지가 앱 전반에서 다듬어졌습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Aksentfargen din følger nå helt til fanelinjen, Hjem ruller pålitelig tilbake til toppen, og titalls mindre detaljer rundt fokus, tonelegging og overganger er polert i hele appen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Je accentkleur loopt nu door tot in de tabbalk, Home scrollt betrouwbaar terug naar boven, en tientallen kleinere focus-, tint- en overgangsdetails zijn in de hele app gladgestreken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kolor akcentu rozciąga się teraz aż do paska kart, Strona główna niezawodnie wraca na górę, a dziesiątki drobnych detali dotyczących fokusa, tonowania i przejść zostały dopracowane w całej aplikacji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sua cor de destaque agora se estende até a barra de abas, Início rola de volta ao topo com confiabilidade, e dezenas de pequenos detalhes de foco, tonalização e transições foram aprimorados em todo o app."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A tua cor de destaque estende-se agora até à barra de separadores, Início desloca-se de volta ao topo de forma fiável, e dezenas de pequenos detalhes de foco, tonalidade e transições foram aperfeiçoados em toda a app."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Culoarea ta de accent ajunge acum până la bara de file, Acasă derulează în partea de sus în mod fiabil, iar zeci de detalii mai mici de focalizare, nuanțare și tranziții au fost rafinate în toată aplicația."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Акцентный цвет теперь распространяется вплоть до панели вкладок, Главный экран надёжно прокручивается обратно наверх, и десятки мелких деталей фокуса, тонирования и переходов отполированы по всему приложению."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Akcentová farba sa teraz prejaví až po lištu záložiek, Domov sa spoľahlivo posunie späť hore a desiatky drobných detailov ohľadom fokusu, tónovania a prechodov sú v celej aplikácii uhladené."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Din accentfärg når nu hela vägen till flikraden, Hem rullar tillförlitligt tillbaka till toppen, och dussintals mindre detaljer kring fokus, toning och övergångar är utjämnade i hela appen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vurgu rengin artık sekme çubuğuna kadar uzanıyor, Ana Sayfa güvenle yukarı geri kayıyor ve uygulama genelinde odak, tonlama ve geçişlere dair onlarca küçük ayrıntı pürüzsüzleştirildi."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Акцентний колір тепер сягає аж до панелі вкладок, Головна надійно прокручується назад угору, а десятки дрібних деталей фокусу, тонування й переходів вигладжено в усьому застосунку."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "强调色现在贯穿至标签栏,主页可靠地滚动回顶部,且数十个关于焦点、着色与过渡的细节在整个应用中得到打磨。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "強調色現在延伸至分頁列,首頁可靠地捲動回頂部,且數十個關於焦點、著色與轉場的細節在整個應用程式中得到打磨。"
          }
        }
      }
    },
