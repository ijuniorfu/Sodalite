    "settings.cloudSync.delete.confirm.message" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Všechna data Sodalite v iCloudu budou smazána. Vaše místní data v každém zařízení zůstanou."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alle Sodalite-data i iCloud slettes. Dine lokale data på hver enhed bevares."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alle Sodalite-Daten in iCloud werden gelöscht. Deine lokalen Daten auf jedem Gerät bleiben erhalten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Όλα τα δεδομένα του Sodalite στο iCloud θα διαγραφούν. Τα τοπικά σας δεδομένα σε κάθε συσκευή παραμένουν."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "All Sodalite data in iCloud will be deleted. Your local data on each device stays."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Se eliminarán todos los datos de Sodalite en iCloud. Tus datos locales en cada dispositivo se conservan."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kaikki Sodaliten tiedot iCloudissa poistetaan. Kunkin laitteen paikalliset tiedot säilyvät."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Toutes les données Sodalite dans iCloud seront supprimées. Vos données locales sur chaque appareil sont conservées."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Svi Sodalite podaci u iCloudu bit će izbrisani. Vaši lokalni podaci na svakom uređaju ostaju."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az iCloudban lévő összes Sodalite-adat törlődik. Az egyes eszközökön lévő helyi adatok megmaradnak."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tutti i dati di Sodalite in iCloud verranno eliminati. I tuoi dati locali su ogni dispositivo restano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "iCloud内のすべてのSodaliteデータが削除されます。各デバイスのローカルデータは残ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "iCloud의 모든 Sodalite 데이터가 삭제됩니다. 각 기기의 로컬 데이터는 유지됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alle Sodalite-data i iCloud slettes. De lokale dataene dine på hver enhet beholdes."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alle Sodalite-gegevens in iCloud worden verwijderd. Je lokale gegevens op elk apparaat blijven behouden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Wszystkie dane Sodalite w iCloud zostaną usunięte. Twoje dane lokalne na każdym urządzeniu pozostaną."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Todos os dados do Sodalite no iCloud serão excluídos. Seus dados locais em cada dispositivo permanecem."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Todos os dados do Sodalite no iCloud serão eliminados. Os seus dados locais em cada dispositivo permanecem."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Toate datele Sodalite din iCloud vor fi șterse. Datele tale locale de pe fiecare dispozitiv rămân."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Все данные Sodalite в iCloud будут удалены. Ваши локальные данные на каждом устройстве останутся."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Všetky dáta Sodalite v iCloude budú zmazané. Vaše lokálne dáta v každom zariadení zostanú."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Alla Sodalite-data i iCloud raderas. Dina lokala data på varje enhet behålls."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "iCloud'daki tüm Sodalite verileri silinecek. Her cihazdaki yerel verileriniz kalır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Усі дані Sodalite в iCloud буде видалено. Ваші локальні дані на кожному пристрої залишаться."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "iCloud 中的所有 Sodalite 数据都将被删除。每台设备上的本地数据会保留。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "iCloud 中的所有 Sodalite 資料都將被刪除。每部裝置上的本機資料會保留。"
          }
        }
      }
    },
