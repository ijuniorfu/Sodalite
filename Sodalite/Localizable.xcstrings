    "changelog.0_10_0.styledSubs.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titulky ASS a SSA se zobrazují s původními písmy, barvami a umístěním. V nastavení přehrávání můžete přepínat mezi stylovaným a jednoduchým zobrazením."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS- og SSA-undertekster vises med deres originale skrifttyper, farver og placering. Skift mellem stilet og almindelig tekstvisning i afspilningsindstillingerne."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS- und SSA-Untertitel erscheinen mit ihren Original-Schriften, -Farben und -Positionen. In den Wiedergabe-Einstellungen kannst du zwischen gestylter und einfacher Darstellung wechseln."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι υπότιτλοι ASS και SSA εμφανίζονται με τις αρχικές γραμματοσειρές, τα χρώματα και τη θέση τους. Εναλλάξτε μεταξύ στυλιζαρισμένης και απλής απόδοσης κειμένου στις ρυθμίσεις αναπαραγωγής."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS and SSA subtitles render with their original fonts, colors and positioning. Switch between styled and plain text rendering in the playback settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los subtítulos ASS y SSA se muestran con sus fuentes, colores y posiciones originales. Cambia entre la representación con estilo y la de texto simple en los ajustes de reproducción."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS- ja SSA-tekstitykset näkyvät alkuperäisillä fonteillaan, väreillään ja sijainneillaan. Voit vaihtaa tyylitellyn ja pelkän tekstin välillä toistoasetuksissa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les sous-titres ASS et SSA s'affichent avec leurs polices, couleurs et positions d'origine. Basculez entre le rendu stylisé et le texte simple dans les réglages de lecture."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titlovi ASS i SSA prikazuju se s izvornim fontovima, bojama i položajem. U postavkama reprodukcije prebacujte između stiliziranog i običnog prikaza teksta."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az ASS és SSA feliratok az eredeti betűtípusokkal, színekkel és pozícióval jelennek meg. A lejátszási beállításokban válthatsz a stílusos és az egyszerű szöveges megjelenítés között."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I sottotitoli ASS e SSA vengono mostrati con i font, i colori e le posizioni originali. Passa dal rendering con stile al testo semplice nelle impostazioni di riproduzione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASSおよびSSA字幕を、元のフォント、色、配置のまま表示します。再生設定でスタイル付き表示とプレーンテキスト表示を切り替えられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS 및 SSA 자막이 원본 글꼴, 색상, 위치 그대로 표시됩니다. 재생 설정에서 스타일 표시와 일반 텍스트 표시를 전환할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS- og SSA-undertekster vises med sine originale skrifter, farger og plassering. Bytt mellom stilisert og enkel tekstvisning i avspillingsinnstillingene."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS- en SSA-ondertitels worden weergegeven met hun originele lettertypen, kleuren en positionering. Wissel in de afspeelinstellingen tussen gestileerde en eenvoudige tekstweergave."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Napisy ASS i SSA są wyświetlane z oryginalnymi czcionkami, kolorami i położeniem. W ustawieniach odtwarzania przełączysz się między stylizowanym a zwykłym wyświetlaniem tekstu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Legendas ASS e SSA aparecem com suas fontes, cores e posições originais. Alterne entre a renderização estilizada e o texto simples nos ajustes de reprodução."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As legendas ASS e SSA aparecem com os tipos de letra, cores e posições originais. Alterne entre a apresentação estilizada e o texto simples nas definições de reprodução."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Subtitrările ASS și SSA sunt redate cu fonturile, culorile și poziționarea lor originale. Comută între redarea stilizată și textul simplu în setările de redare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Субтитры ASS и SSA отображаются с оригинальными шрифтами, цветами и расположением. В настройках воспроизведения можно переключаться между стилизованным и простым текстом."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titulky ASS a SSA sa zobrazujú s pôvodnými písmami, farbami a umiestnením. V nastaveniach prehrávania môžete prepínať medzi štylizovaným a jednoduchým zobrazením."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS- och SSA-undertexter visas med sina ursprungliga typsnitt, färger och placeringar. Växla mellan stiliserad och enkel textvisning i uppspelningsinställningarna."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS ve SSA altyazıları özgün yazı tipleri, renkleri ve konumlarıyla görüntülenir. Oynatma ayarlarından stilli ve düz metin görünümü arasında geçiş yapın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Субтитри ASS і SSA відображаються з оригінальними шрифтами, кольорами та розташуванням. У налаштуваннях відтворення можна перемикатися між стилізованим і простим текстом."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS 和 SSA 字幕将以原始字体、颜色和位置呈现。可在播放设置中切换样式化渲染与纯文本渲染。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ASS 與 SSA 字幕會以原始字型、顏色和位置呈現。可在播放設定中切換樣式化顯示與純文字顯示。"
          }
        }
      }
    },
