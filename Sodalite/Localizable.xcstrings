    "changelog.0_5_0.supporterIcon.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hvězdičková ikona zůstává zlatá bez ohledu na vybranou barvu zvýraznění."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stjerneikonet forbliver guldfarvet uanset hvilken accentfarve du har valgt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Das Stern-Icon bleibt gold, unabhängig von der gewählten Akzentfarbe."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Το εικονίδιο του αστεριού παραμένει χρυσό ανεξάρτητα από το χρώμα έμφασης που έχετε επιλέξει."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "The star icon stays gold regardless of the accent colour you've picked."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "El icono de la estrella se mantiene dorado independientemente del color de acento que hayas elegido."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tähtikuvake pysyy kultaisena valitsemastasi korostusväristä riippumatta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "L'icône en forme d'étoile reste dorée quelle que soit la couleur d'accent choisie."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ikona zvjezdice ostaje zlatna bez obzira na odabranu istaknutu boju."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A csillag ikon arany marad a választott kiemelő színtől függetlenül."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "L'icona a forma di stella resta dorata indipendentemente dal colore d'accento scelto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "選択したアクセントカラーに関係なく、星のアイコンは常に金色のままになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "선택한 강조 색상에 관계없이 별 아이콘이 항상 금색으로 유지됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stjerneikonet forblir gullfarget uavhengig av hvilken aksentfarge du har valgt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Het sterpictogram blijft goudkleurig, ongeacht de accentkleur die je hebt gekozen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ikona gwiazdki pozostaje złota niezależnie od wybranego koloru akcentu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O ícone de estrela continua dourado independentemente da cor de destaque escolhida."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O ícone de estrela continua dourado independentemente da cor de destaque escolhida."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pictograma stea rămâne aurie indiferent de culoarea de accent aleasă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Значок звезды остаётся золотым независимо от выбранного акцентного цвета."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hviezdičková ikona zostáva zlatá bez ohľadu na vybranú farbu zvýraznenia."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stjärnikonen förblir guldfärgad oavsett vilken accentfärg du har valt."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Yıldız simgesi, seçtiğiniz vurgu renginden bağımsız olarak altın renginde kalır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Значок зірки залишається золотим незалежно від обраного акцентного кольору."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "无论你选择哪种强调色,星形图标都保持为金色。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "無論你選擇哪種強調色,星形圖示都保持為金色。"
          }
        }
      }
    },
