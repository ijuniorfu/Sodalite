    "changelog.0_13_0.instantSubtitles.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vestavěné titulky se zapnou okamžitě, i na vzdálených nebo pomalých serverech."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Indlejrede undertekster slås til med det samme, selv på fjerne eller langsomme servere."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Eingebettete Untertitel schalten sich sofort ein, auch auf entfernten oder langsamen Servern."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι ενσωματωμένοι υπότιτλοι ενεργοποιούνται άμεσα, ακόμη και σε απομακρυσμένους ή αργούς διακομιστές."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Embedded subtitles turn on instantly, even on remote or slow servers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los subtítulos integrados se activan al instante, incluso en servidores remotos o lentos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Upotetut tekstitykset käynnistyvät heti myös etä- tai hitailla palvelimilla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les sous-titres intégrés s'activent instantanément, même sur des serveurs distants ou lents."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ugrađeni titlovi uključuju se odmah, čak i na udaljenim ili sporim poslužiteljima."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A beágyazott feliratok azonnal bekapcsolnak, még távoli vagy lassú szervereken is."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I sottotitoli incorporati si attivano immediatamente, anche su server remoti o lenti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "内蔵字幕は、リモートや低速のサーバーでも瞬時にオンになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "내장 자막이 원격 서버나 느린 서버에서도 즉시 켜집니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Innebygde undertekster slås på umiddelbart, selv på eksterne eller trege servere."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ingesloten ondertitels schakelen direct in, zelfs op externe of trage servers."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Wbudowane napisy włączają się natychmiast, nawet na zdalnych lub wolnych serwerach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As legendas incorporadas são ativadas na hora, mesmo em servidores remotos ou lentos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As legendas incorporadas são ativadas de imediato, mesmo em servidores remotos ou lentos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Subtitrările încorporate se activează instantaneu, chiar și pe servere la distanță sau lente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Встроенные субтитры включаются мгновенно даже на удалённых или медленных серверах."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vstavané titulky sa zapnú okamžite aj na vzdialených alebo pomalých serveroch."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Inbäddade undertexter slås på direkt, även på fjärranslutna eller långsamma servrar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gömülü altyazılar uzak veya yavaş sunucularda bile anında açılır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Вбудовані субтитри вмикаються миттєво навіть на віддалених або повільних серверах."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "内嵌字幕即开即用，即使在远程或较慢的服务器上也是如此。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "內嵌字幕即開即用，即使在遠端或較慢的伺服器上也是如此。"
          }
        }
      }
    },
