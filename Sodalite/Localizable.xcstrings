    "support.pending" : {
      "comment": "Status banner when a purchase is pending parental approval or SCA",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Čeká se na schválení. Nákup bude dokončen po schválení."
          }
