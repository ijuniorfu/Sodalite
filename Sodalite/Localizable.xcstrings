    "changelog.0_10_0.detailCalm.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Synopse a informace o tvůrcích si při načítání rezervují místo, takže nic neskáče, a epizody bez popisu to teď dají vědět."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Synopsis og holdinfo reserverer deres plads under indlæsning, så intet hopper, og episoder uden beskrivelse siger det nu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Synopsis und Crew-Infos reservieren ihren Platz beim Laden, nichts springt mehr, und Episoden ohne Beschreibung sagen das jetzt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Η σύνοψη και οι πληροφορίες συντελεστών δεσμεύουν τον χώρο τους κατά τη φόρτωση, ώστε τίποτα να μην μετακινείται, και τα επεισόδια χωρίς περιγραφή το αναφέρουν πλέον."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Synopsis and crew info reserve their space while loading, so nothing jumps, and episodes without a description now say so."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "La sinopsis y la información del equipo reservan su espacio mientras cargan, así nada salta, y los episodios sin descripción ahora lo indican."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Juonikuvaus ja tekijätiedot varaavat tilansa latauksen aikana, joten mikään ei hypi, ja jaksot ilman kuvausta kertovat sen nyt."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le synopsis et les infos sur l'équipe réservent leur espace pendant le chargement, plus rien ne saute, et les épisodes sans description l'indiquent désormais."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sažetak i podaci o ekipi rezerviraju svoje mjesto tijekom učitavanja pa ništa ne skače, a epizode bez opisa sada to i kažu."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A tartalomleírás és a stábinfó betöltés közben fenntartja a helyét, így semmi sem ugrál, és a leírás nélküli epizódok mostantól jelzik ezt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sinossi e informazioni sul cast riservano il loro spazio durante il caricamento, così nulla salta, e gli episodi senza descrizione ora lo dicono."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "あらすじとスタッフ情報は読み込み中もスペースを確保するため、表示が飛び跳ねません。説明のないエピソードはその旨を表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "줄거리와 제작진 정보가 로딩 중에도 자리를 유지해 화면이 튀지 않으며, 설명이 없는 에피소드는 이제 그렇다고 표시됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Synopsis og stabsinfo reserverer plassen sin under lasting, så ingenting hopper, og episoder uten beskrivelse sier det nå."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Synopsis en crew-info reserveren hun ruimte tijdens het laden, zodat niets verspringt, en afleveringen zonder beschrijving melden dat nu."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Opis fabuły i informacje o twórcach rezerwują swoje miejsce podczas ładowania, więc nic nie skacze, a odcinki bez opisu teraz o tym informują."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A sinopse e as informações da equipe reservam seu espaço durante o carregamento, então nada pula, e episódios sem descrição agora avisam isso."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A sinopse e as informações da equipa reservam o seu espaço durante o carregamento, pelo que nada salta, e os episódios sem descrição agora indicam-no."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sinopsisul și informațiile despre echipă își rezervă spațiul în timpul încărcării, astfel nimic nu sare, iar episoadele fără descriere o spun acum."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Описание и сведения о съёмочной группе резервируют место при загрузке, ничего не прыгает, а эпизоды без описания теперь сообщают об этом."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Synopsa a informácie o tvorcoch si pri načítavaní rezervujú miesto, takže nič neskáče, a epizódy bez popisu to teraz dajú vedieť."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Synopsis och teaminfo reserverar sin plats medan de laddas, så inget hoppar, och avsnitt utan beskrivning säger det nu."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Özet ve ekip bilgileri yüklenirken yerlerini korur, böylece hiçbir şey zıplamaz; açıklaması olmayan bölümler de artık bunu belirtir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Опис і відомості про знімальну групу резервують місце під час завантаження, нічого не стрибає, а епізоди без опису тепер повідомляють про це."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "简介和演职人员信息在加载时会预留位置，画面不再跳动；没有简介的单集现在会明确说明。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "簡介與演職人員資訊在載入時會預留位置，畫面不再跳動；沒有簡介的單集現在會明確說明。"
          }
        }
      }
    },
