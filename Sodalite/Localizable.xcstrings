          "stringUnit" : {
            "state": "translated",
            "value": "Estimé à partir de la durée et du nombre de lectures. Visionnages répétés inclus."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Procjena na temelju trajanja i broja reprodukcija. Uključuje ponovna gledanja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Becslés a hossz és a lejátszások száma alapján. Az ismételt megtekintések beleszámítanak."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Stimato dalla durata e dal numero di riproduzioni. Incluse le visioni ripetute."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "再生時間と再生回数からの推定です。再視聴を含みます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "재생 시간과 재생 횟수로 추정한 값입니다. 다시 보기 포함."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Estimert ut fra spilletid og antall avspillinger. Gjenvisninger medregnet."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Geschat op basis van speelduur en aantal weergaven. Herhaalde weergaven inbegrepen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Szacunek na podstawie czasu trwania i liczby odtworzeń. Z uwzględnieniem ponownych odtworzeń."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Estimado a partir da duração e do número de reproduções. Inclui novas exibições."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Estimado a partir da duração e do número de reproduções. Inclui revisualizações."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Estimat din durată și numărul de redări. Revizionările sunt incluse."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Оценка по длительности и числу воспроизведений. С учётом повторных просмотров."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odhad podľa dĺžky a počtu prehraní. Vrátane opakovaných sledovaní."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Uppskattat utifrån speltid och antal uppspelningar. Omtittningar medräknade."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Süre ve oynatma sayısından tahmin edilir. Tekrar izlemeler dahildir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Оцінка за тривалістю та кількістю відтворень. Повторні перегляди враховано."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "根据时长和播放次数估算。包含重复观看。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "根據時長和播放次數估算。包含重複觀看。"
          }
        }
      }
