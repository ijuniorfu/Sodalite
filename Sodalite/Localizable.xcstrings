    "home.error.unreachable" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nelze se připojit k serveru. Zkontrolujte připojení a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kunne ikke nå serveren. Tjek forbindelsen og prøv igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Server nicht erreichbar. Überprüfe die Verbindung und versuche es erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Αδυναμία πρόσβασης στον διακομιστή. Ελέγξτε τη σύνδεση και δοκιμάστε ξανά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Couldn't reach your server. Check the connection and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "No se pudo contactar con el servidor. Comprueba la conexión e inténtalo de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Palvelimeen ei saatu yhteyttä. Tarkista yhteys ja yritä uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Impossible de joindre votre serveur. Vérifiez la connexion et réessayez."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ne mogu se povezati s poslužiteljem. Provjeri vezu i pokušaj ponovno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nem sikerült elérni a kiszolgálót. Ellenőrizd a kapcsolatot, és próbáld újra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
