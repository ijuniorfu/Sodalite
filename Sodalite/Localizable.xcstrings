    "changelog.1_0_0.milestone.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konec beta verze, připraveno pro všechny. Díky všem testerům, kteří ho pomohli utvářet."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ude af beta og klar til alle. Tak til alle testere, der har været med til at forme det."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Raus aus der Beta und bereit für alle. Danke an alle Tester, die dabei geholfen haben."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Τέλος στη beta, έτοιμο για όλους. Ευχαριστούμε κάθε δοκιμαστή που βοήθησε να διαμορφωθεί."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Out of beta and ready for everyone. Thank you to every tester who helped shape it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fuera de la beta y listo para todos. Gracias a cada tester que ayudó a darle forma."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beta on ohi ja sovellus on valmis kaikille. Kiitos jokaiselle testaajalle, joka auttoi muokkaamaan sitä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fini la bêta, prêt pour tous. Merci à tous les testeurs qui ont contribué à le façonner."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gotovo s betom i spremno za sve. Hvala svakom testeru koji je pomogao u oblikovanju."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vége a bétának, mindenki számára készen áll. Köszönet minden tesztelőnek, aki alakította."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fuori dalla beta e pronto per tutti. Grazie a ogni tester che ha contribuito a plasmarlo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ベータを卒業し、みなさんの手元へ。形にしてくれたすべてのテスターに感謝します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "베타를 마치고 모두에게 준비되었습니다. 다듬는 데 도움을 준 모든 테스터에게 감사드립니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ute av beta og klar for alle. Takk til alle testere som var med å forme den."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uit de beta en klaar voor iedereen. Dank aan elke tester die heeft geholpen het vorm te geven."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koniec bety, gotowe dla wszystkich. Dzięki każdemu testerowi, który pomógł to ukształtować."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fora da beta e pronto para todos. Obrigado a cada testador que ajudou a moldá-lo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fora da beta e pronto para todos. Obrigado a cada testador que ajudou a moldá-lo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gata cu beta, pregătit pentru toată lumea. Mulțumim fiecărui tester care a ajutat să prindă contur."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бета позади, приложение готово для всех. Спасибо каждому тестировщику, кто помог его создать."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koniec bety, pripravené pre všetkých. Ďakujeme každému testerovi, ktorý ho pomohol formovať."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ute ur betan och redo för alla. Tack till alla testare som hjälpte till att forma den."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beta bitti, herkes için hazır. Şekillenmesine yardım eden her test kullanıcısına teşekkürler."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бета позаду, застосунок готовий для всіх. Дякуємо кожному тестувальнику, який допоміг його створити."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "结束测试版，为每个人准备就绪。感谢每一位帮助打磨它的测试者。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "結束測試版，為每個人準備就緒。感謝每一位協助打磨它的測試者。"
          }
        }
      }
    },
