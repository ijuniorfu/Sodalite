          "stringUnit" : {
            "state": "translated",
            "value": "Afișează suprapunerea jurnalului motor în player. Doar în versiunile Debug și TestFlight."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Показывает оверлей журнала движка в плеере. Только в сборках Debug и TestFlight."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zobrazí prekrytie protokolu enginu v prehrávači. Iba v ladiacich a TestFlight buildoch."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Visa motorloggöverlägget i spelaren. Endast i Debug- och TestFlight-byggen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Oynatıcıda motor günlüğü kaplamasını göster. Yalnızca Debug ve TestFlight derlemelerinde."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Показує накладку журналу рушія у плеєрі. Лише у збірках Debug та TestFlight."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在播放器中显示引擎日志叠加层。仅限调试和 TestFlight 版本。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "在播放器中顯示引擎日誌疊加層。僅限除錯和 TestFlight 版本。"
          }
        }
      }
    },
    "settings.playback.engineDiagnostics.subtitle" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Přidá čítače bufferu, sítě a subsystémů. Pro řešení potíží."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tilføjer tællere for buffer, netværk og undersystem. Til fejlfinding."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zeigt Buffer-, Netzwerk- und Subsystem-Zähler. Für Troubleshooting."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Προσθέτει μετρητές buffer, δικτύου και υποσυστημάτων. Για διάγνωση."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Adds buffer, network, and subsystem counters. For troubleshooting."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Añade contadores de búfer, red y subsistemas. Para solucionar problemas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lisää puskuri-, verkko- ja alijärjestelmälaskurit. Vianetsintään."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ajoute des compteurs de buffer, réseau et sous-systèmes. Pour le dépannage."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dodaje brojače bufera, mreže i podsustava. Za rješavanje problema."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Buffer-, hálózati és alrendszer-számlálók megjelenítése. Hibakereséshez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Aggiunge contatori di buffer, rete e sottosistemi. Per il troubleshooting."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "バッファ、ネットワーク、サブシステムのカウンタを追加します。トラブルシュート用。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "버퍼, 네트워크, 서브시스템 카운터를 추가합니다. 문제 해결용."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Legger til tellere for buffer, nettverk og delsystem. For feilsøking."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Voegt buffer-, netwerk- en subsysteemtellers toe. Voor probleemoplossing."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dodaje liczniki bufora, sieci i podsystemów. Do diagnostyki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Adiciona contadores de buffer, rede e subsistemas. Para diagnóstico."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Adiciona contadores de buffer, rede e subsistemas. Para diagnóstico."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Adaugă contoare pentru buffer, rețea și subsisteme. Pentru depanare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Добавляет счётчики буфера, сети и подсистем. Для диагностики."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pridá počítadlá bufferu, siete a podsystémov. Na riešenie problémov."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Lägger till räknare för buffert, nätverk och delsystem. För felsökning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tampon, ağ ve alt sistem sayaçları ekler. Sorun gidermek için."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Додає лічильники буфера, мережі та підсистем. Для діагностики."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "添加缓冲、网络和子系统计数器。用于故障排查。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "新增緩衝、網路和子系統計數器。用於疑難排解。"
          }
        }
      }
    },
