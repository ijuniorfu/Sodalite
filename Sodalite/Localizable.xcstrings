    "changelog.0_10_0.liveTV.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sledujte živé kanály s plnohodnotným televizním programem, oblíbenými kanály, Timeshiftem s přetáčením a plánovanými nahrávkami, jednotlivě i jako seriálové časovače."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Se live-kanaler med en komplet programguide, kanalfavoritter, timeshift med spoling og planlagte optagelser med enkelt- og serietimere."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Schau Live-Sender mit vollwertigem Programmguide, Sender-Favoriten, Timeshift mit Scrubbing und geplanten Aufnahmen, einzeln oder als Serien-Timer."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Παρακολουθήστε ζωντανά κανάλια με πλήρη οδηγό προγράμματος, αγαπημένα κανάλια, Timeshift με γρήγορη μετακίνηση και προγραμματισμένες εγγραφές με μεμονωμένους χρονοδιακόπτες ή χρονοδιακόπτες σειράς."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Watch live channels with a full programme guide, channel favorites, timeshift with scrubbing, and scheduled recordings with single and series timers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mira canales en directo con una guía de programación completa, canales favoritos, timeshift con desplazamiento y grabaciones programadas con temporizadores individuales y de serie."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Katso suoria kanavia täyden ohjelmaoppaan, kanavasuosikkien, kelattavan Timeshiftin ja ajastettujen tallennusten kanssa, yksittäin tai sarja-ajastuksina."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Regardez des chaînes en direct avec un guide des programmes complet, des chaînes favorites, le timeshift avec navigation et des enregistrements programmés avec minuteries simples et de série."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Gledajte kanale uživo uz potpuni vodič kroz program, omiljene kanale, Timeshift s premotavanjem i zakazane snimke s pojedinačnim i serijskim tajmerima."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nézz élő csatornákat teljes műsorújsággal, kedvenc csatornákkal, tekerhető Timeshifttel és ütemezett felvételekkel, egyszeri és sorozatidőzítőkkel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Guarda i canali in diretta con una guida programmi completa, canali preferiti, timeshift con scorrimento e registrazioni programmate con timer singoli e di serie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "ライブチャンネルを視聴できます。フル機能の番組表、お気に入りチャンネル、シーク可能なタイムシフト、単発予約とシリーズ予約による録画に対応しています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "전체 편성표, 채널 즐겨찾기, 탐색 가능한 타임시프트, 단일 및 시리즈 타이머 예약 녹화와 함께 라이브 채널을 시청하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Se direktekanaler med en komplett programguide, kanalfavoritter, timeshift med spoling og planlagte opptak med enkelt- og serietimere."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Kijk live zenders met een volledige programmagids, favoriete zenders, timeshift met scrubben en geplande opnamen met losse en serietimers."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Oglądaj kanały na żywo z pełnym przewodnikiem po programach, ulubionymi kanałami, funkcją Timeshift z przewijaniem oraz zaplanowanymi nagraniami z pojedynczymi i serialowymi timerami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Assista a canais ao vivo com guia de programação completo, canais favoritos, timeshift com navegação e gravações agendadas com timers únicos e de série."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Veja canais em direto com um guia de programação completo, canais favoritos, timeshift com navegação e gravações agendadas com temporizadores únicos e de série."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Urmărește canale live cu un ghid de programe complet, canale favorite, timeshift cu derulare și înregistrări programate cu temporizatoare individuale și de serial."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Смотрите каналы в прямом эфире с полноценным телегидом, избранными каналами, функцией Timeshift с перемоткой и запланированными записями с одиночными и серийными таймерами."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sledujte živé kanály s plnohodnotným programom, obľúbenými kanálmi, Timeshiftom s pretáčaním a plánovanými nahrávkami, jednotlivo aj ako seriálové časovače."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Titta på livekanaler med en komplett programguide, kanalfavoriter, timeshift med spolning och schemalagda inspelningar med enkel- och serietimer."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Canlı kanalları eksiksiz bir program rehberi, kanal favorileri, ileri geri sarılabilen Timeshift ve tekli veya dizi zamanlayıcılı planlı kayıtlarla izleyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Дивіться канали в прямому ефірі з повноцінним телегідом, обраними каналами, функцією Timeshift з перемоткою та запланованими записами з одиночними й серійними таймерами."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "观看直播频道：完整节目表、频道收藏、可拖动的时移播放，以及支持单次和剧集定时的预约录制。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "觀看直播頻道：完整節目表、頻道收藏、可拖曳的時移播放，以及支援單次與影集定時的預約錄製。"
          }
        }
      }
    },
