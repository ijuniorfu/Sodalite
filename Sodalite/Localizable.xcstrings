    "changelog.0_12_0.shuffle.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zamíchej celý seriál, kolekci nebo jakoukoli mřížku knihovny do náhodné fronty jediným tlačítkem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bland en hel serie, en samling eller et hvilket som helst biblioteksgitter til en tilfældig kø med ét tryk."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mische eine ganze Serie, eine Sammlung oder jedes Mediathek-Raster mit einem Knopf zu einer zufälligen Wiedergabeliste."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ανακάτεψε μια ολόκληρη σειρά, μια συλλογή ή οποιοδήποτε πλέγμα βιβλιοθήκης σε μια τυχαία ουρά με ένα κουμπί."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Shuffle a whole series, a collection or any library grid into a random queue with one button."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mezcla una serie entera, una colección o cualquier cuadrícula de la biblioteca en una cola aleatoria con un botón."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sekoita koko sarja, kokoelma tai mikä tahansa kirjastoruudukko satunnaiseen jonoon yhdellä painikkeella."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mélange une série entière, une collection ou n'importe quelle grille de bibliothèque en une file aléatoire d'un seul bouton."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Izmiješaj cijelu seriju, kolekciju ili bilo koju mrežu knjižnice u nasumični red jednim gumbom."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Keverj össze egy egész sorozatot, egy gyűjteményt vagy bármely könyvtárrácsot véletlenszerű sorba egyetlen gombbal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mescola un'intera serie, una raccolta o qualsiasi griglia della libreria in una coda casuale con un pulsante."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "シリーズ全体、コレクション、ライブラリの一覧を、ボタン1つでランダムなキューにシャッフルできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "버튼 하나로 시리즈 전체, 컬렉션 또는 모든 라이브러리 그리드를 무작위 대기열로 섞을 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Bland en hel serie, en samling eller et hvilket som helst bibliotekrutenett til en tilfeldig kø med én knapp."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Schud een hele serie, een collectie of elk bibliotheekraster met één knop tot een willekeurige wachtrij."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Wymieszaj cały serial, kolekcję lub dowolną siatkę biblioteki w losową kolejkę jednym przyciskiem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Embaralhe uma série inteira, uma coleção ou qualquer grade da biblioteca em uma fila aleatória com um botão."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Baralha uma série inteira, uma coleção ou qualquer grelha da biblioteca numa fila aleatória com um botão."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Amestecă un serial întreg, o colecție sau orice grilă din bibliotecă într-o coadă aleatorie cu un buton."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Перемешайте целый сериал, коллекцию или любую сетку медиатеки в случайную очередь одной кнопкой."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Zamiešaj celý seriál, kolekciu alebo akúkoľvek mriežku knižnice do náhodnej fronty jediným tlačidlom."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Blanda en hel serie, en samling eller valfritt biblioteksrutnät till en slumpmässig kö med en knapp."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tek bir düğmeyle bütün bir diziyi, koleksiyonu ya da herhangi bir kitaplık ızgarasını rastgele bir sıraya karıştırın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Перемішайте цілий серіал, колекцію або будь-яку сітку медіатеки у випадкову чергу однією кнопкою."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "一键将整部剧集、合集或任意媒体库网格打乱成随机队列。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "一鍵將整部影集、合集或任意媒體庫格狀清單打亂成隨機佇列。"
          }
        }
      }
    },
