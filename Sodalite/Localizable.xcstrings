    "changelog.0_10_0.latestRows.body" : {
      "comment": "0.10.0 What's New highlight body",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Seriály s jedinou novou epizodou se zase zobrazují jako seriál a Nejnovější seriály pokrývají všechny knihovny, žádné chybějící položky ani oříznuté snímky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serier med en enkelt ny episode vises igen som serien, og Nyeste serier dækker alle biblioteker, ikke flere manglende poster eller beskårne billeder."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serien mit nur einer neuen Folge erscheinen wieder als Serie, und Neueste Serien deckt alle Bibliotheken ab, keine fehlenden Einträge oder beschnittenen Standbilder mehr."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι σειρές με ένα μόνο νέο επεισόδιο εμφανίζονται ξανά ως σειρά και οι Τελευταίες σειρές καλύπτουν κάθε βιβλιοθήκη, χωρίς πια ελλείποντα στοιχεία ή κομμένα καρέ."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Series with a single new episode show as the series again, and Latest in TV Shows covers every library, no more missing entries or cropped stills."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Las series con un solo episodio nuevo vuelven a mostrarse como serie, y Últimas series cubre todas las bibliotecas, sin más entradas ausentes ni fotogramas recortados."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sarjat, joissa on vain yksi uusi jakso, näkyvät taas sarjana, ja Uusimmat sarjat kattaa kaikki kirjastot, ei enää puuttuvia kohteita tai rajautuneita kuvia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les séries avec un seul nouvel épisode s'affichent de nouveau comme la série, et Dernières séries couvre toutes les bibliothèques, fini les entrées manquantes ou les images recadrées."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serije s jednom novom epizodom ponovno se prikazuju kao serija, a Najnovije serije pokrivaju sve medijateke, nema više nedostajućih stavki ni obrezanih sličica."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Az egyetlen új epizóddal rendelkező sorozatok újra sorozatként jelennek meg, és a Legújabb sorozatok minden könyvtárat lefed, nincs több hiányzó elem vagy levágott állókép."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le serie con un solo nuovo episodio appaiono di nuovo come serie e Ultime serie copre tutte le librerie, niente più voci mancanti o fotogrammi tagliati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "新しいエピソードが1話だけのシリーズが再びシリーズとして表示され、「最新のドラマ」はすべてのライブラリを対象にします。項目の欠落や切り取られたサムネイルはなくなりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "새 에피소드가 하나뿐인 시리즈가 다시 시리즈로 표시되고, 최신 시리즈가 모든 라이브러리를 포함합니다. 누락된 항목이나 잘린 스틸이 더는 없습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serier med én enkelt ny episode vises igjen som serien, og Nyeste serier dekker alle biblioteker, ikke flere manglende oppføringer eller beskårne bilder."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Series met één nieuwe aflevering verschijnen weer als serie, en Nieuwste series dekt elke bibliotheek, geen ontbrekende items of bijgesneden stills meer."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Seriale z jednym nowym odcinkiem znów pokazują się jako serial, a Najnowsze seriale obejmują wszystkie biblioteki, koniec z brakującymi pozycjami i przyciętymi kadrami."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Séries com um único episódio novo voltam a aparecer como série, e Séries recentes cobre todas as bibliotecas, sem mais entradas faltando ou imagens cortadas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "As séries com um único episódio novo voltam a aparecer como série, e Últimas séries abrange todas as bibliotecas, sem mais entradas em falta ou imagens cortadas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serialele cu un singur episod nou apar din nou ca serial, iar Ultimele seriale acoperă toate bibliotecile, fără intrări lipsă sau imagini decupate."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Сериалы с одной новой серией снова отображаются как сериал, а Последние сериалы охватывают все библиотеки, больше никаких пропавших элементов и обрезанных кадров."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Seriály s jedinou novou epizódou sa opäť zobrazujú ako seriál a Najnovšie seriály pokrývajú všetky knižnice, žiadne chýbajúce položky ani orezané zábery."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serier med ett enda nytt avsnitt visas som serien igen, och Senaste serier täcker alla bibliotek, inga fler saknade poster eller beskurna bilder."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Tek yeni bölümü olan diziler yeniden dizi olarak görünüyor ve Son Diziler tüm kitaplıkları kapsıyor; eksik girişler veya kırpılmış kareler artık yok."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Серіали з одним новим епізодом знову відображаються як серіал, а Останні серіали охоплюють усі бібліотеки, більше жодних зниклих елементів чи обрізаних кадрів."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "只有一集新内容的剧集会重新以剧集形式显示，最新剧集涵盖所有媒体库，不再有缺失条目或被裁剪的剧照。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "只有一集新內容的影集會重新以影集形式顯示，最新影集涵蓋所有媒體庫，不再有缺漏項目或被裁切的劇照。"
          }
        }
      }
    },
    "changelog.0_10_0.latestRows.title" : {
      "comment": "0.10.0 What's New highlight title",
