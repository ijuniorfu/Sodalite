    "changelog.0_7_0.formats.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 a VC-1 se nyní přehrávají přímo. Rozpoznávají se kontejnery BD a DVD; podporují se zvukové stopy MLP a MP2."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 og VC-1 afspilles nu direkte. BD- og DVD-containere genkendes, og MLP- og MP2-lydspor understøttes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 und VC-1 spielen jetzt direkt; BD- und DVD-Container werden erkannt; MLP und MP2 sind als Tonspuren ergänzt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Τα VP8, MPEG-4, MPEG-2 και VC-1 αναπαράγονται πλέον απευθείας. Αναγνωρίζονται οι περιέκτες BD και DVD και υποστηρίζονται οι ηχητικές ροές MLP και MP2."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2, and VC-1 now play directly. BD and DVD containers are recognised, and MLP and MP2 audio tracks are supported."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 y VC-1 ahora se reproducen directamente. Se reconocen los contenedores BD y DVD, y se admiten pistas de audio MLP y MP2."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 ja VC-1 toistuvat nyt suoraan. BD- ja DVD-säiliöt tunnistetaan, ja MLP- ja MP2-ääniraitoja tuetaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 et VC-1 se lisent désormais directement. Les conteneurs BD et DVD sont reconnus et les pistes audio MLP et MP2 sont prises en charge."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 i VC-1 sada se reproduciraju izravno. Prepoznaju se BD i DVD spremnici, a podržane su i MLP i MP2 audio zapise."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A VP8, MPEG-4, MPEG-2 és VC-1 mostantól közvetlenül lejátszható. A BD- és DVD-tárolók felismerhetők, valamint az MLP- és MP2-hangsávok támogatottá váltak."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 e VC-1 ora si riproducono direttamente. I contenitori BD e DVD vengono riconosciuti e le tracce audio MLP e MP2 sono supportate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8、MPEG-4、MPEG-2、VC-1 が直接再生できるようになりました。BD と DVD のコンテナを認識し、MLP と MP2 の音声トラックにも対応しています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2, VC-1을 이제 바로 재생합니다. BD 및 DVD 컨테이너를 인식하고 MLP 및 MP2 오디오 트랙을 지원합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 og VC-1 spilles nå av direkte. BD- og DVD-containere gjenkjennes, og MLP- og MP2-lydspor støttes."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 en VC-1 worden nu rechtstreeks afgespeeld. BD- en DVD-containers worden herkend, en MLP- en MP2-audiosporen worden ondersteund."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 i VC-1 są teraz odtwarzane bezpośrednio. Kontenery BD i DVD są rozpoznawane, a ścieżki dźwiękowe MLP i MP2 obsługiwane."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 e VC-1 agora são reproduzidos diretamente. Os contêineres BD e DVD são reconhecidos, e as faixas de áudio MLP e MP2 são suportadas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 e VC-1 são agora reproduzidos diretamente. Os contentores BD e DVD são reconhecidos, e as faixas de áudio MLP e MP2 são suportadas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 și VC-1 se redau acum direct. Containerele BD și DVD sunt recunoscute, iar pistele audio MLP și MP2 sunt acceptate."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 и VC-1 теперь воспроизводятся напрямую. Распознаются контейнеры BD и DVD, поддерживаются звуковые дорожки MLP и MP2."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 a VC-1 sa teraz prehrávajú priamo. Rozpoznávajú sa kontajnery BD a DVD a podporujú sa zvukové stopy MLP a MP2."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 och VC-1 spelas nu upp direkt. BD- och DVD-behållare känns igen, och MLP- och MP2-ljudspår stöds."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 ve VC-1 artık doğrudan oynatılıyor. BD ve DVD kapsayıcıları tanınıyor, MLP ve MP2 ses parçaları destekleniyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8, MPEG-4, MPEG-2 і VC-1 тепер відтворюються напряму. Контейнери BD і DVD розпізнаються, а аудіодоріжки MLP і MP2 підтримуються."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8、MPEG-4、MPEG-2 与 VC-1 现在可直接播放。BD 与 DVD 容器获得识别,并支持 MLP 与 MP2 音频轨道。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "VP8、MPEG-4、MPEG-2 與 VC-1 現在可直接播放。BD 與 DVD 容器獲得辨識,並支援 MLP 與 MP2 音訊軌道。"
          }
        }
      }
    },
