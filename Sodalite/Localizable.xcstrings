    "settings.playback.subtitle.position.subtitle" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Posunout titulky nahoru nebo dolů oproti výchozí poloze."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Flyt undertekster op eller ned i forhold til standardpositionen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Untertitel relativ zur Standardposition nach oben oder unten verschieben."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Μετακινήστε τους υπότιτλους πάνω ή κάτω σε σχέση με την προεπιλεγμένη θέση."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Shift subtitles up or down from the default position."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mueve los subtítulos hacia arriba o hacia abajo respecto a la posición predeterminada."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Siirrä tekstityksiä ylös- tai alaspäin oletussijaintiin nähden."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Décaler les sous-titres vers le haut ou vers le bas par rapport à la position par défaut."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pomakni titlove gore ili dolje u odnosu na zadanu poziciju."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Feliratok mozgatása felfelé vagy lefelé az alapértelmezett pozícióhoz képest."
          }
        },
        "it" : {
