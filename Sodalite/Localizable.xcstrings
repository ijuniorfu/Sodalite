    "changelog.0_8_1.upNextOrder.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pokračovat nyní vždy přehraje následující díl místo přeskočení řady, ve které už byly některé díly zhlédnuté."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Næste afsnit afspiller nu altid det følgende afsnit i stedet for at springe over en sæson, hvor nogle afsnit allerede er set."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Als Nächstes spielt jetzt immer die direkt folgende Folge ab, statt eine Staffel zu überspringen, in der schon einige Folgen gesehen wurden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Το «Επόμενο» αναπαράγει πλέον πάντα το αμέσως επόμενο επεισόδιο, αντί να παρακάμπτει έναν κύκλο που είχε ήδη κάποια ιδωμένα επεισόδια."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Up Next now always plays the episode that comes next, instead of skipping over a season that already had some watched episodes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Siguiente ahora reproduce siempre el episodio que va a continuación, en lugar de saltarse una temporada que ya tenía algunos episodios vistos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Seuraavaksi toistaa nyt aina järjestyksessä seuraavan jakson sen sijaan, että ohittaisi kauden, jolla on jo katsottuja jaksoja."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "À suivre lit désormais toujours l'épisode qui suit, au lieu de sauter une saison qui contenait déjà des épisodes vus."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sljedeće sada uvijek reproducira sljedeću epizodu umjesto da preskoči sezonu u kojoj su neke epizode već pogledane."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A Következő mostantól mindig a soron következő epizódot játssza le, ahelyett hogy átugorna egy évadot, amelyben már voltak megnézett epizódok."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Da vedere ora riproduce sempre l'episodio successivo, invece di saltare una stagione che aveva già alcuni episodi visti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "「次に再生」は、視聴済みのエピソードがあるシーズンを飛ばさず、常に次のエピソードを再生するようになりました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "다음 재생이 이제 이미 시청한 에피소드가 있는 시즌을 건너뛰지 않고 항상 바로 다음 에피소드를 재생합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Neste spiller nå alltid den påfølgende episoden i stedet for å hoppe over en sesong som allerede hadde noen sette episoder."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Volgende speelt nu altijd de eerstvolgende aflevering af in plaats van een seizoen over te slaan waarin al enkele afleveringen bekeken zijn."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Następny odcinek odtwarza teraz zawsze kolejny odcinek, zamiast pomijać sezon, w którym obejrzano już niektóre odcinki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A Seguir agora sempre reproduz o episódio seguinte, em vez de pular uma temporada que já tinha alguns episódios assistidos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A Seguir reproduz agora sempre o episódio seguinte, em vez de saltar uma temporada que já tinha alguns episódios vistos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Urmează redă acum întotdeauna episodul care urmează, în loc să sară peste un sezon care avea deja câteva episoade vizionate."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "«Далее» теперь всегда воспроизводит следующий по порядку эпизод, а не пропускает сезон, в котором уже есть просмотренные эпизоды."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ďalej teraz vždy prehrá nasledujúcu epizódu namiesto preskočenia série, v ktorej už boli niektoré epizódy pozreté."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nästa spelar nu alltid upp det följande avsnittet i stället för att hoppa över en säsong som redan hade några sedda avsnitt."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sıradaki artık izlenmiş bölümleri olan bir sezonu atlamak yerine her zaman bir sonraki bölümü oynatıyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "«Далі» тепер завжди відтворює наступний за порядком епізод, а не пропускає сезон, у якому вже є переглянуті епізоди."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "“下一集”现在总是播放紧接着的下一集，而不会跳过已经看过部分剧集的某一季。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "「下一集」現在一律播放緊接著的下一集，而不會跳過已經看過部分集數的某一季。"
          }
        }
      }
    },
