    "changelog.0_9_0.surround.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vícekanálový zvuk se na některých přijímačích už nemíchá do sterea, když je vypnuté plynulé přehrávání zvuku."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Flerkanalslyd mikses ikke længere ned til stereo på visse receivere, når kontinuerlig lyd er slået fra."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Mehrkanal-Ton wird auf manchen Receivern nicht mehr auf Stereo heruntergemischt, wenn fortlaufende Audiowiedergabe deaktiviert ist."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ο πολυκαναλικός ήχος δεν υποβιβάζεται πλέον σε στερεοφωνικό σε ορισμένους δέκτες όταν είναι απενεργοποιημένη η συνεχής αναπαραγωγή ήχου."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Multichannel audio no longer downmixes to stereo on some receivers when continuous audio is turned off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "El audio multicanal ya no se mezcla a estéreo en algunos receptores cuando el audio continuo está desactivado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Monikanavaääni ei enää alasmiksaudu stereoksi joissakin vahvistimissa, kun jatkuva ääni on pois käytöstä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "L'audio multicanal n'est plus mixé en stéréo sur certains amplis lorsque l'audio continu est désactivé."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Višekanalni zvuk više se ne miješa u stereo na nekim prijemnicima kada je neprekidna reprodukcija zvuka isključena."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A többcsatornás hang egyes erősítőkön többé nem keveredik le sztereóra, amikor a folyamatos hanglejátszás ki van kapcsolva."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "L'audio multicanale non viene più ridotto a stereo su alcuni ricevitori quando l'audio continuo è disattivato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "連続再生をオフにしたとき、一部のレシーバーでマルチチャンネル音声がステレオにダウンミックスされる不具合を解消しました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "연속 재생을 끈 경우 일부 리시버에서 멀티채널 오디오가 스테레오로 다운믹스되던 문제를 해결했습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Flerkanalslyd mikses ikke lenger ned til stereo på enkelte mottakere når kontinuerlig lyd er slått av."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Meerkanaals audio wordt op sommige receivers niet meer teruggemengd naar stereo wanneer continue audio is uitgeschakeld."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Dźwięk wielokanałowy nie jest już miksowany do stereo na niektórych amplitunerach, gdy ciągłe odtwarzanie dźwięku jest wyłączone."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O áudio multicanal não é mais reduzido para estéreo em alguns receptores quando o áudio contínuo está desativado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O áudio multicanal deixa de ser reduzido para estéreo em alguns recetores quando o áudio contínuo está desativado."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sunetul multicanal nu mai este redus la stereo pe unele receptoare atunci când redarea audio continuă este dezactivată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Многоканальный звук больше не сводится к стерео на некоторых ресиверах, когда непрерывное воспроизведение звука отключено."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Viackanálový zvuk sa na niektorých prijímačoch už nemieša do sterea, keď je vypnuté plynulé prehrávanie zvuku."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Flerkanalsljud mixas inte längre ned till stereo på vissa mottagare när kontinuerligt ljud är avstängt."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sürekli ses kapalıyken çok kanallı ses, bazı alıcılarda artık stereoya indirgenmiyor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Багатоканальний звук більше не зводиться до стерео на деяких ресиверах, коли безперервне відтворення звуку вимкнено."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "关闭连续播放时，多声道音频不再在部分功放上被下混为立体声。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "關閉連續播放時，多聲道音訊不再在部分擴大機上被下混為立體聲。"
          }
        }
      }
    },
