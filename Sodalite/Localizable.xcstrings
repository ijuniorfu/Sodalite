    "changelog.0_5_0.dolbyVision.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV streamy se nyní signalizují jako 'dvh1' se správnou konfigurací 'dvcC', takže televizory podporující DV přepnou do režimu Dolby Vision u obsahu Profile 5, 8.1 a 8.4."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV-streams signaleres nu som 'dvh1' med korrekt 'dvcC'-konfiguration, så DV-kompatible tv-apparater skifter til Dolby Vision-tilstand ved Profile 5-, 8.1- og 8.4-indhold."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV-Streams werden jetzt als 'dvh1' mit korrekter 'dvcC'-Konfiguration signalisiert, sodass DV-fähige Fernseher für Profil 5, 8.1 und 8.4 in den Dolby-Vision-Modus wechseln."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Οι ροές DV σηματοδοτούνται πλέον ως 'dvh1' με τη σωστή διαμόρφωση 'dvcC', ώστε οι τηλεοράσεις με υποστήριξη DV να εναλλάσσονται στη λειτουργία Dolby Vision για περιεχόμενο Profile 5, 8.1 και 8.4."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV streams now signal as 'dvh1' with the proper 'dvcC' configuration so DV-capable TVs switch into Dolby Vision mode for Profile 5, 8.1 and 8.4 content."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Los flujos de DV se identifican ahora como 'dvh1' con la configuración 'dvcC' correcta, de modo que los televisores compatibles con DV cambian al modo Dolby Vision para contenido de los perfiles 5, 8.1 y 8.4."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV-virrat tunnistetaan nyt nimellä 'dvh1' oikealla 'dvcC'-määrityksellä, jotta DV-yhteensopivat televisiot vaihtavat Dolby Vision -tilaan Profile 5-, 8.1- ja 8.4-sisällössä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Les flux DV s'identifient désormais comme 'dvh1' avec la configuration 'dvcC' adéquate, ce qui fait basculer les téléviseurs compatibles DV en mode Dolby Vision pour les profils 5, 8.1 et 8.4."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV streamovi sada se signaliziraju kao 'dvh1' s ispravnom 'dvcC' konfiguracijom, pa televizori koji podržavaju DV prebacuju u Dolby Vision način za sadržaj profila 5, 8.1 i 8.4."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A DV-folyamok mostantól 'dvh1' jelzéssel és helyes 'dvcC'-konfigurációval érkeznek, így a DV-kompatibilis tévék Dolby Vision módba váltanak Profile 5-ös, 8.1-es és 8.4-es tartalmaknál."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "I flussi DV vengono ora identificati come 'dvh1' con la corretta configurazione 'dvcC', così i TV compatibili con DV passano alla modalità Dolby Vision per i contenuti Profile 5, 8.1 e 8.4."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DVストリームを正しい「dvcC」構成とともに「dvh1」としてシグナリングするようになりました。Profile 5・8.1・8.4のコンテンツでDV対応テレビがDolby Visionモードに切り替わります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV 스트림이 올바른 'dvcC' 구성과 함께 'dvh1'으로 시그널링되며, Profile 5, 8.1, 8.4 콘텐츠에서 DV 지원 TV가 Dolby Vision 모드로 전환됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV-strømmer signaleres nå som 'dvh1' med korrekt 'dvcC'-konfigurasjon, slik at DV-kompatible TV-er bytter til Dolby Vision-modus for Profile 5-, 8.1- og 8.4-innhold."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV-streams worden nu aangeduid als 'dvh1' met de juiste 'dvcC'-configuratie, zodat DV-compatibele tv's overschakelen naar de Dolby Vision-modus voor inhoud uit Profile 5, 8.1 en 8.4."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Strumienie DV są teraz oznaczane jako 'dvh1' z poprawną konfiguracją 'dvcC', dzięki czemu telewizory zgodne z DV przełączają się w tryb Dolby Vision dla treści Profile 5, 8.1 i 8.4."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Streams de DV agora se identificam como 'dvh1' com a configuração 'dvcC' correta, fazendo com que TVs compatíveis com DV mudem para o modo Dolby Vision em conteúdo Profile 5, 8.1 e 8.4."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Streams de DV identificam-se agora como 'dvh1' com a configuração 'dvcC' correcta, fazendo com que TVs compatíveis com DV passem para o modo Dolby Vision em conteúdo Profile 5, 8.1 e 8.4."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fluxurile DV se semnalează acum ca 'dvh1' cu configurația 'dvcC' corectă, astfel încât televizoarele compatibile DV trec în modul Dolby Vision pentru conținut Profile 5, 8.1 și 8.4."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Потоки DV теперь сигнализируются как 'dvh1' с корректной конфигурацией 'dvcC', чтобы DV-совместимые телевизоры переключались в режим Dolby Vision для контента Profile 5, 8.1 и 8.4."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV streamy sa teraz signalizujú ako 'dvh1' so správnou konfiguráciou 'dvcC', takže televízory podporujúce DV prepnú do režimu Dolby Vision pri obsahu Profile 5, 8.1 a 8.4."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV-strömmar signaleras nu som 'dvh1' med korrekt 'dvcC'-konfiguration, så att DV-kompatibla tv-apparater växlar till Dolby Vision-läge för Profile 5-, 8.1- och 8.4-innehåll."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV akışları artık doğru 'dvcC' yapılandırmasıyla 'dvh1' olarak işaretlenir, böylece DV uyumlu TV'ler Profile 5, 8.1 ve 8.4 içeriklerinde Dolby Vision moduna geçer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Потоки DV тепер сигналізуються як 'dvh1' з коректною конфігурацією 'dvcC', щоб DV-сумісні телевізори перемикалися в режим Dolby Vision для контенту Profile 5, 8.1 і 8.4."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV 流现在以正确的 'dvcC' 配置作为 'dvh1' 进行信号传递,以便支持 DV 的电视为 Profile 5、8.1 和 8.4 内容切换到 Dolby Vision 模式。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "DV 串流現在以正確的 'dvcC' 設定作為 'dvh1' 進行訊號傳遞,讓支援 DV 的電視為 Profile 5、8.1 和 8.4 內容切換至 Dolby Vision 模式。"
          }
        }
      }
    },
