    "delete.toast.partialSuccess" : {
      "comment": "Toast when Jellyfin delete succeeded but the *arr cascade did not",
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Odstraněno z Jellyfin, ale záznam v Radarr / Sonarr nešlo odstranit."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Fjernet fra Jellyfin, men Radarr / Sonarr-posten kunne ikke fjernes."
          }
