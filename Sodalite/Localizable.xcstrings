    "changelog.0_12_0.subtitleSearch.body" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Najdi a stáhni správné titulky přímo v přehrávači. Soubory shodné podle otisku dostanou odznak a ty, které jsi přidal, smažeš dlouhým stiskem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Find og hent det rigtige undertekstspor direkte i afspilleren. Hash-matchede filer får et mærke, og dem du selv har tilføjet, kan fjernes med et langt tryk."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Finde und lade den passenden Untertitel direkt im Player. Hash-genaue Treffer bekommen ein Abzeichen, selbst hinzugefügte lassen sich per langem Druck entfernen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Βρες και κατέβασε το σωστό κανάλι υποτίτλων μέσα από τον player. Τα αρχεία με αντιστοίχιση hash παίρνουν σήμα, ενώ όσα πρόσθεσες αφαιρούνται με παρατεταμένο πάτημα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Find and download the right subtitle track from inside the player. Hash-matched files get a badge, and ones you added can be removed with a long press."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Encuentra y descarga la pista de subtítulos correcta desde el reproductor. Los archivos que coinciden por hash llevan una insignia, y los que añadas se eliminan con una pulsación larga."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Etsi ja lataa oikea tekstitysraita suoraan soittimessa. Hash-osumat saavat merkin, ja itse lisäämäsi voi poistaa pitkällä painalluksella."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Trouve et télécharge la bonne piste de sous-titres directement dans le lecteur. Les fichiers correspondant par empreinte reçoivent un badge, et ceux que tu ajoutes se suppriment par appui long."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Pronađi i preuzmi pravi zapis titlova izravno u playeru. Datoteke usklađene po hashu dobivaju oznaku, a one koje si dodao uklanjaju se dugim pritiskom."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Keresd meg és töltsd le a megfelelő feliratsávot a lejátszón belül. A hash alapján egyező fájlok jelölést kapnak, a magad által hozzáadottak pedig hosszú nyomással törölhetők."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Trova e scarica la traccia di sottotitoli giusta direttamente nel player. I file corrispondenti per hash ricevono un badge e quelli che aggiungi si rimuovono con una pressione prolungata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "プレーヤー内から適切な字幕トラックを検索してダウンロードできます。ハッシュ一致したファイルにはバッジが付き、自分で追加したものは長押しで削除できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "플레이어 안에서 알맞은 자막 트랙을 찾아 내려받으세요. 해시가 일치하는 파일에는 배지가 붙고, 직접 추가한 파일은 길게 눌러 삭제할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Finn og last ned riktig undertekstspor rett i spilleren. Hash-treff får et merke, og de du selv la til, kan fjernes med et langt trykk."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Vind en download het juiste ondertitelspoor rechtstreeks in de speler. Bestanden met een hash-match krijgen een markering en wat je zelf toevoegt, verwijder je met lang indrukken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Znajdź i pobierz właściwą ścieżkę napisów bezpośrednio w odtwarzaczu. Pliki dopasowane skrótem dostają odznakę, a dodane przez Ciebie usuniesz długim naciśnięciem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Encontre e baixe a faixa de legenda certa de dentro do player. Arquivos com correspondência por hash recebem um selo, e os que você adicionou podem ser removidos com um toque longo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Encontra e transfere a faixa de legendas certa a partir do leitor. Os ficheiros com correspondência por hash recebem um selo e os que adicionaste removem-se com uma pressão longa."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Găsește și descarcă pista de subtitrare potrivită direct din player. Fișierele potrivite prin hash primesc o insignă, iar cele adăugate de tine se elimină cu o apăsare lungă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Находите и скачивайте нужную дорожку субтитров прямо в плеере. Файлы, совпавшие по хешу, получают значок, а добавленные вами можно удалить долгим нажатием."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Nájdi a stiahni správnu stopu titulkov priamo v prehrávači. Súbory zhodné podľa odtlačku dostanú odznak a tie, ktoré si pridal, zmažeš dlhým stlačením."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Hitta och ladda ner rätt undertextspår direkt i spelaren. Hash-matchade filer får en bricka, och de du själv lagt till tas bort med ett långt tryck."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Doğru altyazı izini doğrudan oynatıcıdan bulup indirin. Hash ile eşleşen dosyalar bir rozet alır, eklediklerinizi ise uzun basarak kaldırabilirsiniz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Знаходьте й завантажуйте потрібну доріжку субтитрів прямо в плеєрі. Файли, що збіглися за хешем, отримують значок, а додані вами можна видалити довгим натисканням."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "直接在播放器中查找并下载合适的字幕轨道。哈希匹配的文件会显示标记，你添加的字幕可长按删除。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "直接在播放器中尋找並下載合適的字幕軌。雜湊比對相符的檔案會顯示標記，你新增的字幕可長按刪除。"
          }
        }
      }
    },
