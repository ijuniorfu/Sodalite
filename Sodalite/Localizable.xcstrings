    "livetv.recording.error.message" : {
      "extractionState": "manual",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Server nemohl naplánovat nahrávání. Zkontrolujte, zda je v Jellyfinu nastavena cesta pro nahrávky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serveren kunne ikke planlægge optagelsen. Kontroller, at der er konfigureret en optagelsessti i Jellyfin."
          }
        },
        "de" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Der Server konnte die Aufnahme nicht planen. Prüfe, ob in Jellyfin ein Aufnahmepfad konfiguriert ist."
          }
        },
        "el" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Ο διακομιστής δεν μπόρεσε να προγραμματίσει την εγγραφή. Έλεγξε αν έχει οριστεί διαδρομή εγγραφών στο Jellyfin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state": "translated",
            "value": "The server could not schedule the recording. Check that a recording path is configured in Jellyfin."
          }
        },
        "es" : {
          "stringUnit" : {
            "state": "translated",
            "value": "El servidor no pudo programar la grabación. Comprueba que haya una ruta de grabación configurada en Jellyfin."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Palvelin ei voinut ajastaa tallennusta. Tarkista, että Jellyfiniin on määritetty tallennuspolku."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Le serveur n'a pas pu programmer l'enregistrement. Vérifiez qu'un chemin d'enregistrement est configuré dans Jellyfin."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Poslužitelj nije mogao zakazati snimanje. Provjeri je li u Jellyfinu postavljena putanja za snimke."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state": "translated",
            "value": "A szerver nem tudta ütemezni a felvételt. Ellenőrizd, hogy a Jellyfinben be van-e állítva felvételi útvonal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Il server non è riuscito a programmare la registrazione. Verifica che in Jellyfin sia configurato un percorso di registrazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state": "translated",
            "value": "サーバーが録画を予約できませんでした。Jellyfinで録画パスが設定されているか確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state": "translated",
            "value": "서버가 녹화를 예약하지 못했습니다. Jellyfin에 녹화 경로가 설정되어 있는지 확인하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serveren kunne ikke planlegge opptaket. Sjekk at en opptaksbane er konfigurert i Jellyfin."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "De server kon de opname niet inplannen. Controleer of er een opnamepad is ingesteld in Jellyfin."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serwer nie mógł zaplanować nagrania. Sprawdź, czy w Jellyfinie skonfigurowano ścieżkę nagrań."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O servidor não conseguiu agendar a gravação. Verifique se um caminho de gravação está configurado no Jellyfin."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state": "translated",
            "value": "O servidor não conseguiu agendar a gravação. Verifique se está configurado um caminho de gravação no Jellyfin."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Serverul nu a putut programa înregistrarea. Verifică dacă în Jellyfin este configurată o cale de înregistrare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Сервер не смог запланировать запись. Проверьте, настроен ли путь для записей в Jellyfin."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Server nemohol naplánovať nahrávanie. Skontrolujte, či je v Jellyfine nastavená cesta pre nahrávky."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Servern kunde inte schemalägga inspelningen. Kontrollera att en inspelningssökväg är konfigurerad i Jellyfin."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Sunucu kaydı planlayamadı. Jellyfin'de bir kayıt yolunun yapılandırıldığından emin olun."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state": "translated",
            "value": "Сервер не зміг запланувати запис. Перевірте, чи налаштовано шлях для записів у Jellyfin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state": "translated",
            "value": "服务器无法预约录制。请检查 Jellyfin 中是否已配置录制路径。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state": "translated",
            "value": "伺服器無法預約錄製。請檢查 Jellyfin 中是否已設定錄製路徑。"
          }
        }
      }
    },
    "livetv.recording.error.title" : {
      "extractionState": "manual",
